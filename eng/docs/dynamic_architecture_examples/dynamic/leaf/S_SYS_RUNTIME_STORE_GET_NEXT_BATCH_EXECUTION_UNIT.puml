@startuml
title Load next dispatchable batch execution unit from AIOS managed storage

hide footbox
autonumber 10 10
skinparam BoxPadding 12
skinparam SequenceMessageAlign center
skinparam Shadowing false
skinparam ParticipantPadding 18
skinparam ResponseMessageBelowArrow true
skinparam DefaultFontName Monospace

participant "Caller\n(AgentRuntime)" as SYS_AR

box "AIOS — System Components" #F3F3F3
  control "RuntimeStore" as SYS_RS <<component>>
  control "Core" as SYS_Core <<component>>
  control "ToolsAdapter\n(MCP client / ToolBus)" as SYS_Tools <<component>>
end box

box "External Environment" #EEF5FF
  database "AIOS Managed Storage\n(.aios)" as EXT_AIOS <<external>>
end box

note over SYS_AR, EXT_AIOS #FFF8DC
S_SYS_RUNTIME_STORE_GET_NEXT_BATCH_EXECUTION_UNIT
end note

note over SYS_RS, SYS_Tools
  RuntimeStore owns batch dispatch-order semantics.
  ToolsAdapter provides the physical access path to AIOS managed storage.
  Core validates persisted artifacts before RuntimeStore parses and derives dispatch context.
end note

note over SYS_RS
  This slice returns the next dispatchable runtime child batch execution unit
  for one active parent task.
end note

group S1 "AgentRuntime requests next dispatchable batch execution unit"
  SYS_AR -> SYS_RS : IF_SYS_RUNTIME_STORE.get_next_batch_execution_unit(ctx:CallContext, run_ref:str, task_id:str) -> Result[BatchExecutionUnitDispatchContext]\n[step=S1.1]\n[connection use_port=P_AR_USE_RUNTIME_STORE; prov_port=P_RS_PROV_RUNTIME_STORE; conn=C_AR__RS__RUNTIME_STORE]\n[vals run_ref=run_ref; task_id=task_id]
  activate SYS_RS

  alt [COND=run_ref is null or malformed or task_id is null or malformed]
    SYS_RS --> SYS_AR : [step=S1.2]\n[vals result.outcome=err; result.err.category=INPUT; result.err.code=BATCH_EXECUTION_UNIT_REF_INVALID]
    deactivate SYS_RS
    stop
  end
end

group S2 "RuntimeStore loads, validates, and parses task runtime index"
  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.read_text(ctx:CallContext, path:str, opts?:FSReadOptions) -> Result[ReadTextResult]\n[step=S2.1]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/runs/<run_ref>/task_runtime_index.json"; opts.encoding="utf-8"]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_READ_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S2.1r]\n[vals result.outcome=(ok|err); result.err.code=<fs_error_if_any>]

  alt [COND=result.outcome=err]
    SYS_RS -> SYS_RS : classify_task_runtime_index_read_error(result.err)\n[step=S2.2]\n[vals mapped_code=TASK_RUNTIME_INDEX_UNAVAILABLE]
    SYS_RS --> SYS_AR : [step=S2.3]\n[vals result.outcome=err; result.err.category=(NOT_FOUND|DEPENDENCY); result.err.code=TASK_RUNTIME_INDEX_UNAVAILABLE]
    deactivate SYS_RS
    stop
  end

  SYS_RS -> SYS_Core : IF_SYS_CORE_SERVICE.validate(ctx:CallContext, items:[ValidationItem], fw:FrameworkHandle) -> Result[ValidationBatchResult]\n[step=S2.4]\n[connection use_port=P_RS_USE_CORE_SERVICE; prov_port=P_CORE_PROV_CORE_SERVICE; conn=C_RS__CORE__CORE_SERVICE]\n[vals items=[{item_id="task_runtime_index"; kind=ARTIFACT; content_type="application/json"; payload_text="<task_runtime_index_json>"}]]
  ref over SYS_RS, SYS_Core
    expand=S_SYS_CORE_VALIDATE
    op=IF_SYS_CORE_SERVICE.validate
    note="Validate task_runtime_index.json before parse."
  end ref
  SYS_Core --> SYS_RS : [step=S2.4r]\n[vals result.outcome=(ok|err); result.ok.overall_status=(PASS|FAIL)]

  alt [COND=result.outcome=err or result.ok.overall_status=FAIL]
    SYS_RS --> SYS_AR : [step=S2.5]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=TASK_RUNTIME_INDEX_INVALID]
    deactivate SYS_RS
    stop
  else [COND=INDEX_VALID]
    SYS_RS -> SYS_RS : task_runtime_index=parse_task_runtime_index("<task_runtime_index_json>")\n[step=S2.6]
  end

  alt [COND=task_id not ready for batch execution according to task_runtime_index]
    SYS_RS --> SYS_AR : [step=S2.7]\n[vals result.outcome=err; result.err.category=CONFLICT; result.err.code=TASK_NOT_READY_FOR_BATCH_EXECUTION]
    deactivate SYS_RS
    stop
  end
end

group S3 "RuntimeStore loads, validates, and parses batch execution-unit index"
  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.read_text(ctx:CallContext, path:str, opts?:FSReadOptions) -> Result[ReadTextResult]\n[step=S3.1]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/runs/<run_ref>/tasks/<task_id>/batch_execution_unit_index.json"; opts.encoding="utf-8"]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_READ_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S3.1r]\n[vals result.outcome=(ok|err); result.err.code=<fs_error_if_any>]

  alt [COND=result.outcome=err]
    SYS_RS -> SYS_RS : classify_batch_unit_index_read_error(result.err)\n[step=S3.2]\n[vals mapped_code=BATCH_EXECUTION_UNIT_INDEX_UNAVAILABLE]
    SYS_RS --> SYS_AR : [step=S3.3]\n[vals result.outcome=err; result.err.category=(NOT_FOUND|DEPENDENCY); result.err.code=BATCH_EXECUTION_UNIT_INDEX_UNAVAILABLE]
    deactivate SYS_RS
    stop
  end

  SYS_RS -> SYS_Core : IF_SYS_CORE_SERVICE.validate(ctx:CallContext, items:[ValidationItem], fw:FrameworkHandle) -> Result[ValidationBatchResult]\n[step=S3.4]\n[connection use_port=P_RS_USE_CORE_SERVICE; prov_port=P_CORE_PROV_CORE_SERVICE; conn=C_RS__CORE__CORE_SERVICE]\n[vals items=[{item_id="batch_execution_unit_index"; kind=ARTIFACT; content_type="application/json"; payload_text="<batch_execution_unit_index_json>"}]]
  ref over SYS_RS, SYS_Core
    expand=S_SYS_CORE_VALIDATE
    op=IF_SYS_CORE_SERVICE.validate
    note="Validate batch_execution_unit_index.json before parse."
  end ref
  SYS_Core --> SYS_RS : [step=S3.4r]\n[vals result.outcome=(ok|err); result.ok.overall_status=(PASS|FAIL)]

  alt [COND=result.outcome=err or result.ok.overall_status=FAIL]
    SYS_RS --> SYS_AR : [step=S3.5]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=BATCH_EXECUTION_UNIT_INDEX_INVALID]
    deactivate SYS_RS
    stop
  else [COND=INDEX_VALID]
    SYS_RS -> SYS_RS : batch_execution_unit_index=parse_batch_execution_unit_index("<batch_execution_unit_index_json>")\n[step=S3.6]
  end
end

group S4 "RuntimeStore loads and validates candidate batch execution-unit records"
  note over SYS_RS
    RuntimeStore may load one or more candidate unit records to evaluate:
    - dispatch order
    - current unit state
    - attempts_used / max_attempts
    - resumability / retryability
  end note

  loop [COND=for each candidate_unit_id in batch_execution_unit_index.stable_order]
    SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.read_text(ctx:CallContext, path:str, opts?:FSReadOptions) -> Result[ReadTextResult]\n[step=S4.1]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/runs/<run_ref>/tasks/<task_id>/batches/<candidate_unit_id>.json"; opts.encoding="utf-8"]
    ref over SYS_RS, SYS_Tools, EXT_AIOS
      expand=S_SYS_TOOL_BUS_FS_READ_TEXT
      ref_mode=call_return
    end ref
    SYS_Tools --> SYS_RS : [step=S4.1r]\n[vals result.outcome=(ok|err); result.err.code=<fs_error_if_any>]

    alt [COND=result.outcome=err]
      SYS_RS --> SYS_AR : [step=S4.2]\n[vals result.outcome=err; result.err.category=(NOT_FOUND|DEPENDENCY); result.err.code=BATCH_EXECUTION_UNIT_UNAVAILABLE]
      deactivate SYS_RS
      stop
    else [COND=READ_OK]
      SYS_RS -> SYS_Core : IF_SYS_CORE_SERVICE.validate(ctx:CallContext, items:[ValidationItem], fw:FrameworkHandle) -> Result[ValidationBatchResult]\n[step=S4.3]\n[connection use_port=P_RS_USE_CORE_SERVICE; prov_port=P_CORE_PROV_CORE_SERVICE; conn=C_RS__CORE__CORE_SERVICE]\n[vals items=[{item_id="batch_execution_unit"; kind=ARTIFACT; content_type="application/json"; payload_text="<batch_execution_unit_json>"}]]
      ref over SYS_RS, SYS_Core
        expand=S_SYS_CORE_VALIDATE
        op=IF_SYS_CORE_SERVICE.validate
        note="Validate batch execution-unit record before parse."
      end ref
      SYS_Core --> SYS_RS : [step=S4.3r]\n[vals result.outcome=(ok|err); result.ok.overall_status=(PASS|FAIL)]

      alt [COND=result.outcome=err or result.ok.overall_status=FAIL]
        SYS_RS --> SYS_AR : [step=S4.4]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=BATCH_EXECUTION_UNIT_INVALID]
        deactivate SYS_RS
        stop
      else [COND=UNIT_VALID]
        SYS_RS -> SYS_RS : candidate_unit=parse_batch_execution_unit("<batch_execution_unit_json>")\n[step=S4.5]
      end
    end
  end
end

group S5 "RuntimeStore derives next dispatchable unit"
  SYS_RS -> SYS_RS : derive_next_batch_execution_unit(task_runtime_index, batch_execution_unit_index, candidate_units)\n[step=S5.1]\n[vals rules={prefer earliest non-terminal unit in stable batch order; allow READY/PENDING; allow RETRYABLE_FAIL/NEEDS_CHANGE only when attempts remain; exclude COMPLETED/FAILED/BLOCKED}]
  alt [COND=derived.next_unit is null]
    SYS_RS --> SYS_AR : [step=S5.2]\n[vals result.outcome=ok; result.ok.status=NO_DISPATCHABLE_BATCH_EXECUTION_UNIT; result.ok.task_id=task_id]
    deactivate SYS_RS
    stop
  else [COND=DISPATCHABLE_UNIT_FOUND]
    SYS_RS --> SYS_AR : [step=S5.3]\n[vals result.outcome=ok; result.ok.status=BATCH_EXECUTION_UNIT_READY; result.ok.batch_execution_unit_id=<derived.next_unit.id>; result.ok.dispatch_context=<BatchExecutionUnitDispatchContext>]
    deactivate SYS_RS
  end
end

@enduml