@startuml
title Validate progress subscription target from AIOS managed storage

hide footbox
autonumber 10 10
skinparam BoxPadding 12
skinparam SequenceMessageAlign center
skinparam Shadowing false
skinparam ParticipantPadding 18
skinparam ResponseMessageBelowArrow true
skinparam DefaultFontName Monospace

participant "Caller\n(AgentRuntime)" as SYS_AR

box "AIOS — System Components" #F3F3F3
  control "RuntimeStore" as SYS_RS <<component>>
  control "Core" as SYS_Core <<component>>
  control "ToolsAdapter\n(MCP client / ToolBus)" as SYS_Tools <<component>>
end box

box "External Environment" #EEF5FF
  database "AIOS Managed Storage\n(.aios)" as EXT_AIOS <<external>>
end box

note over SYS_AR, EXT_AIOS #FFF8DC
S_SYS_RUNTIME_STORE_GET_PROGRESS_SUBSCRIPTION_TARGET
end note

note over SYS_RS, SYS_Tools
  RuntimeStore owns observable-scope validation semantics.
  ToolsAdapter provides the physical access path to AIOS managed storage.
  Core validates persisted target artifacts before RuntimeStore parses and decides eligibility.
end note

note over SYS_RS
  This slice validates whether a requested observable scope exists
  and is eligible for live progress subscription.
  MVP supports run scope only.
end note

group S1 "AgentRuntime requests subscription-target validation"
  SYS_AR -> SYS_RS : IF_SYS_RUNTIME_STORE.get_progress_subscription_target(ctx:CallContext, scope_kind:ObservableScopeKind, scope_ref:str) -> Result[ProgressSubscriptionTarget]\n[step=S1.1]\n[connection use_port=P_AR_USE_RUNTIME_STORE; prov_port=P_RS_PROV_RUNTIME_STORE; conn=C_AR__RS__RUNTIME_STORE]\n[vals scope_kind=scope_kind; scope_ref=scope_ref]
  activate SYS_RS
end

group S2 "RuntimeStore validates requested observable scope"
  SYS_RS -> SYS_RS : validate_subscription_scope(scope_kind, scope_ref)\n[step=S2.1]\n[vals validate={scope_kind_supported, scope_ref_shape}]
  alt [COND=validate.code=SCOPE_KIND_UNSUPPORTED]
    SYS_RS --> SYS_AR : [step=S2.2]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=SCOPE_KIND_UNSUPPORTED]
    deactivate SYS_RS
    stop
  else [COND=validate.code=SUBSCRIPTION_TARGET_INVALID]
    SYS_RS --> SYS_AR : [step=S2.3]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=SUBSCRIPTION_TARGET_INVALID]
    deactivate SYS_RS
    stop
  end
end

group S3 "RuntimeStore loads, validates, and parses requested run target"
  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.read_text(ctx:CallContext, path:str, opts?:FSReadOptions) -> Result[ReadTextResult]\n[step=S3.1]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/runs/<scope_ref>/run_meta.json"; opts.encoding="utf-8"]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_READ_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S3.1r]\n[vals result.outcome=(ok|err); result.err.code=<fs_error_if_any>]

  alt [COND=result.outcome=err]
    SYS_RS -> SYS_RS : classify_subscription_target_read_error(result.err)\n[step=S3.2]\n[vals mapped_code=SUBSCRIPTION_TARGET_NOT_FOUND]
    SYS_RS --> SYS_AR : [step=S3.3]\n[vals result.outcome=err; result.err.category=NOT_FOUND; result.err.code=SUBSCRIPTION_TARGET_NOT_FOUND]
    deactivate SYS_RS
    stop
  end

  SYS_RS -> SYS_Core : IF_SYS_CORE_SERVICE.validate(ctx:CallContext, items:[ValidationItem], fw:FrameworkHandle) -> Result[ValidationBatchResult]\n[step=S3.4]\n[connection use_port=P_RS_USE_CORE_SERVICE; prov_port=P_CORE_PROV_CORE_SERVICE; conn=C_RS__CORE__CORE_SERVICE]\n[vals items=[{item_id="run_meta"; kind=ARTIFACT; content_type="application/json"; payload_text="<run_meta_json>"}]]
  ref over SYS_RS, SYS_Core
    expand=S_SYS_CORE_VALIDATE
    op=IF_SYS_CORE_SERVICE.validate
    note="Validate run_meta.json before parse for subscription eligibility."
  end ref
  SYS_Core --> SYS_RS : [step=S3.4r]\n[vals result.outcome=(ok|err); result.ok.overall_status=(PASS|FAIL)]

  alt [COND=result.outcome=err or result.ok.overall_status=FAIL]
    SYS_RS --> SYS_AR : [step=S3.5]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=SUBSCRIPTION_TARGET_INVALID]
    deactivate SYS_RS
    stop
  else [COND=RUN_META_VALID]
    SYS_RS -> SYS_RS : run_meta=parse_run_meta("<run_meta_json>")\n[step=S3.6]
  end
end

group S4 "RuntimeStore checks live-subscription eligibility"
  SYS_RS -> SYS_RS : evaluate_subscription_eligibility(scope_kind, scope_ref, run_meta)\n[step=S4.1]\n[vals eligibility=(ALLOWED|DENIED); scope_state=run_meta.run_state]

  alt [COND=eligibility=DENIED]
    note over SYS_RS
      Examples:
      - target is terminal and no longer publishable
      - target policy forbids live subscription
      - target exists but is outside supported observable lifecycle
    end note
    SYS_RS --> SYS_AR : [step=S4.2]\n[vals result.outcome=err; result.err.category=AUTHORIZATION; result.err.code=SUBSCRIPTION_NOT_ALLOWED]
    deactivate SYS_RS
    stop
  end
end

group S5 "RuntimeStore returns validated subscription target"
  SYS_RS --> SYS_AR : [step=S5.1]\n[vals result.outcome=ok; result.ok.scope_kind=scope_kind; result.ok.scope_ref=scope_ref; result.ok.scope_state=<run_meta.run_state>; result.ok.delivery_mode=best_effort_live]
  deactivate SYS_RS
end

@enduml