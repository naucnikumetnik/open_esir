@startuml
title Resolve agent handle to resolved agent configuration (AgentStore)

hide footbox
autonumber 10 10
skinparam BoxPadding 12
skinparam SequenceMessageAlign center
skinparam Shadowing false
skinparam ParticipantPadding 18
skinparam ResponseMessageBelowArrow true
skinparam DefaultFontName Monospace

participant "Caller\n(AgentRuntime / ExecUnit)" as SYS_AR

box "AIOS — System Components" #F3F3F3
  control "AgentStore" as SYS_AS <<component>>
  control "Core" as SYS_Core <<component>>
  control "ToolsAdapter\n(MCP client / ToolBus)" as SYS_Tools <<component>>
end box

box "External Environment" #EEF5FF
  database "AIOS Managed Storage\n(.aios)" as EXT_AIOS <<external>>
end box

note over SYS_AR, EXT_AIOS #FFF8DC
S_SYS_AGENT_STORE_RESOLVE_AGENT
ap_ref = AP_RESOLVE_AGENT
end note

note over SYS_AS
  AgentStore resolves AgentHandle to a fully usable ResolvedAgentConfig.
  Shape validation is delegated to Core.validate.
  Physical storage access is via ToolsAdapter (fs.*).
end note

' ============================================================================
' S1 — Caller requests agent resolution
' ============================================================================
group S1 "Caller requests resolve_agent"
  SYS_AR -> SYS_AS : IF_SYS_AGENT_STORE.resolve_agent(ctx:CallContext, agent:AgentHandle) -> Result[ResolvedAgentConfig]\n[step=S1.1]\n[connection use_port=P_AR_USE_AGENT_STORE; prov_port=P_AS_PROV_AGENT_STORE; conn=C_AR__AS__AGENT_STORE]\n[vals agent.id=<agent_id>]
  activate SYS_AS
end

' ============================================================================
' S2 — Load + validate inventory (agents_config.json) and map agent -> model_ref
' ============================================================================
group S2 "Load inventory + map AgentHandle to model_ref"
  SYS_AS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.read_text(ctx:CallContext, path:str, opts?:FSReadOptions) -> Result[ReadTextResult]\n[step=S2.1]\n[connection use_port=P_AS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_AS__TOOLS__TOOL_BUS]\n[vals path=".aios/agents_database/agents_config.json"; opts.encoding="utf-8"]
  ref over SYS_AS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_READ_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_AS : [step=S2.1r]\n[vals result.outcome=(ok|err); result.err.code=<fs_error_if_any>]

  alt [COND=result.outcome=err]
    SYS_AS -> SYS_AS : classify_inventory_read_error(result.err)\n[step=S2.2]\n[vals mapped_code=AGENT_RESOLUTION_FAILED]
    SYS_AS --> SYS_AR : [step=S2.3]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=AGENT_RESOLUTION_FAILED; result.err.data.reason="AGENT_INVENTORY_UNAVAILABLE"]
    deactivate SYS_AS
    stop
  end

  SYS_AS -> SYS_Core : IF_SYS_CORE_SERVICE.validate(ctx:CallContext, items:[ValidationItem], fw:FrameworkHandle) -> Result[ValidationBatchResult]\n[step=S2.4]\n[connection use_port=P_AS_USE_CORE_SERVICE; prov_port=P_CORE_PROV_CORE_SERVICE; conn=C_AS__CORE__CORE_SERVICE]\n[vals items=[{item_id="agents_config"; kind=AGENT_INVENTORY; content_type="application/json"; payload_text="<agents_config_json>"}]]
  ref over SYS_AS, SYS_Core
    expand=S_SYS_CORE_VALIDATE
    op=IF_SYS_CORE_SERVICE.validate
  end ref
  SYS_Core --> SYS_AS : [step=S2.4r]\n[vals result.outcome=(ok|err); result.ok.overall_status=(PASS|FAIL)]

  alt [COND=result.outcome=err or result.ok.overall_status=FAIL]
    SYS_AS --> SYS_AR : [step=S2.5]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=AGENT_RESOLUTION_FAILED; result.err.data.reason="AGENT_INVENTORY_INVALID"]
    deactivate SYS_AS
    stop
  else [COND=INVENTORY_VALID]
    SYS_AS -> SYS_AS : inventory=parse_agents_config("<agents_config_json>") -> AgentInventory\n[step=S2.6]
    SYS_AS -> SYS_AS : model_ref:ModelRef=lookup_model_ref(inventory, agent.id)\n[step=S2.7]\n[vals model_ref=<ModelRef_or_null>]
  end

  alt [COND=model_ref is null]
    SYS_AS --> SYS_AR : [step=S2.8]\n[vals result.outcome=err; result.err.category=NOT_FOUND; result.err.code=AGENT_RESOLUTION_FAILED; result.err.data.reason="AGENT_NOT_FOUND"; result.err.data.agent_id=agent.id]
    deactivate SYS_AS
    stop
  end
end

' ============================================================================
' S3 — Load + validate model_card.yaml
' ============================================================================
group S3 "Load + validate model_card"
  SYS_AS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.read_text(ctx:CallContext, path:str, opts?:FSReadOptions) -> Result[ReadTextResult]\n[step=S3.1]\n[connection use_port=P_AS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_AS__TOOLS__TOOL_BUS]\n[vals path=".aios/agents_database/<model_ref>/model_card.yaml"; opts.encoding="utf-8"]
  ref over SYS_AS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_READ_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_AS : [step=S3.1r]\n[vals result.outcome=(ok|err)]

  alt [COND=result.outcome=err]
    SYS_AS --> SYS_AR : [step=S3.2]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=AGENT_RESOLUTION_FAILED; result.err.data.reason="MODEL_CARD_UNAVAILABLE"; result.err.data.model_ref=model_ref]
    deactivate SYS_AS
    stop
  end

  SYS_AS -> SYS_Core : IF_SYS_CORE_SERVICE.validate(ctx:CallContext, items:[ValidationItem], fw:FrameworkHandle) -> Result[ValidationBatchResult]\n[step=S3.3]\n[connection use_port=P_AS_USE_CORE_SERVICE; prov_port=P_CORE_PROV_CORE_SERVICE; conn=C_AS__CORE__CORE_SERVICE]\n[vals items=[{item_id="model_card"; kind=MODEL_CARD; content_type="application/yaml"; payload_text="<model_card_yaml>"}]]
  ref over SYS_AS, SYS_Core
    expand=S_SYS_CORE_VALIDATE
    op=IF_SYS_CORE_SERVICE.validate
  end ref
  SYS_Core --> SYS_AS : [step=S3.3r]\n[vals result.outcome=(ok|err); result.ok.overall_status=(PASS|FAIL)]

  alt [COND=result.outcome=err or result.ok.overall_status=FAIL]
    SYS_AS --> SYS_AR : [step=S3.4]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=AGENT_RESOLUTION_FAILED; result.err.data.reason="MODEL_CARD_INVALID"; result.err.data.model_ref=model_ref]
    deactivate SYS_AS
    stop
  else [COND=MODEL_CARD_VALID]
    SYS_AS -> SYS_AS : model_card=parse_model_card("<model_card_yaml>") -> ModelCard\n[step=S3.5]
  end
end

' ============================================================================
' S4 — Load + validate access.json (conditional) and decide access mode
' ============================================================================
group S4 "Load + validate access config (conditional)"
  SYS_AS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.read_text(ctx:CallContext, path:str, opts?:FSReadOptions) -> Result[ReadTextResult]\n[step=S4.1]\n[connection use_port=P_AS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_AS__TOOLS__TOOL_BUS]\n[vals path=".aios/agents_database/<model_ref>/access.json"; opts.encoding="utf-8"]
  ref over SYS_AS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_READ_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_AS : [step=S4.1r]\n[vals result.outcome=(ok|err)]

  alt [COND=result.outcome=err]
    SYS_AS -> SYS_AS : access_required=decide_access_required(model_card)\n[step=S4.2]\n[vals access_required=(true|false)]
    alt [COND=access_required=true]
      SYS_AS --> SYS_AR : [step=S4.3]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=AGENT_RESOLUTION_FAILED; result.err.data.reason="ACCESS_UNAVAILABLE"; result.err.data.model_ref=model_ref]
      deactivate SYS_AS
      stop
    else [COND=access_optional]
      SYS_AS -> SYS_AS : access=use_default_local_access(model_card)\n[step=S4.4]\n[vals access_mode="local_file"; locator=".aios/agents_database/<model_ref>/model.gguf"]
    end
  else [COND=ACCESS_READ_OK]
    SYS_AS -> SYS_Core : IF_SYS_CORE_SERVICE.validate(ctx:CallContext, items:[ValidationItem], fw:FrameworkHandle) -> Result[ValidationBatchResult]\n[step=S4.5]\n[connection use_port=P_AS_USE_CORE_SERVICE; prov_port=P_CORE_PROV_CORE_SERVICE; conn=C_AS__CORE__CORE_SERVICE]\n[vals items=[{item_id="access"; kind=MODEL_ACCESS; content_type="application/json"; payload_text="<access_json>"}]]
    ref over SYS_AS, SYS_Core
      expand=S_SYS_CORE_VALIDATE
      op=IF_SYS_CORE_SERVICE.validate
    end ref
    SYS_Core --> SYS_AS : [step=S4.5r]\n[vals result.outcome=(ok|err); result.ok.overall_status=(PASS|FAIL)]

    alt [COND=result.outcome=err or result.ok.overall_status=FAIL]
      SYS_AS --> SYS_AR : [step=S4.6]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=AGENT_RESOLUTION_FAILED; result.err.data.reason="ACCESS_INVALID"; result.err.data.model_ref=model_ref]
      deactivate SYS_AS
      stop
    else [COND=ACCESS_VALID]
      SYS_AS -> SYS_AS : access=parse_model_access("<access_json>") -> ModelAccess\n[step=S4.7]\n[vals access_mode=<local_file|local_endpoint|cloud_api|mcp>]
    end
  end
end

' ============================================================================
' S5 — Local model blob presence check (only for local_file)
' ============================================================================
group S5 "Local blob presence check (only when access_mode=local_file)"
  alt [COND=access_mode=local_file]
    SYS_AS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.stat(ctx:CallContext, path:str) -> Result[FSStatResult]\n[step=S5.1]\n[connection use_port=P_AS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_AS__TOOLS__TOOL_BUS]\n[vals path=".aios/agents_database/<model_ref>/model.gguf"]
    ref over SYS_AS, SYS_Tools, EXT_AIOS
      expand=S_SYS_TOOL_BUS_FS_STAT
      ref_mode=call_return
    end ref
    SYS_Tools --> SYS_AS : [step=S5.1r]\n[vals result.outcome=(ok|err)]

    alt [COND=result.outcome=err]
      SYS_AS --> SYS_AR : [step=S5.2]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=AGENT_RESOLUTION_FAILED; result.err.data.reason="LOCAL_MODEL_BLOB_MISSING"; result.err.data.model_ref=model_ref]
      deactivate SYS_AS
      stop
    end
  end
end

' ============================================================================
' S6 — Derive ResolvedAgentConfig and return
' ============================================================================
group S6 "Derive resolved agent config and return"
  SYS_AS -> SYS_AS : resolved_cfg=build_resolved_agent_config(agent, model_ref, model_card, access)\n[step=S6.1]\n[vals resolved_cfg.access=<endpoint_details_minus_secrets>]

  SYS_AS --> SYS_AR : [step=S6.2]\n[vals result.outcome=ok; result.ok=<ResolvedAgentConfig>]
  deactivate SYS_AS
end

@enduml