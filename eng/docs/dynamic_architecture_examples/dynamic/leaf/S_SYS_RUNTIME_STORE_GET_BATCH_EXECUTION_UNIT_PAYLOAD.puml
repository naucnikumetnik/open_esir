@startuml
title Load batch execution unit payload from AIOS managed storage

hide footbox
autonumber 10 10
skinparam BoxPadding 12
skinparam SequenceMessageAlign center
skinparam Shadowing false
skinparam ParticipantPadding 18
skinparam ResponseMessageBelowArrow true
skinparam DefaultFontName Monospace

participant "Caller\n(AgentRuntime)" as SYS_AR

box "AIOS — System Components" #F3F3F3
  control "RuntimeStore" as SYS_RS <<component>>
  control "Core" as SYS_Core <<component>>
  control "ToolsAdapter\n(MCP client / ToolBus)" as SYS_Tools <<component>>
end box

box "External Environment" #EEF5FF
  database "AIOS Managed Storage\n(.aios)" as EXT_AIOS <<external>>
end box

note over SYS_AR, EXT_AIOS #FFF8DC
S_SYS_RUNTIME_STORE_GET_BATCH_EXECUTION_UNIT_PAYLOAD
end note

note over SYS_RS, SYS_Tools
  RuntimeStore owns batch-execution-unit payload semantics.
  ToolsAdapter provides the physical access path to AIOS managed storage.
  The caller already holds the batch_execution_unit_id from dispatch context.
end note

group S1 "AgentRuntime requests batch execution unit payload"
  SYS_AR -> SYS_RS : IF_SYS_RUNTIME_STORE.get_batch_execution_unit_payload(ctx:CallContext, run_ref:str, task_id:str, batch_execution_unit_id:str) -> Result[BatchExecutionUnitPayload]\n[step=S1.1]\n[connection use_port=P_AR_USE_RUNTIME_STORE; prov_port=P_RS_PROV_RUNTIME_STORE; conn=C_AR__RS__RUNTIME_STORE]\n[vals run_ref=run_ref; task_id=task_id; batch_execution_unit_id=batch_execution_unit_id]
  activate SYS_RS

  alt [COND=run_ref is null or malformed or task_id is null or malformed or batch_execution_unit_id is null or malformed]
    SYS_RS --> SYS_AR : [step=S1.2]\n[vals result.outcome=err; result.err.category=INPUT; result.err.code=BATCH_EXECUTION_UNIT_UNAVAILABLE]
    deactivate SYS_RS
    stop
  end
end

group S2 "RuntimeStore reads batch execution unit through ToolsAdapter"
  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.read_text(ctx:CallContext, path:str, opts?:FSReadOptions) -> Result[ReadTextResult]\n[step=S2.1]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/runs/<run_ref>/tasks/<task_id>/batches/<batch_execution_unit_id>.json"; opts.encoding="utf-8"]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_READ_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S2.1r]\n[vals result.outcome=(ok|err); result.err.code=<fs_error_if_any>]

  alt [COND=result.outcome=err]
    SYS_RS -> SYS_RS : classify_batch_execution_unit_read_error(result.err)\n[step=S2.2]\n[vals mapped_code=BATCH_EXECUTION_UNIT_UNAVAILABLE]
    SYS_RS --> SYS_AR : [step=S2.3]\n[vals result.outcome=err; result.err.category=(NOT_FOUND|DEPENDENCY); result.err.code=BATCH_EXECUTION_UNIT_UNAVAILABLE]
    deactivate SYS_RS
    stop
  end
end

group S3 "RuntimeStore validates and parses batch execution unit"
  SYS_RS -> SYS_Core : IF_SYS_CORE_SERVICE.validate(ctx:CallContext, items:[ValidationItem], fw:FrameworkHandle) -> Result[ValidationBatchResult]\n[step=S3.1]\n[connection use_port=P_RS_USE_CORE_SERVICE; prov_port=P_CORE_PROV_CORE_SERVICE; conn=C_RS__CORE__CORE_SERVICE]\n[vals items=[{item_id="batch_execution_unit"; kind=ARTIFACT; content_type="application/json"; payload_text="<batch_execution_unit_json>"}]]
  ref over SYS_RS, SYS_Core
    expand=S_SYS_CORE_VALIDATE
    op=IF_SYS_CORE_SERVICE.validate
    note="Validate batch execution-unit record before parse."
  end ref
  SYS_Core --> SYS_RS : [step=S3.1r]\n[vals result.outcome=(ok|err); result.ok.overall_status=(PASS|FAIL)]

  alt [COND=result.outcome=err or result.ok.overall_status=FAIL]
    SYS_RS --> SYS_AR : [step=S3.2]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=BATCH_EXECUTION_UNIT_INVALID]
    deactivate SYS_RS
    stop
  else [COND=UNIT_VALID]
    SYS_RS -> SYS_RS : batch_execution_unit=parse_batch_execution_unit("<batch_execution_unit_json>")\n[step=S3.3]
    SYS_RS -> SYS_RS : payload=extract_batch_execution_unit_payload(batch_execution_unit)\n[step=S3.4]\n[vals payload=<BatchExecutionUnitPayload>]
  end
end

group S4 "RuntimeStore returns batch execution unit payload"
  SYS_RS --> SYS_AR : [step=S4.1]\n[vals result.outcome=ok; result.ok.batch_execution_unit_id=<batch_execution_unit_id>; result.ok.payload=<BatchExecutionUnitPayload>]
  deactivate SYS_RS
end

@enduml