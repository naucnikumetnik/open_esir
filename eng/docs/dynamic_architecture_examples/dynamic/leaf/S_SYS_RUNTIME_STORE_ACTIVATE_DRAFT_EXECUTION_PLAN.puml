@startuml
title Activate draft execution plan (create run + materialize accepted plan)

hide footbox
autonumber 10 10
skinparam BoxPadding 12
skinparam SequenceMessageAlign center
skinparam Shadowing false
skinparam ParticipantPadding 18
skinparam ResponseMessageBelowArrow true
skinparam DefaultFontName Monospace

participant "Caller\n(AgentRuntime)" as SYS_AR

box "AIOS — System Components" #F3F3F3
  control "RuntimeStore" as SYS_RS <<component>>
  control "Core" as SYS_Core <<component>>
  control "ToolsAdapter\n(MCP client / ToolBus)" as SYS_Tools <<component>>
end box

box "External Environment" #EEF5FF
  database "AIOS Managed Storage\n(.aios)" as EXT_AIOS <<external>>
end box

note over SYS_AR, EXT_AIOS #FFF8DC
S_SYS_RUNTIME_STORE_ACTIVATE_DRAFT_EXECUTION_PLAN
end note

note over SYS_RS, SYS_Tools
  RuntimeStore owns draft-plan activation semantics.
  ToolsAdapter provides the physical access path to AIOS managed storage.
  Core validates stored and derived activation artifacts before persistence.
end note

note over SYS_RS
  Confirming a draft plan creates run_ref.
  The accepted execution plan is materialized into run-scoped storage.
  Rejecting a draft plan does not create a run.
end note

group S1 "AgentRuntime requests draft-plan activation"
  SYS_AR -> SYS_RS : IF_SYS_RUNTIME_STORE.activate_draft_execution_plan(ctx:CallContext, plan_ref:str) -> Result[ActivatedExecutionPlan]\n[step=S1.1]\n[connection use_port=P_AR_USE_RUNTIME_STORE; prov_port=P_RS_PROV_RUNTIME_STORE; conn=C_AR__RS__RUNTIME_STORE]\n[vals plan_ref=plan_ref]
  activate SYS_RS

  alt [COND=plan_ref is null or malformed]
    SYS_RS --> SYS_AR : [step=S1.2]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=PLAN_REF_INVALID]
    deactivate SYS_RS
    stop
  end
end

group S2 "RuntimeStore reads, validates, and parses draft-plan document"
  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.read_text(ctx:CallContext, path:str, opts?:FSReadOptions) -> Result[ReadTextResult]\n[step=S2.1]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/plans/<plan_ref>/draft_plan.json"; opts.encoding="utf-8"]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_READ_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S2.1r]\n[vals result.outcome=(ok|err); result.err.code=<fs_error_if_any>]

  alt [COND=result.outcome=err]
    SYS_RS -> SYS_RS : classify_draft_plan_read_error(result.err)\n[step=S2.2]\n[vals mapped_code=DRAFT_PLAN_UNAVAILABLE]
    SYS_RS --> SYS_AR : [step=S2.3]\n[vals result.outcome=err; result.err.category=(NOT_FOUND|DEPENDENCY); result.err.code=DRAFT_PLAN_UNAVAILABLE]
    deactivate SYS_RS
    stop
  end

  SYS_RS -> SYS_Core : IF_SYS_CORE_SERVICE.validate(ctx:CallContext, items:[ValidationItem], fw:FrameworkHandle) -> Result[ValidationBatchResult]\n[step=S2.4]\n[connection use_port=P_RS_USE_CORE_SERVICE; prov_port=P_CORE_PROV_CORE_SERVICE; conn=C_RS__CORE__CORE_SERVICE]\n[vals items=[{item_id="draft_plan_document"; kind=ARTIFACT; content_type="application/json"; payload_text="<draft_plan_document_json>"}]]
  ref over SYS_RS, SYS_Core
    expand=S_SYS_CORE_VALIDATE
    op=IF_SYS_CORE_SERVICE.validate
    note="Validate stored draft-plan document before parse."
  end ref
  SYS_Core --> SYS_RS : [step=S2.4r]\n[vals result.outcome=(ok|err); result.ok.overall_status=(PASS|FAIL)]

  alt [COND=result.outcome=err or result.ok.overall_status=FAIL]
    SYS_RS --> SYS_AR : [step=S2.5]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=DRAFT_PLAN_INVALID]
    deactivate SYS_RS
    stop
  else [COND=DRAFT_PLAN_VALID]
    SYS_RS -> SYS_RS : parse_draft_plan_document("<draft_plan_document_json>")\n[step=S2.6]\n[vals draft_plan=<DraftExecutionPlan>; draft_summary=<DraftExecutionPlanSummary>]
  end

  alt [COND=draft_plan.state != READY_FOR_CONFIRMATION]
    SYS_RS --> SYS_AR : [step=S2.7]\n[vals result.outcome=err; result.err.category=CONFLICT; result.err.code=PLAN_NOT_CONFIRMABLE]
    deactivate SYS_RS
    stop
  end
end

group S3 "RuntimeStore derives activation artifacts"
  SYS_RS -> SYS_RS : derive_activation_artifacts(draft_plan, draft_summary)\n[step=S3.1]\n[vals derive={run_ref, accepted_execution_plan, run_meta, task_runtime_index, confirmed_draft_plan_document}]

  SYS_RS -> SYS_Core : IF_SYS_CORE_SERVICE.validate(ctx:CallContext, items:[ValidationItem], fw:FrameworkHandle) -> Result[ValidationBatchResult]\n[step=S3.2]\n[connection use_port=P_RS_USE_CORE_SERVICE; prov_port=P_CORE_PROV_CORE_SERVICE; conn=C_RS__CORE__CORE_SERVICE]\n[vals items=[{item_id="accepted_execution_plan"; kind=ARTIFACT; content_type="application/json"; payload_any=accepted_execution_plan}, {item_id="run_meta"; kind=ARTIFACT; content_type="application/json"; payload_any=run_meta}, {item_id="task_runtime_index"; kind=ARTIFACT; content_type="application/json"; payload_any=task_runtime_index}, {item_id="confirmed_draft_plan_document"; kind=ARTIFACT; content_type="application/json"; payload_any=confirmed_draft_plan_document}]]
  ref over SYS_RS, SYS_Core
    expand=S_SYS_CORE_VALIDATE
    op=IF_SYS_CORE_SERVICE.validate
    note="Validate all derived activation artifacts before persistence."
  end ref
  SYS_Core --> SYS_RS : [step=S3.2r]\n[vals result.outcome=(ok|err); result.ok.overall_status=(PASS|FAIL)]

  alt [COND=result.outcome=err or result.ok.overall_status=FAIL]
    SYS_RS --> SYS_AR : [step=S3.3]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=PLAN_ACTIVATION_FAILED]
    deactivate SYS_RS
    stop
  else [COND=DERIVED_ARTIFACTS_VALID]
    SYS_RS -> SYS_RS : serialize_activation_artifacts()\n[step=S3.4]\n[vals execution_plan_json="<execution_plan_json>"; run_meta_json="<run_meta_json>"; task_runtime_index_json="<task_runtime_index_json>"; confirmed_draft_plan_json="<confirmed_draft_plan_document_json>"]
  end
end

group S4 "RuntimeStore creates run root and materializes accepted plan"
  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.ensure_dir(ctx:CallContext, path:str) -> Result[WriteResult]\n[step=S4.1]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/runs/<run_ref>"]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_ENSURE_DIR
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S4.1r]\n[vals result.outcome=(ok|err)]

  alt [COND=result.outcome=err]
    SYS_RS --> SYS_AR : [step=S4.2]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=PLAN_ACTIVATION_FAILED]
    deactivate SYS_RS
    stop
  end

  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.write_text(ctx:CallContext, path:str, text:str, expected_etag?:str, opts?:FSWriteOptions) -> Result[WriteResult]\n[step=S4.3]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/runs/<run_ref>/execution_plan.json"; text="<execution_plan_json>"; expected_etag=null; opts.atomic=true]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_WRITE_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S4.3r]\n[vals result.outcome=(ok|err)]

  alt [COND=result.outcome=err]
    SYS_RS --> SYS_AR : [step=S4.4]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=PLAN_ACTIVATION_FAILED]
    deactivate SYS_RS
    stop
  end

  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.write_text(ctx:CallContext, path:str, text:str, expected_etag?:str, opts?:FSWriteOptions) -> Result[WriteResult]\n[step=S4.5]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/runs/<run_ref>/run_meta.json"; text="<run_meta_json>"; expected_etag=null; opts.atomic=true]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_WRITE_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S4.5r]\n[vals result.outcome=(ok|err)]

  alt [COND=result.outcome=err]
    note over SYS_RS
      execution_plan.json may already have been written.
      Activation is treated as failed to caller and recovered later by
      idempotent retry or repair logic in a later slice.
    end note
    SYS_RS --> SYS_AR : [step=S4.6]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=PLAN_ACTIVATION_FAILED]
    deactivate SYS_RS
    stop
  end

  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.write_text(ctx:CallContext, path:str, text:str, expected_etag?:str, opts?:FSWriteOptions) -> Result[WriteResult]\n[step=S4.7]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/runs/<run_ref>/task_runtime_index.json"; text="<task_runtime_index_json>"; expected_etag=null; opts.atomic=true]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_WRITE_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S4.7r]\n[vals result.outcome=(ok|err)]

  alt [COND=result.outcome=err]
    note over SYS_RS
      Some run-scoped artifacts may already have been written.
      Activation is treated as failed to caller and recovered later by
      idempotent retry or repair logic in a later slice.
    end note
    SYS_RS --> SYS_AR : [step=S4.8]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=PLAN_ACTIVATION_FAILED]
    deactivate SYS_RS
    stop
  end

  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.write_text(ctx:CallContext, path:str, text:str, expected_etag?:str, opts?:FSWriteOptions) -> Result[WriteResult]\n[step=S4.9]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/plans/<plan_ref>/draft_plan.json"; text="<confirmed_draft_plan_json>"; expected_etag=<current_etag_or_null>; opts.atomic=true]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_WRITE_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S4.9r]\n[vals result.outcome=(ok|err)]

  alt [COND=result.outcome=err]
    note over SYS_RS
      Run world may already have been materialized while draft-plan confirmation update failed.
      Activation is treated as failed to caller and recovered later by
      idempotent retry or repair logic in a later slice.
    end note
    SYS_RS --> SYS_AR : [step=S4.10]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=PLAN_ACTIVATION_FAILED]
    deactivate SYS_RS
    stop
  end
end

group S5 "RuntimeStore returns activated execution plan"
  SYS_RS --> SYS_AR : [step=S5.1]\n[vals result.outcome=ok; result.ok.plan_ref=plan_ref; result.ok.plan_state=READY_FOR_EXECUTION; result.ok.run_ref=<run_ref>; result.ok.execution_plan_path=".aios/runtime/runs/<run_ref>/execution_plan.json"]
  deactivate SYS_RS
end

@enduml
