@startuml
title Write binary content through ToolsAdapter filesystem capability

hide footbox
autonumber 10 10
skinparam BoxPadding 12
skinparam SequenceMessageAlign center
skinparam Shadowing false
skinparam ParticipantPadding 18
skinparam ResponseMessageBelowArrow true
skinparam DefaultFontName Monospace

participant "Caller\n(System Component)" as SYS_CALLER

box "AIOS — System Components" #F3F3F3
  control "ToolsAdapter\n(MCP client / ToolBus)" as SYS_Tools <<component>>
end box

box "External Environment" #EEF5FF
  database "Target File Store\n(.aios / workspace / mounted storage)" as EXT_FS <<external>>
end box

note over SYS_CALLER, EXT_FS #FFF8DC
S_SYS_TOOL_BUS_FS_WRITE_BYTES
end note

note over SYS_Tools, EXT_FS
  ToolsAdapter owns external binary-write boundary semantics.
  Caller owns payload meaning and path selection semantics.
  ToolsAdapter owns boundary validation, execution, and normalization of result.
  External file-store access is modeled through IF_DEP_FILE_STORE.
  This leaf covers only the filesystem capability family of ToolBus.
end note

note over SYS_Tools
  This slice writes opaque bytes to an external file path.
  It does not interpret domain meaning of the payload being written.
  Non-local artifact access is modeled through other endpoint-aware system paths.
end note

group S1 "Caller requests binary write through ToolsAdapter"
  SYS_CALLER -> SYS_Tools : IF_SYS_TOOL_BUS.fs.write_bytes(ctx:CallContext, path:str, bytes:any, expected_etag?:str, opts?:FSWriteOptions) -> Result[WriteResult]\n[step=S1.1]\n[connection use_port=<caller_use_tool_bus>; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=<caller__tools__tool_bus>]\n[vals path=path; expected_etag=<etag_or_null>; opts.atomic=<bool?>]
  activate SYS_Tools
end

group S2 "ToolsAdapter validates request"
  alt [COND=result.outcome=err and result.err.code=FS_PATH_INVALID]
    SYS_Tools --> SYS_CALLER : [step=S2.1]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=FS_PATH_INVALID]
    deactivate SYS_Tools

  else [COND=result.outcome=err and result.err.code=FS_ACCESS_DENIED]
    SYS_Tools --> SYS_CALLER : [step=S2.2]\n[vals result.outcome=err; result.err.category=SECURITY; result.err.code=FS_ACCESS_DENIED]
    deactivate SYS_Tools

  else [COND=result.outcome=err and result.err.code=FS_WRITE_BYTES_INVALID]
    SYS_Tools --> SYS_CALLER : [step=S2.3]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=FS_WRITE_BYTES_INVALID]
    deactivate SYS_Tools

  else [COND=result.outcome=ok]
    note over SYS_Tools
      ToolsAdapter may internally normalize:
      - absolute/resolved path
      - atomic write options
      - concurrency precondition handling via expected_etag
    end note
  end
end

group S3 "ToolsAdapter writes bytes through dependency file-store contract"
  SYS_Tools -> EXT_FS : IF_DEP_FILE_STORE.write_bytes(ctx:CallContext, path:str, bytes:any, expected_etag?:str, opts?:FSWriteOptions) -> Result[DepWriteResult]\n[step=S3.1]\n[connection use_port=P_TOOLS_USE_DEP_FILE_STORE; prov_port=P_EXT_FS_PROV_DEP_FILE_STORE; conn=C_TOOLS__EXT_FS__DEP_FILE_STORE]\n[vals path=path; expected_etag=expected_etag; opts.atomic=opts.atomic]
  EXT_FS --> SYS_Tools : [step=S3.1r]\n[vals result.outcome=(ok|err); result.ok.new_etag="<etag>"; result.ok.content_type="<ct?>"]

  alt [COND=result.outcome=err and result.err.code=FS_WRITE_FAILED]
    SYS_Tools --> SYS_CALLER : [step=S3.2]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=FS_WRITE_FAILED]
    deactivate SYS_Tools

  else [COND=result.outcome=err and result.err.code=FS_ETAG_CONFLICT]
    SYS_Tools --> SYS_CALLER : [step=S3.3]\n[vals result.outcome=err; result.err.category=CONFLICT; result.err.code=FS_ETAG_CONFLICT]
    deactivate SYS_Tools

  else [COND=result.outcome=ok]
  end
end

group S4 "ToolsAdapter returns normalized write result"
  SYS_Tools --> SYS_CALLER : [step=S4.1]\n[vals result.outcome=ok; result.ok.new_etag="<etag>"; result.ok.content_type="<ct?>"]
  deactivate SYS_Tools
end

@enduml
