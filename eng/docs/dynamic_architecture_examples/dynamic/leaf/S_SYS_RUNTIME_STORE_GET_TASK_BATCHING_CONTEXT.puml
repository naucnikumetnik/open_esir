@startuml
title Load task batching context from AIOS managed storage

hide footbox
autonumber 10 10
skinparam BoxPadding 12
skinparam SequenceMessageAlign center
skinparam Shadowing false
skinparam ParticipantPadding 18
skinparam ResponseMessageBelowArrow true
skinparam DefaultFontName Monospace

participant "Caller\n(AgentRuntime)" as SYS_AR

box "AIOS — System Components" #F3F3F3
  control "RuntimeStore" as SYS_RS <<component>>
  control "Core" as SYS_Core <<component>>
  control "ToolsAdapter\n(MCP client / ToolBus)" as SYS_Tools <<component>>
end box

box "External Environment" #EEF5FF
  database "AIOS Managed Storage\n(.aios)" as EXT_AIOS <<external>>
end box

note over SYS_AR, EXT_AIOS #FFF8DC
S_SYS_RUNTIME_STORE_GET_TASK_BATCHING_CONTEXT
end note

note over SYS_RS, SYS_Tools
  RuntimeStore owns aggregated task-batching read semantics.
  ToolsAdapter provides the physical access path to AIOS managed storage.
  Core validates persisted artifacts before RuntimeStore parses and derives the context.
end note

note over SYS_RS
  This slice prepares the persisted context needed to derive or reuse
  batch execution units for one selected parent task.
end note

group S1 "AgentRuntime requests task batching context"
  SYS_AR -> SYS_RS : IF_SYS_RUNTIME_STORE.get_task_batching_context(ctx:CallContext, run_ref:str, task_id:str) -> Result[TaskBatchingContext]\n[step=S1.1]\n[connection use_port=P_AR_USE_RUNTIME_STORE; prov_port=P_RS_PROV_RUNTIME_STORE; conn=C_AR__RS__RUNTIME_STORE]\n[vals run_ref=run_ref; task_id=task_id]
  activate SYS_RS

  alt [COND=run_ref is null or malformed or task_id is null or malformed]
    SYS_RS --> SYS_AR : [step=S1.2]\n[vals result.outcome=err; result.err.category=INPUT; result.err.code=TASK_BATCHING_REF_INVALID]
    deactivate SYS_RS
    stop
  end
end

group S2 "RuntimeStore loads, validates, and parses run metadata"
  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.read_text(ctx:CallContext, path:str, opts?:FSReadOptions) -> Result[ReadTextResult]\n[step=S2.1]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/runs/<run_ref>/run_meta.json"; opts.encoding="utf-8"]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_READ_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S2.1r]\n[vals result.outcome=(ok|err); result.err.code=<fs_error_if_any>]

  alt [COND=result.outcome=err]
    SYS_RS -> SYS_RS : classify_run_meta_read_error(result.err)\n[step=S2.2]\n[vals mapped_code=RUN_NOT_FOUND]
    SYS_RS --> SYS_AR : [step=S2.3]\n[vals result.outcome=err; result.err.category=NOT_FOUND; result.err.code=RUN_NOT_FOUND]
    deactivate SYS_RS
    stop
  end

  SYS_RS -> SYS_Core : IF_SYS_CORE_SERVICE.validate(ctx:CallContext, items:[ValidationItem], fw:FrameworkHandle) -> Result[ValidationBatchResult]\n[step=S2.4]\n[connection use_port=P_RS_USE_CORE_SERVICE; prov_port=P_CORE_PROV_CORE_SERVICE; conn=C_RS__CORE__CORE_SERVICE]\n[vals items=[{item_id="run_meta"; kind=ARTIFACT; content_type="application/json"; payload_text="<run_meta_json>"}]]
  ref over SYS_RS, SYS_Core
    expand=S_SYS_CORE_VALIDATE
    op=IF_SYS_CORE_SERVICE.validate
    note="Validate run_meta.json before parse."
  end ref
  SYS_Core --> SYS_RS : [step=S2.4r]\n[vals result.outcome=(ok|err); result.ok.overall_status=(PASS|FAIL)]

  alt [COND=result.outcome=err or result.ok.overall_status=FAIL]
    SYS_RS --> SYS_AR : [step=S2.5]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=RUN_META_INVALID]
    deactivate SYS_RS
    stop
  else [COND=RUN_META_VALID]
    SYS_RS -> SYS_RS : run_meta=parse_run_meta("<run_meta_json>")\n[step=S2.6]
  end

  alt [COND=run_meta.run_state in {COMPLETED,FAILED,BLOCKED}]
    SYS_RS --> SYS_AR : [step=S2.7]\n[vals result.outcome=err; result.err.category=CONFLICT; result.err.code=RUN_NOT_ACTIVE]
    deactivate SYS_RS
    stop
  end
end

group S3 "RuntimeStore loads, validates, and parses run-scoped execution plan"
  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.read_text(ctx:CallContext, path:str, opts?:FSReadOptions) -> Result[ReadTextResult]\n[step=S3.1]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/runs/<run_ref>/execution_plan.json"; opts.encoding="utf-8"]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_READ_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S3.1r]\n[vals result.outcome=(ok|err); result.err.code=<fs_error_if_any>]

  alt [COND=result.outcome=err]
    SYS_RS -> SYS_RS : classify_execution_plan_read_error(result.err)\n[step=S3.2]\n[vals mapped_code=RUN_EXECUTION_PLAN_UNAVAILABLE]
    SYS_RS --> SYS_AR : [step=S3.3]\n[vals result.outcome=err; result.err.category=(NOT_FOUND|DEPENDENCY); result.err.code=RUN_EXECUTION_PLAN_UNAVAILABLE]
    deactivate SYS_RS
    stop
  end

  SYS_RS -> SYS_Core : IF_SYS_CORE_SERVICE.validate(ctx:CallContext, items:[ValidationItem], fw:FrameworkHandle) -> Result[ValidationBatchResult]\n[step=S3.4]\n[connection use_port=P_RS_USE_CORE_SERVICE; prov_port=P_CORE_PROV_CORE_SERVICE; conn=C_RS__CORE__CORE_SERVICE]\n[vals items=[{item_id="execution_plan"; kind=ARTIFACT; content_type="application/json"; payload_text="<execution_plan_json>"}]]
  ref over SYS_RS, SYS_Core
    expand=S_SYS_CORE_VALIDATE
    op=IF_SYS_CORE_SERVICE.validate
    note="Validate execution_plan.json before parse."
  end ref
  SYS_Core --> SYS_RS : [step=S3.4r]\n[vals result.outcome=(ok|err); result.ok.overall_status=(PASS|FAIL)]

  alt [COND=result.outcome=err or result.ok.overall_status=FAIL]
    SYS_RS --> SYS_AR : [step=S3.5]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=RUN_EXECUTION_PLAN_INVALID]
    deactivate SYS_RS
    stop
  else [COND=EXECUTION_PLAN_VALID]
    SYS_RS -> SYS_RS : execution_plan=parse_execution_plan("<execution_plan_json>")\n[step=S3.6]
  end

  alt [COND=task_id not in execution_plan.parent_task_ids]
    SYS_RS --> SYS_AR : [step=S3.7]\n[vals result.outcome=err; result.err.category=NOT_FOUND; result.err.code=RUN_TASK_NOT_FOUND]
    deactivate SYS_RS
    stop
  end
end

group S4 "RuntimeStore loads, validates, and parses task runtime index"
  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.read_text(ctx:CallContext, path:str, opts?:FSReadOptions) -> Result[ReadTextResult]\n[step=S4.1]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/runs/<run_ref>/task_runtime_index.json"; opts.encoding="utf-8"]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_READ_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S4.1r]\n[vals result.outcome=(ok|err); result.err.code=<fs_error_if_any>]

  alt [COND=result.outcome=err]
    SYS_RS -> SYS_RS : classify_task_runtime_index_read_error(result.err)\n[step=S4.2]\n[vals mapped_code=TASK_RUNTIME_INDEX_UNAVAILABLE]
    SYS_RS --> SYS_AR : [step=S4.3]\n[vals result.outcome=err; result.err.category=(NOT_FOUND|DEPENDENCY); result.err.code=TASK_RUNTIME_INDEX_UNAVAILABLE]
    deactivate SYS_RS
    stop
  end

  SYS_RS -> SYS_Core : IF_SYS_CORE_SERVICE.validate(ctx:CallContext, items:[ValidationItem], fw:FrameworkHandle) -> Result[ValidationBatchResult]\n[step=S4.4]\n[connection use_port=P_RS_USE_CORE_SERVICE; prov_port=P_CORE_PROV_CORE_SERVICE; conn=C_RS__CORE__CORE_SERVICE]\n[vals items=[{item_id="task_runtime_index"; kind=ARTIFACT; content_type="application/json"; payload_text="<task_runtime_index_json>"}]]
  ref over SYS_RS, SYS_Core
    expand=S_SYS_CORE_VALIDATE
    op=IF_SYS_CORE_SERVICE.validate
    note="Validate task_runtime_index.json before parse."
  end ref
  SYS_Core --> SYS_RS : [step=S4.4r]\n[vals result.outcome=(ok|err); result.ok.overall_status=(PASS|FAIL)]

  alt [COND=result.outcome=err or result.ok.overall_status=FAIL]
    SYS_RS --> SYS_AR : [step=S4.5]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=TASK_RUNTIME_INDEX_INVALID]
    deactivate SYS_RS
    stop
  else [COND=INDEX_VALID]
    SYS_RS -> SYS_RS : task_runtime_index=parse_task_runtime_index("<task_runtime_index_json>")\n[step=S4.6]
  end
end

group S5 "RuntimeStore loads existing batch execution-unit index for task"
  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.read_text(ctx:CallContext, path:str, opts?:FSReadOptions) -> Result[ReadTextResult]\n[step=S5.1]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/runs/<run_ref>/tasks/<task_id>/batch_execution_unit_index.json"; opts.encoding="utf-8"]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_READ_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S5.1r]\n[vals result.outcome=(ok|err); result.err.code=<fs_error_if_any>]

  alt [COND=result.outcome=err]
    SYS_RS -> SYS_RS : classify_batch_unit_index_read_error(result.err)\n[step=S5.2]\n[vals mapped_status=BATCH_EXECUTION_UNIT_INDEX_UNAVAILABLE]
    note over SYS_RS
      No existing batch execution units may simply mean this task
      has not yet been prepared for batching.
    end note
    SYS_RS -> SYS_RS : batch_execution_unit_index=derive_empty_batch_execution_unit_index(task_id)\n[step=S5.3]
  else [COND=INDEX_READ_OK]
    SYS_RS -> SYS_Core : IF_SYS_CORE_SERVICE.validate(ctx:CallContext, items:[ValidationItem], fw:FrameworkHandle) -> Result[ValidationBatchResult]\n[step=S5.4]\n[connection use_port=P_RS_USE_CORE_SERVICE; prov_port=P_CORE_PROV_CORE_SERVICE; conn=C_RS__CORE__CORE_SERVICE]\n[vals items=[{item_id="batch_execution_unit_index"; kind=ARTIFACT; content_type="application/json"; payload_text="<batch_execution_unit_index_json>"}]]
    ref over SYS_RS, SYS_Core
      expand=S_SYS_CORE_VALIDATE
      op=IF_SYS_CORE_SERVICE.validate
      note="Validate batch_execution_unit_index.json before parse."
    end ref
    SYS_Core --> SYS_RS : [step=S5.4r]\n[vals result.outcome=(ok|err); result.ok.overall_status=(PASS|FAIL)]

    alt [COND=result.outcome=err or result.ok.overall_status=FAIL]
      SYS_RS --> SYS_AR : [step=S5.5]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=BATCH_EXECUTION_UNIT_INDEX_INVALID]
      deactivate SYS_RS
      stop
    else [COND=INDEX_VALID]
      SYS_RS -> SYS_RS : batch_execution_unit_index=parse_batch_execution_unit_index("<batch_execution_unit_index_json>")\n[step=S5.6]
    end
  end
end

group S6 "RuntimeStore derives task batching context"
  SYS_RS -> SYS_RS : derive_task_batching_context(run_ref, task_id, run_meta, execution_plan, task_runtime_index, batch_execution_unit_index)\n[step=S6.1]\n[vals derive={parent_task_definition, batching_policy, batching_params, parent_task_runtime_state, reusable_batch_unit_summary, stable_ordering_basis}]
  alt [COND=derived.task_preparable=false]
    SYS_RS --> SYS_AR : [step=S6.2]\n[vals result.outcome=err; result.err.category=CONFLICT; result.err.code=TASK_NOT_PREPARABLE]
    deactivate SYS_RS
    stop
  else [COND=TASK_BATCHING_CONTEXT_READY]
    SYS_RS --> SYS_AR : [step=S6.3]\n[vals result.outcome=ok; result.ok.run_ref=run_ref; result.ok.task_id=task_id; result.ok.batching_mode=<mode>; result.ok.existing_batch_unit_count=<n>; result.ok.batching_context=<TaskBatchingContext>]
    deactivate SYS_RS
  end
end

@enduml
