@startuml
title Resolve artifact location from AIOS managed storage

hide footbox
autonumber 10 10
skinparam BoxPadding 12
skinparam SequenceMessageAlign center
skinparam Shadowing false
skinparam ParticipantPadding 18
skinparam ResponseMessageBelowArrow true
skinparam DefaultFontName Monospace

participant "Caller\n(AgentRuntime)" as SYS_AR

box "AIOS — System Components" #F3F3F3
  control "RuntimeStore" as SYS_RS <<component>>
  control "Core" as SYS_Core <<component>>
  control "ToolsAdapter\n(MCP client / ToolBus)" as SYS_Tools <<component>>
end box

box "External Environment" #EEF5FF
  database "AIOS Managed Storage\n(.aios)" as EXT_AIOS <<external>>
end box

note over SYS_AR, EXT_AIOS #FFF8DC
S_SYS_RUNTIME_STORE_RESOLVE_LOCATION
end note

note over SYS_RS, SYS_Tools
  RuntimeStore owns CM-catalogue and location-resolution semantics.
  ToolsAdapter provides the physical access path to AIOS managed storage.
  Core validates catalogue shape before RuntimeStore parses and resolves.
end note

group S1 "AgentRuntime requests location resolution"
  SYS_AR -> SYS_RS : IF_SYS_RUNTIME_STORE.resolve_location(ctx:CallContext, ref:ArtifactRef, profile:ProjectProfile) -> Result[ResolvedLocation]\n[step=S1.1]\n[connection use_port=P_AR_USE_RUNTIME_STORE; prov_port=P_RS_PROV_RUNTIME_STORE; conn=C_AR__RS__RUNTIME_STORE]\n[vals ref.kind=ref.kind; ref.id=ref.id]
  activate SYS_RS

  SYS_RS -> SYS_RS : derive_catalogue_path(profile)\n[step=S1.2]\n[vals catalogue_path=<profile.catalogue_ref_or_default>]
end

group S2 "RuntimeStore reads CM catalogue through ToolsAdapter"
  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.read_text(ctx:CallContext, path:str, opts?:FSReadOptions) -> Result[ReadTextResult]\n[step=S2.1]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=<catalogue_path>; opts.encoding="utf-8"]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_READ_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S2.1r]\n[vals result.outcome=(ok|err); result.err.code=<fs_error_if_any>]

  alt [COND=result.outcome=err]
    SYS_RS -> SYS_RS : classify_cm_catalogue_read_error(result.err)\n[step=S2.2]\n[vals mapped_code=CM_CATALOGUE_UNAVAILABLE]
    SYS_RS --> SYS_AR : [step=S2.3]\n[vals result.outcome=err; result.err.category=(NOT_FOUND|DEPENDENCY); result.err.code=CM_CATALOGUE_UNAVAILABLE]
    deactivate SYS_RS
    stop
  end
end

group S3 "RuntimeStore validates and parses CM catalogue"
  SYS_RS -> SYS_Core : IF_SYS_CORE_SERVICE.validate(ctx:CallContext, items:[ValidationItem], fw:FrameworkHandle) -> Result[ValidationBatchResult]\n[step=S3.1]\n[connection use_port=P_RS_USE_CORE_SERVICE; prov_port=P_CORE_PROV_CORE_SERVICE; conn=C_RS__CORE__CORE_SERVICE]\n[vals items=[{item_id="cm_catalogue"; kind=ARTIFACT; content_type="application/json"; payload_text="<cm_catalogue_json>"}]]
  ref over SYS_RS, SYS_Core
    expand=S_SYS_CORE_VALIDATE
    op=IF_SYS_CORE_SERVICE.validate
    note="Validate(list-of-1) for cm_catalogue.json"
  end ref
  SYS_Core --> SYS_RS : [step=S3.1r]\n[vals result.outcome=(ok|err); result.ok.overall_status=(PASS|FAIL)]

  alt [COND=result.outcome=err or result.ok.overall_status=FAIL]
    SYS_RS --> SYS_AR : [step=S3.2]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=CM_CATALOGUE_INVALID]
    deactivate SYS_RS
    stop
  else [COND=CATALOGUE_VALID]
    SYS_RS -> SYS_RS : parse_cm_catalogue("<cm_catalogue_json>")\n[step=S3.3]\n[vals catalogue=<CMCatalogue>]
  end
end

group S4 "RuntimeStore resolves referenced artifact location"
  SYS_RS -> SYS_RS : resolve_from_catalogue(ref, profile, catalogue)\n[step=S4.1]\n[vals resolved=<ResolvedLocation_or_null>]

  alt [COND=resolved is null]
    SYS_RS --> SYS_AR : [step=S4.2]\n[vals result.outcome=err; result.err.category=NOT_FOUND; result.err.code=EXECUTION_TARGET_UNRESOLVABLE]
    deactivate SYS_RS
    stop
  else [COND=RESOLVED]
    SYS_RS --> SYS_AR : [step=S4.3]\n[vals result.outcome=ok; result.ok=<ResolvedLocation>]
    deactivate SYS_RS
  end
end

@enduml