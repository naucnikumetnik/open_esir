@startuml
title Append durable telemetry to AIOS managed storage

hide footbox
autonumber 10 10
skinparam BoxPadding 12
skinparam SequenceMessageAlign center
skinparam Shadowing false
skinparam ParticipantPadding 18
skinparam ResponseMessageBelowArrow true
skinparam DefaultFontName Monospace

participant "Caller\n(Observability)" as SYS_Obs

box "AIOS — System Components" #F3F3F3
  control "RuntimeStore" as SYS_RS <<component>>
  control "Core" as SYS_Core <<component>>
  control "ToolsAdapter\n(MCP client / ToolBus)" as SYS_Tools <<component>>
end box

box "External Environment" #EEF5FF
  database "AIOS Managed Storage\n(.aios)" as EXT_AIOS <<external>>
end box

note over SYS_Obs, EXT_AIOS #FFF8DC
S_SYS_RUNTIME_STORE_APPEND_TELEMETRY
end note

note over SYS_RS, SYS_Tools
  RuntimeStore owns durable telemetry semantics.
  ToolsAdapter provides the physical access path to AIOS managed storage.
  Core validates derived telemetry artifacts before persistence.
end note

group S1 "Observability requests durable telemetry append"
  SYS_Obs -> SYS_RS : IF_SYS_RUNTIME_STORE.append_telemetry(ctx:CallContext, event:EventEnvelope) -> Result[TelemetryAck]\n[step=S1.1]\n[connection use_port=P_OBS_USE_RUNTIME_STORE; prov_port=P_RS_PROV_RUNTIME_STORE; conn=C_OBS__RS__RUNTIME_STORE]\n[vals event.ev=event.ev; event.retention=durable; event.scope_kind=event.scope_kind; event.scope_ref=event.scope_ref]
  activate SYS_RS
end

group S2 "RuntimeStore validates request and derives telemetry artifacts"
  SYS_RS -> SYS_RS : validate_telemetry_request(event)\n[step=S2.1]\n[vals validate={event_shape, scope_shape, durable_scope_supported}]
  alt [COND=validate.code=EVENT_INVALID]
    SYS_RS --> SYS_Obs : [step=S2.2]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=EVENT_INVALID]
    deactivate SYS_RS
    stop
  else [COND=validate.code=TELEMETRY_SCOPE_INVALID]
    SYS_RS --> SYS_Obs : [step=S2.3]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=TELEMETRY_SCOPE_INVALID]
    deactivate SYS_RS
    stop
  else [COND=REQUEST_VALID]
    SYS_RS -> SYS_RS : derive_telemetry_artifacts(event)\n[step=S2.4]\n[vals derive={telemetry_event_ref, scope_event_record_path, scope_timeline_index_path, cursor_timestamp_material}]
    SYS_RS -> SYS_RS : derive_telemetry_event_record(event, telemetry_event_ref)\n[step=S2.5]\n[vals telemetry_event_record=<TelemetryEventRecord>]
  end
end

group S3 "RuntimeStore validates and serializes immutable event record"
  SYS_RS -> SYS_Core : IF_SYS_CORE_SERVICE.validate(ctx:CallContext, items:[ValidationItem], fw:FrameworkHandle) -> Result[ValidationBatchResult]\n[step=S3.1]\n[connection use_port=P_RS_USE_CORE_SERVICE; prov_port=P_CORE_PROV_CORE_SERVICE; conn=C_RS__CORE__CORE_SERVICE]\n[vals items=[{item_id="telemetry_event_record"; kind=ARTIFACT; content_type="application/json"; payload_any=telemetry_event_record}]]
  ref over SYS_RS, SYS_Core
    expand=S_SYS_CORE_VALIDATE
    op=IF_SYS_CORE_SERVICE.validate
    note="Validate immutable telemetry event record before persistence."
  end ref
  SYS_Core --> SYS_RS : [step=S3.1r]\n[vals result.outcome=(ok|err); result.ok.overall_status=(PASS|FAIL)]

  alt [COND=result.outcome=err or result.ok.overall_status=FAIL]
    SYS_RS --> SYS_Obs : [step=S3.2]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=EVENT_INVALID]
    deactivate SYS_RS
    stop
  else [COND=EVENT_RECORD_VALID]
    SYS_RS -> SYS_RS : serialize_telemetry_event_record(telemetry_event_record)\n[step=S3.3]\n[vals telemetry_event_json="<telemetry_event_json>"]
  end
end

group S4 "RuntimeStore ensures scope event directory exists"
  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.ensure_dir(ctx:CallContext, path:str) -> Result[WriteResult]\n[step=S4.1]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/activity/<scope_kind>/<scope_ref>/events"]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_ENSURE_DIR
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S4.1r]\n[vals result.outcome=(ok|err)]

  alt [COND=result.outcome=err]
    SYS_RS --> SYS_Obs : [step=S4.2]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=TELEMETRY_APPEND_FAILED]
    deactivate SYS_RS
    stop
  end
end

group S5 "RuntimeStore writes immutable event record"
  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.write_text(ctx:CallContext, path:str, text:str, expected_etag?:str, opts?:FSWriteOptions) -> Result[WriteResult]\n[step=S5.1]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/activity/<scope_kind>/<scope_ref>/events/<telemetry_event_ref>.json"; text="<telemetry_event_json>"; expected_etag=null; opts.atomic=true]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_WRITE_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S5.1r]\n[vals result.outcome=(ok|err); result.err.code=<fs_error_if_any>]

  alt [COND=result.outcome=err]
    SYS_RS --> SYS_Obs : [step=S5.2]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=TELEMETRY_APPEND_FAILED]
    deactivate SYS_RS
    stop
  end
end

group S6 "RuntimeStore loads or derives timeline index"
  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.read_text(ctx:CallContext, path:str, opts?:FSReadOptions) -> Result[ReadTextResult]\n[step=S6.1]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/activity/<scope_kind>/<scope_ref>/timeline_index.json"; opts.encoding="utf-8"]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_READ_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S6.1r]\n[vals result.outcome=(ok|err); result.err.code=<fs_error_if_any>]

  alt [COND=result.outcome=err]
    SYS_RS -> SYS_RS : timeline_index=derive_empty_timeline_index(event.scope_kind, event.scope_ref)\n[step=S6.2]
  else [COND=INDEX_READ_OK]
    SYS_RS -> SYS_Core : IF_SYS_CORE_SERVICE.validate(ctx:CallContext, items:[ValidationItem], fw:FrameworkHandle) -> Result[ValidationBatchResult]\n[step=S6.3]\n[connection use_port=P_RS_USE_CORE_SERVICE; prov_port=P_CORE_PROV_CORE_SERVICE; conn=C_RS__CORE__CORE_SERVICE]\n[vals items=[{item_id="timeline_index"; kind=ARTIFACT; content_type="application/json"; payload_text="<timeline_index_json>"}]]
    ref over SYS_RS, SYS_Core
      expand=S_SYS_CORE_VALIDATE
      op=IF_SYS_CORE_SERVICE.validate
      note="Validate current timeline index before merge."
    end ref
    SYS_Core --> SYS_RS : [step=S6.3r]\n[vals result.outcome=(ok|err); result.ok.overall_status=(PASS|FAIL)]

    alt [COND=result.outcome=err or result.ok.overall_status=FAIL]
      note over SYS_RS
        Existing timeline index is invalid.
        Append is treated as failed so later repair/index rebuild can restore consistency.
      end note
      SYS_RS --> SYS_Obs : [step=S6.4]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=TELEMETRY_APPEND_FAILED]
      deactivate SYS_RS
      stop
    else [COND=INDEX_VALID]
      SYS_RS -> SYS_RS : timeline_index=parse_timeline_index("<timeline_index_json>")\n[step=S6.5]
    end
  end
end

group S7 "RuntimeStore merges and persists updated timeline index"
  SYS_RS -> SYS_RS : merge_timeline_index(timeline_index, telemetry_event_ref, cursor_timestamp_material)\n[step=S7.1]\n[vals updated_index=<TimelineIndex>; derived_cursor=<timeline_cursor>]
  SYS_RS -> SYS_RS : serialize_timeline_index(updated_index)\n[step=S7.2]\n[vals updated_timeline_index_json="<updated_timeline_index_json>"]

  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.write_text(ctx:CallContext, path:str, text:str, expected_etag?:str, opts?:FSWriteOptions) -> Result[WriteResult]\n[step=S7.3]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/activity/<scope_kind>/<scope_ref>/timeline_index.json"; text="<updated_timeline_index_json>"; expected_etag="<prior_index_etag_or_null>"; opts.atomic=true]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_WRITE_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S7.3r]\n[vals result.outcome=(ok|err); result.err.code=<fs_error_if_any>]

  alt [COND=result.outcome=err]
    note over SYS_RS
      Immutable event record may already have been written.
      Append is treated as failed to caller and repaired later by
      idempotent index rebuild logic.
    end note
    SYS_RS --> SYS_Obs : [step=S7.4]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=TELEMETRY_APPEND_FAILED]
    deactivate SYS_RS
    stop
  end
end

group S8 "RuntimeStore returns telemetry append acknowledgement"
  SYS_RS --> SYS_Obs : [step=S8.1]\n[vals result.outcome=ok; result.ok.scope_kind=event.scope_kind; result.ok.scope_ref=event.scope_ref; result.ok.telemetry_event_ref=<telemetry_event_ref>; result.ok.cursor=<timeline_cursor>]
  deactivate SYS_RS
end

@enduml