@startuml
title Persist batch execution units to AIOS managed storage

hide footbox
autonumber 10 10
skinparam BoxPadding 12
skinparam SequenceMessageAlign center
skinparam Shadowing false
skinparam ParticipantPadding 18
skinparam ResponseMessageBelowArrow true
skinparam DefaultFontName Monospace

participant "Caller\n(AgentRuntime)" as SYS_AR

box "AIOS — System Components" #F3F3F3
  control "RuntimeStore" as SYS_RS <<component>>
  control "Core" as SYS_Core <<component>>
  control "ToolsAdapter\n(MCP client / ToolBus)" as SYS_Tools <<component>>
end box

box "External Environment" #EEF5FF
  database "AIOS Managed Storage\n(.aios)" as EXT_AIOS <<external>>
end box

note over SYS_AR, EXT_AIOS #FFF8DC
S_SYS_RUNTIME_STORE_PUT_BATCH_EXECUTION_UNITS
end note

note over SYS_RS, SYS_Tools
  RuntimeStore owns persistence semantics for runtime child batch execution units.
  ToolsAdapter provides the physical access path to AIOS managed storage.
  Core validates request payloads and target runtime artifacts before persistence.
end note

group S1 "AgentRuntime requests batch execution-unit persistence"
  SYS_AR -> SYS_RS : IF_SYS_RUNTIME_STORE.put_batch_execution_units(ctx:CallContext, run_ref:str, task_id:str, units:[BatchExecutionUnit]) -> Result[BatchExecutionUnitSetRef]\n[step=S1.1]\n[connection use_port=P_AR_USE_RUNTIME_STORE; prov_port=P_RS_PROV_RUNTIME_STORE; conn=C_AR__RS__RUNTIME_STORE]\n[vals run_ref=run_ref; task_id=task_id; units.count=<n>]
  activate SYS_RS

  alt [COND=run_ref is null or malformed or task_id is null or malformed]
    SYS_RS --> SYS_AR : [step=S1.2]\n[vals result.outcome=err; result.err.category=INPUT; result.err.code=BATCH_EXECUTION_UNIT_REF_INVALID]
    deactivate SYS_RS
    stop
  end
end

group S2 "RuntimeStore validates request payload"
  SYS_RS -> SYS_Core : IF_SYS_CORE_SERVICE.validate(ctx:CallContext, items:[ValidationItem], fw:FrameworkHandle) -> Result[ValidationBatchResult]\n[step=S2.1]\n[connection use_port=P_RS_USE_CORE_SERVICE; prov_port=P_CORE_PROV_CORE_SERVICE; conn=C_RS__CORE__CORE_SERVICE]\n[vals items=[{item_id="batch_execution_unit_set"; kind=ARTIFACT; content_type="application/json"; payload_any=units}]]
  ref over SYS_RS, SYS_Core
    expand=S_SYS_CORE_VALIDATE
    op=IF_SYS_CORE_SERVICE.validate
    note="Validate batch execution-unit set before persistence."
  end ref
  SYS_Core --> SYS_RS : [step=S2.1r]\n[vals result.outcome=(ok|err); result.ok.overall_status=(PASS|FAIL)]

  alt [COND=result.outcome=err or result.ok.overall_status=FAIL]
    SYS_RS --> SYS_AR : [step=S2.2]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=BATCH_EXECUTION_UNIT_SET_INVALID]
    deactivate SYS_RS
    stop
  end
end

group S3 "RuntimeStore loads, validates, and parses target task runtime context"
  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.read_text(ctx:CallContext, path:str, opts?:FSReadOptions) -> Result[ReadTextResult]\n[step=S3.1]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/runs/<run_ref>/task_runtime_index.json"; opts.encoding="utf-8"]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_READ_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S3.1r]\n[vals result.outcome=(ok|err); result.err.code=<fs_error_if_any>]

  alt [COND=result.outcome=err]
    SYS_RS -> SYS_RS : classify_task_runtime_index_read_error(result.err)\n[step=S3.2]\n[vals mapped_code=TASK_RUNTIME_INDEX_UNAVAILABLE]
    SYS_RS --> SYS_AR : [step=S3.3]\n[vals result.outcome=err; result.err.category=(NOT_FOUND|DEPENDENCY); result.err.code=TASK_RUNTIME_INDEX_UNAVAILABLE]
    deactivate SYS_RS
    stop
  end

  SYS_RS -> SYS_Core : IF_SYS_CORE_SERVICE.validate(ctx:CallContext, items:[ValidationItem], fw:FrameworkHandle) -> Result[ValidationBatchResult]\n[step=S3.4]\n[connection use_port=P_RS_USE_CORE_SERVICE; prov_port=P_CORE_PROV_CORE_SERVICE; conn=C_RS__CORE__CORE_SERVICE]\n[vals items=[{item_id="task_runtime_index"; kind=ARTIFACT; content_type="application/json"; payload_text="<task_runtime_index_json>"}]]
  ref over SYS_RS, SYS_Core
    expand=S_SYS_CORE_VALIDATE
    op=IF_SYS_CORE_SERVICE.validate
    note="Validate task_runtime_index.json before parse."
  end ref
  SYS_Core --> SYS_RS : [step=S3.4r]\n[vals result.outcome=(ok|err); result.ok.overall_status=(PASS|FAIL)]

  alt [COND=result.outcome=err or result.ok.overall_status=FAIL]
    SYS_RS --> SYS_AR : [step=S3.5]\n[vals result.outcome=err; result.err.category=VALIDATION; result.err.code=TASK_RUNTIME_INDEX_INVALID]
    deactivate SYS_RS
    stop
  else [COND=INDEX_VALID]
    SYS_RS -> SYS_RS : task_runtime_index=parse_task_runtime_index("<task_runtime_index_json>")\n[step=S3.6]
  end

  alt [COND=task_id not in task_runtime_index.parent_task_ids]
    SYS_RS --> SYS_AR : [step=S3.7]\n[vals result.outcome=err; result.err.category=NOT_FOUND; result.err.code=RUN_TASK_NOT_FOUND]
    deactivate SYS_RS
    stop
  end
end

group S4 "RuntimeStore derives target paths and serializes units + index"
  SYS_RS -> SYS_RS : derive_batch_unit_paths(run_ref, task_id, units)\n[step=S4.1]\n[vals derive={batch_unit_paths, batch_execution_unit_index_path}]
  SYS_RS -> SYS_RS : derive_batch_execution_unit_index(task_id, units)\n[step=S4.2]\n[vals index=<BatchExecutionUnitIndex>]
  SYS_RS -> SYS_RS : serialize_batch_execution_units(units)\n[step=S4.3]\n[vals unit_json_map=<id->json>]
  SYS_RS -> SYS_RS : serialize_batch_execution_unit_index(index)\n[step=S4.4]\n[vals index_json="<batch_execution_unit_index_json>"]
end

group S5 "RuntimeStore ensures task batch directory exists"
  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.ensure_dir(ctx:CallContext, path:str) -> Result[WriteResult]\n[step=S5.1]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/runs/<run_ref>/tasks/<task_id>/batches"]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_ENSURE_DIR
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S5.1r]\n[vals result.outcome=(ok|err)]

  alt [COND=result.outcome=err]
    SYS_RS --> SYS_AR : [step=S5.2]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=BATCH_EXECUTION_UNIT_PERSIST_FAILED]
    deactivate SYS_RS
    stop
  end
end

group S6 "RuntimeStore writes unit records and batch execution-unit index"
  loop [COND=for each unit in units]
    SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.write_text(ctx:CallContext, path:str, text:str, expected_etag?:str, opts?:FSWriteOptions) -> Result[WriteResult]\n[step=S6.1]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/runs/<run_ref>/tasks/<task_id>/batches/<unit.id>.json"; text="<unit_json>"; expected_etag=null; opts.atomic=true]
    ref over SYS_RS, SYS_Tools, EXT_AIOS
      expand=S_SYS_TOOL_BUS_FS_WRITE_TEXT
      ref_mode=call_return
    end ref
    SYS_Tools --> SYS_RS : [step=S6.1r]\n[vals result.outcome=(ok|err); result.err.code=<fs_error_if_any>]

    alt [COND=result.outcome=err]
      note over SYS_RS
        Some earlier unit records may already have been written.
        Persistence is treated as failed to caller and recovered later by
        idempotent overwrite/repair in a later slice.
      end note
      SYS_RS --> SYS_AR : [step=S6.2]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=BATCH_EXECUTION_UNIT_PERSIST_FAILED]
      deactivate SYS_RS
      stop
    end
  end

  SYS_RS -> SYS_Tools : IF_SYS_TOOL_BUS.fs.write_text(ctx:CallContext, path:str, text:str, expected_etag?:str, opts?:FSWriteOptions) -> Result[WriteResult]\n[step=S6.3]\n[connection use_port=P_RS_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_RS__TOOLS__TOOL_BUS]\n[vals path=".aios/runtime/runs/<run_ref>/tasks/<task_id>/batch_execution_unit_index.json"; text="<batch_execution_unit_index_json>"; expected_etag=null; opts.atomic=true]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_TOOL_BUS_FS_WRITE_TEXT
    ref_mode=call_return
  end ref
  SYS_Tools --> SYS_RS : [step=S6.3r]\n[vals result.outcome=(ok|err); result.err.code=<fs_error_if_any>]

  alt [COND=result.outcome=err]
    note over SYS_RS
      Unit records may already have been written while the index update failed.
      Persistence is treated as failed to caller and recovered later by
      idempotent index rebuild logic in a later slice.
    end note
    SYS_RS --> SYS_AR : [step=S6.4]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=BATCH_EXECUTION_UNIT_PERSIST_FAILED]
    deactivate SYS_RS
    stop
  end
end

group S7 "RuntimeStore returns batch execution-unit set reference"
  SYS_RS --> SYS_AR : [step=S7.1]\n[vals result.outcome=ok; result.ok.status=BATCH_EXECUTION_UNITS_PERSISTED; result.ok.batch_execution_unit_count=<n>; result.ok.task_id=task_id]
  deactivate SYS_RS
end

@enduml