@startuml
title Start run execution automatically after plan confirmation

hide footbox
autonumber 10 10
skinparam BoxPadding 12
skinparam SequenceMessageAlign center
skinparam Shadowing false
skinparam ParticipantPadding 18
skinparam ResponseMessageBelowArrow true
skinparam DefaultFontName Monospace

participant "Caller\n(S_SYS_CONFIRM_OR_REJECT_EXECUTION_PLAN / AgentRuntime)" as SYS_AR

box "AIOS — System Components" #F3F3F3
  control  "RuntimeStore" as SYS_RS <<component>>
  control  "ToolsAdapter\n(MCP client / ToolBus)" as SYS_Tools <<component>>
  control  "Observability\n(EventBus/Logger)" as SYS_Obs <<component>>
end box

box "External Environment" #EEF5FF
  database "AIOS Managed Storage\n(.aios)" as EXT_AIOS <<external>>
end box

note over SYS_AR, EXT_AIOS #FFF8DC
S_SYS_START_RUN_EXECUTION
[semantics scope={run_admission_only}; observability_effect=best_effort]
end note

note over SYS_AR
  Automatic continuation of successful draft-plan confirmation.
  Begins only after run_ref exists and run-scoped execution artifacts
  have been materialized.
end note

group S1 "AgentRuntime begins automatic run start"
  SYS_AR -> SYS_Obs : IF_SYS_OBSERVABILITY.emit(ctx:CallContext, event:EventEnvelope) -> Result[EmitAck]\n[step=S1.1]\n[connection use_port=P_AR_USE_OBSERVABILITY; prov_port=P_OBS_PROV_OBSERVABILITY; conn=C_AR__OBS__OBSERVABILITY]\n[vals event.ev=RUN_EXECUTION_START_STARTED; event.severity=INFO; event.visibility=internal; event.scope_kind=run; event.scope_ref=<run_ref>; event.data.plan_ref=<plan_ref>]
  ref over SYS_AR, SYS_Obs
    expand=S_SYS_OBSERVABILITY_EMIT
    ref_mode=call_return
  end ref
  SYS_Obs --> SYS_AR : [step=S1.1r]\n[vals result.outcome=ok]
end

group S2 "AgentRuntime admits run by state transition"
  SYS_AR -> SYS_RS : IF_SYS_RUNTIME_STORE.apply_patch(ctx:CallContext, ref:ArtifactRef, patch:PatchEnvelope) -> Result[PatchAck]\n[step=S2.1]\n[connection use_port=P_AR_USE_RUNTIME_STORE; prov_port=P_RS_PROV_RUNTIME_STORE; conn=C_AR__RS__RUNTIME_STORE]\n[vals ref={kind="run", id=<run_ref>}; patch.preconditions.run_state=READY_FOR_EXECUTION; patch.ops=[set run_state=RUNNING, set started_at=<now>, set current_phase=ORCHESTRATION_ACTIVE]]
  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_RUNTIME_STORE_APPLY_PATCH
    ref_mode=call_return
  end ref
  SYS_RS --> SYS_AR : [step=S2.1r]\n[vals result.outcome=(ok|err)]

  SYS_AR -> SYS_AR : classify_run_admission_outcome(result)\n[step=S2.1c]\n[vals on_ok={status=RUN_STARTED}; on_err={code=RUN_START_FAILED}]

  alt [COND=classified.code=RUN_START_FAILED]
    SYS_AR -> SYS_Obs : IF_SYS_OBSERVABILITY.emit(ctx:CallContext, event:EventEnvelope) -> Result[EmitAck]\n[step=S2.2]\n[connection use_port=P_AR_USE_OBSERVABILITY; prov_port=P_OBS_PROV_OBSERVABILITY; conn=C_AR__OBS__OBSERVABILITY]\n[vals event.ev=RUN_EXECUTION_START_FAILED; event.severity=ERROR; event.visibility=internal; event.scope_kind=run; event.scope_ref=<run_ref>; event.data.reason=RUN_START_REJECTED_OR_PATCH_FAILED; event.data.plan_ref=<plan_ref>]
    ref over SYS_AR, SYS_Obs
      expand=S_SYS_OBSERVABILITY_EMIT
      ref_mode=call_return
    end ref
    SYS_Obs --> SYS_AR : [step=S2.2r]\n[vals result.outcome=ok]

    SYS_AR --> SYS_AR : [step=S2.3]\n[vals result.outcome=err; result.err.category=CONFLICT|DEPENDENCY; result.err.code=RUN_START_FAILED; result.err.run_ref=<run_ref>; result.err.run_exists=(true|false)]

  else [COND=classified.status=RUN_STARTED]
    SYS_AR -> SYS_Obs : IF_SYS_OBSERVABILITY.emit(ctx:CallContext, event:EventEnvelope) -> Result[EmitAck]\n[step=S2.4]\n[connection use_port=P_AR_USE_OBSERVABILITY; prov_port=P_OBS_PROV_OBSERVABILITY; conn=C_AR__OBS__OBSERVABILITY]\n[vals event.ev=RUN_EXECUTION_STARTED; event.severity=INFO; event.visibility=both; event.user_msg="Run execution started"; event.scope_kind=run; event.scope_ref=<run_ref>; event.data.plan_ref=<plan_ref>]
    ref over SYS_AR, SYS_Obs
      expand=S_SYS_OBSERVABILITY_EMIT
      ref_mode=call_return
    end ref
    SYS_Obs --> SYS_AR : [step=S2.4r]\n[vals result.outcome=ok]

    group S3 "Control hands off to run orchestration loop"
      ref over SYS_AR, SYS_RS
        expand=S_SYS_RUN_ORCHESTRATION_LOOP
        ref_mode=handoff
      end ref

      SYS_AR --> SYS_AR : [step=S3.1]\n[vals result.outcome=ok; result.ok.status=RUN_ADMITTED; result.ok.run_ref=<run_ref>; result.ok.run_state=RUNNING; result.ok.current_phase=ORCHESTRATION_ACTIVE]
    end
  end
end

@enduml