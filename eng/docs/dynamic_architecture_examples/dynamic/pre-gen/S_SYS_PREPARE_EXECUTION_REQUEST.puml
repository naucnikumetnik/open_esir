@startuml
title Prepare execution request (defined entry path; validate admissibility + resolve target + check AgentStore)

hide footbox
autonumber 10 10
skinparam BoxPadding 12
skinparam SequenceMessageAlign center
skinparam Shadowing false
skinparam ParticipantPadding 18
skinparam ResponseMessageBelowArrow true
skinparam DefaultFontName Monospace

actor "Human\n(Developer/Operator)" as Human

box "AIOS — System Components" #F3F3F3
  boundary "UI\n(Web / CLI / Chat)" as SYS_UI <<component>>
  boundary "ClientGateway" as SYS_CG <<component>>
  control  "AgentRuntime" as SYS_AR <<component>>
  control  "Core" as SYS_Core <<component>>
  control  "RuntimeStore" as SYS_RS <<component>>
  control  "AgentStore" as SYS_AS <<component>>
  control  "ToolsAdapter\n(MCP client / ToolBus)" as SYS_Tools <<component>>
  control  "Observability\n(EventBus/Logger)" as SYS_Obs <<component>>
end box

box "External Environment" #EEF5FF
  database "AIOS Managed Storage\n(.aios)" as EXT_AIOS <<external>>
  database "Project Workspace\n(project artifacts)" as EXT_WS <<external>>
end box

note over Human, EXT_WS #FFF8DC
S_SYS_PREPARE_EXECUTION_REQUEST
end note

note over SYS_UI, SYS_CG
  UI is the human-facing interaction surface.
  ClientGateway provides stable backend-facing contracts to all UIs.
end note

note over SYS_AR
  This scenario validates request admissibility, resolves execution intent,
  and checks AgentStore feasibility (at least one feasible agent; model config typed;
  local model blobs present when required).
  It does not yet prove that all task-local workspace dependencies are available.
  That is done during execution-plan build.
  AgentRuntime is the only system component that touches target-project artifacts.
  Internally, that endpoint-aware access is owned by ArtifactIO.
  Core only receives resolved target location + blob and never reads target artifacts directly.
end note

group S1 "Human submits execution request"
  Human -> SYS_UI : submit_execution_request(target_id:str, requested_mode:ExecutionMode, review_mode:ReviewMode, user_prefs?:ExecutionPrefs)\n[step=S1.1]
  activate SYS_UI

  SYS_UI -> SYS_CG : IF_SYS_CLIENT_GATEWAY_EXECUTION.prepare_execution_request(ctx:CallContext, req:ExecuteRequest) -> Result[PrepareExecutionRequestResult]\n[step=S1.2]\n[connection use_port=P_UI_USE_CLIENT_GATEWAY_EXECUTION; prov_port=P_CG_PROV_CLIENT_GATEWAY_EXECUTION; conn=C_UI__CG__CLIENT_GATEWAY_EXECUTION]\n[vals req.target_id=<artifact_id>; req.requested_mode=<auto|unit|workflow>; req.review_mode=<inherit|force_on|force_off>; req.user_prefs=<optional>]
  activate SYS_CG

  SYS_CG -> SYS_AR : IF_SYS_AGENT_RUNTIME.prepare_execution_request(ctx:CallContext, req:ExecuteRequest) -> Result[PrepareExecutionRequestResult]\n[step=S1.3]\n[connection use_port=P_CG_USE_AGENT_RUNTIME; prov_port=P_AR_PROV_AGENT_RUNTIME; conn=C_CG__AR__AGENT_RUNTIME]\n[vals req.target_id=req.target_id; req.requested_mode=req.requested_mode; req.review_mode=req.review_mode; req.user_prefs=req.user_prefs]
  activate SYS_AR
end

group S2 "AgentRuntime loads project execution context"
  SYS_AR -> SYS_Obs : IF_SYS_OBSERVABILITY.emit(ctx:CallContext, event:EventEnvelope) -> Result[EmitAck]\n[step=S2.1]\n[connection use_port=P_AR_USE_OBSERVABILITY; prov_port=P_OBS_PROV_OBSERVABILITY; conn=C_AR__OBS__OBSERVABILITY]\n[vals event.ev=EXECUTION_REQUEST_PREPARE_STARTED; event.severity=INFO; event.visibility=internal]
  ref over SYS_AR, SYS_Obs
    expand=S_SYS_OBSERVABILITY_EMIT
    ref_mode=call_return
  end ref
  SYS_Obs --> SYS_AR : [step=S2.1r]\n[vals result.outcome=ok]

  SYS_AR -> SYS_RS : IF_SYS_RUNTIME_STORE.get_project_profile(ctx:CallContext) -> Result[ProjectProfile]\n[step=S2.2]\n[connection use_port=P_AR_USE_RUNTIME_STORE; prov_port=P_RS_PROV_RUNTIME_STORE; conn=C_AR__RS__RUNTIME_STORE]

  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_RUNTIME_STORE_GET_PROJECT_PROFILE
    ref_mode=call_return
  end ref

  SYS_RS --> SYS_AR : [step=S2.2r]\n[vals result.outcome=(ok|err); result.err.code=PROJECT_PROFILE_UNAVAILABLE]

  alt [COND=result.outcome=err and result.err.code=PROJECT_PROFILE_UNAVAILABLE]
    SYS_AR -> SYS_Obs : IF_SYS_OBSERVABILITY.emit(ctx:CallContext, event:EventEnvelope) -> Result[EmitAck]\n[step=S2.3]\n[connection use_port=P_AR_USE_OBSERVABILITY; prov_port=P_OBS_PROV_OBSERVABILITY; conn=C_AR__OBS__OBSERVABILITY]\n[vals event.ev=EXECUTION_REQUEST_PREPARE_FAILED; event.severity=ERROR; event.visibility=internal; event.data.reason=PROJECT_PROFILE_UNAVAILABLE]
    ref over SYS_AR, SYS_Obs
      expand=S_SYS_OBSERVABILITY_EMIT
      ref_mode=call_return
    end ref
    SYS_Obs --> SYS_AR : [step=S2.3r]\n[vals result.outcome=ok]

    SYS_AR --> SYS_CG : [step=S2.4]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=PROJECT_PROFILE_UNAVAILABLE]
    SYS_CG --> SYS_UI : [step=S2.5]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=PROJECT_PROFILE_UNAVAILABLE]
    SYS_UI --> Human : show_error("Project profile unavailable")\n[step=S2.6]
    deactivate SYS_AR
    deactivate SYS_CG
    deactivate SYS_UI

  else [COND=result.outcome=ok]
  end
end

group S3 "AgentRuntime resolves and reads requested target"
  SYS_AR -> SYS_RS : IF_SYS_RUNTIME_STORE.resolve_location(ctx:CallContext, ref:ArtifactRef, profile:ProjectProfile) -> Result[ResolvedLocation]\n[step=S3.1]\n[connection use_port=P_AR_USE_RUNTIME_STORE; prov_port=P_RS_PROV_RUNTIME_STORE; conn=C_AR__RS__RUNTIME_STORE]\n[vals ref={kind="execution_target", id=req.target_id}]

  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_RUNTIME_STORE_RESOLVE_LOCATION
    ref_mode=call_return
  end ref

  SYS_RS --> SYS_AR : [step=S3.1r]\n[vals result.outcome=(ok|err); result.err.code=EXECUTION_TARGET_UNRESOLVABLE; result.ok.endpoint_kind=<local|runtime_store|external>; result.ok.locator=<resolved_locator>; result.ok.content_type_hint=<optional>]

  alt [COND=result.outcome=err and result.err.code=EXECUTION_TARGET_UNRESOLVABLE]
    SYS_AR -> SYS_Obs : IF_SYS_OBSERVABILITY.emit(ctx:CallContext, event:EventEnvelope) -> Result[EmitAck]\n[step=S3.2]\n[connection use_port=P_AR_USE_OBSERVABILITY; prov_port=P_OBS_PROV_OBSERVABILITY; conn=C_AR__OBS__OBSERVABILITY]\n[vals event.ev=EXECUTION_REQUEST_PREPARE_FAILED; event.severity=ERROR; event.visibility=internal; event.data.reason=EXECUTION_TARGET_UNRESOLVABLE; event.data.target_id=req.target_id]
    ref over SYS_AR, SYS_Obs
      expand=S_SYS_OBSERVABILITY_EMIT
      ref_mode=call_return
    end ref
    SYS_Obs --> SYS_AR : [step=S3.2r]\n[vals result.outcome=ok]

    SYS_AR --> SYS_CG : [step=S3.3]\n[vals result.outcome=err; result.err.category=NOT_FOUND; result.err.code=EXECUTION_TARGET_UNRESOLVABLE]
    SYS_CG --> SYS_UI : [step=S3.4]\n[vals result.outcome=err; result.err.category=NOT_FOUND; result.err.code=EXECUTION_TARGET_UNRESOLVABLE]
    SYS_UI --> Human : show_error("Execution target not found")\n[step=S3.5]
    deactivate SYS_AR
    deactivate SYS_CG
    deactivate SYS_UI

  else [COND=result.outcome=ok]
  end

  alt [COND=result.outcome=ok and result.ok.endpoint_kind=local]
    SYS_AR -> SYS_Tools : IF_SYS_TOOL_BUS.fs.read_bytes(ctx:CallContext, path:str, opts?:FSReadOptions) -> Result[ReadBytesResult]\n[step=S3.6]\n[connection use_port=P_AR_USE_TOOL_BUS; prov_port=P_TOOLS_PROV_TOOL_BUS; conn=C_AR__TOOLS__TOOL_BUS]\n[vals path=<resolved_locator.path>]
    ref over SYS_AR, SYS_Tools, EXT_WS
      expand=S_SYS_TOOL_BUS_FS_READ_BYTES
      ref_mode=call_return
      note="System-level simplification: ArtifactIO owns this target-artifact read inside AgentRuntime; local targets use the ToolBus filesystem capability."
    end ref
    SYS_Tools --> SYS_AR : [step=S3.6r]\n[vals result.outcome=(ok|err)]

    SYS_AR -> SYS_AR : classify_target_read_outcome(result)\n[step=S3.6c]\n[vals on_ok={status=TARGET_READ_OK}; on_err={code=EXECUTION_TARGET_READ_FAILED}]

  else [COND=result.outcome=ok and result.ok.endpoint_kind=other]
    note over SYS_AR
      Non-local target-location kinds remain endpoint-aware.
      AgentRuntime still owns target-artifact access internally via ArtifactIO;
      this scenario only exercises the local ToolBus filesystem branch.
    end note
  end

  alt [COND=result.outcome=err and result.err.code=EXECUTION_TARGET_READ_FAILED]
    SYS_AR -> SYS_Obs : IF_SYS_OBSERVABILITY.emit(ctx:CallContext, event:EventEnvelope) -> Result[EmitAck]\n[step=S3.8]\n[connection use_port=P_AR_USE_OBSERVABILITY; prov_port=P_OBS_PROV_OBSERVABILITY; conn=C_AR__OBS__OBSERVABILITY]\n[vals event.ev=EXECUTION_REQUEST_PREPARE_FAILED; event.severity=ERROR; event.visibility=internal; event.data.reason=EXECUTION_TARGET_READ_FAILED; event.data.target_id=req.target_id]
    ref over SYS_AR, SYS_Obs
      expand=S_SYS_OBSERVABILITY_EMIT
      ref_mode=call_return
    end ref
    SYS_Obs --> SYS_AR : [step=S3.8r]\n[vals result.outcome=ok]

    SYS_AR --> SYS_CG : [step=S3.9]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=EXECUTION_TARGET_READ_FAILED]
    SYS_CG --> SYS_UI : [step=S3.10]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=EXECUTION_TARGET_READ_FAILED]
    SYS_UI --> Human : show_error("Execution target read failed")\n[step=S3.11]
    deactivate SYS_AR
    deactivate SYS_CG
    deactivate SYS_UI

  else [COND=classified.status=TARGET_READ_OK]
  end
end

group S4 "Core validates request admissibility and prepares normalized execution intent"
  SYS_AR -> SYS_Core : IF_SYS_CORE_SERVICE.prepare_execution_intent(ctx:CallContext, req:ExecuteRequest, profile:ProjectProfile, target_loc:ResolvedLocation, target_blob:ArtifactBlob) -> Result[PreparedExecutionIntent]\n[step=S4.1]\n[connection use_port=P_AR_USE_CORE_SERVICE; prov_port=P_CORE_PROV_CORE_SERVICE; conn=C_AR__CORE__CORE_SERVICE]\n[vals req.requested_mode=req.requested_mode; req.review_mode=req.review_mode; req.user_prefs=req.user_prefs]
  ref over SYS_AR, SYS_Core
    expand=S_SYS_CORE_PREPARE_EXECUTION_INTENT
    ref_mode=call_return
  end ref
  SYS_Core --> SYS_AR : [step=S4.1r]\n[vals result.outcome=(ok|err); result.err.code=EXECUTION_REQUEST_INVALID]

  alt [COND=result.outcome=err and result.err.code=EXECUTION_REQUEST_INVALID]
    SYS_AR -> SYS_Obs : IF_SYS_OBSERVABILITY.emit(ctx:CallContext, event:EventEnvelope) -> Result[EmitAck]\n[step=S4.2]\n[connection use_port=P_AR_USE_OBSERVABILITY; prov_port=P_OBS_PROV_OBSERVABILITY; conn=C_AR__OBS__OBSERVABILITY]\n[vals event.ev=EXECUTION_REQUEST_PREPARE_REJECTED; event.severity=WARN; event.visibility=internal; event.data.target_id=req.target_id]
    ref over SYS_AR, SYS_Obs
      expand=S_SYS_OBSERVABILITY_EMIT
      ref_mode=call_return
    end ref
    SYS_Obs --> SYS_AR : [step=S4.2r]\n[vals result.outcome=ok]

    SYS_AR --> SYS_CG : [step=S4.3]\n[vals result.outcome=ok; result.ok.status=NEEDS_CHANGE; result.ok.reason=EXECUTION_REQUEST_INVALID]
    SYS_CG --> SYS_UI : [step=S4.4]\n[vals result.outcome=ok; result.ok.status=NEEDS_CHANGE; result.ok.reason=EXECUTION_REQUEST_INVALID]
    SYS_UI --> Human : update_view_state(status="needs_change", reason="EXECUTION_REQUEST_INVALID")\n[step=S4.5]
    deactivate SYS_AR
    deactivate SYS_CG
    deactivate SYS_UI

  else [COND=result.outcome=ok]
    note over SYS_AR
      PreparedExecutionIntent now carries normalized execution_kind,
      resolved review policy, validated target identity, normalized planning_basis,
      and pinned context needed for execution-plan build.
      It is ready for plan build, not yet guaranteed execution-ready.
    end note
  end
end

group S4b "AgentStore checks configured models (inventory + typed meta + local blobs) and returns feasible candidates"
  SYS_AR -> SYS_AS : IF_SYS_AGENT_STORE.list_planning_candidates(ctx:CallContext, intent:PreparedExecutionIntent) -> Result[PlanningCandidateSet]\n[step=S4b.1]\n[connection use_port=P_AR_USE_AGENT_STORE; prov_port=P_AS_PROV_AGENT_STORE; conn=C_AR__AS__AGENT_STORE]\n[vals intent=<prepared_intent_from_S4>]

  ref over SYS_AS, SYS_Tools, EXT_AIOS
    expand=S_SYS_AGENT_STORE_LIST_PLANNING_CANDIDATES
    ref_mode=call_return
    note="AgentStore validates: inventory exists; model_card/access typed; if local_file then model blob exists."
  end ref

  SYS_AS --> SYS_AR : [step=S4b.1r]\n[vals result.outcome=(ok|err); result.err.code=(AGENT_INVENTORY_UNAVAILABLE|AGENT_MODEL_META_UNAVAILABLE|NO_FEASIBLE_PLANNING_CANDIDATES)]

  alt [COND=result.outcome=err]
    SYS_AR -> SYS_Obs : IF_SYS_OBSERVABILITY.emit(ctx:CallContext, event:EventEnvelope) -> Result[EmitAck]\n[step=S4b.2]\n[connection use_port=P_AR_USE_OBSERVABILITY; prov_port=P_OBS_PROV_OBSERVABILITY; conn=C_AR__OBS__OBSERVABILITY]\n[vals event.ev=EXECUTION_REQUEST_PREPARE_REJECTED; event.severity=WARN; event.visibility=both; event.user_msg="Agent configuration needs update"; event.data.reason=result.err.code]
    ref over SYS_AR, SYS_Obs
      expand=S_SYS_OBSERVABILITY_EMIT
      ref_mode=call_return
    end ref
    SYS_Obs --> SYS_AR : [step=S4b.2r]\n[vals result.outcome=ok]

    SYS_AR --> SYS_CG : [step=S4b.3]\n[vals result.outcome=ok; result.ok.status=NEEDS_CHANGE; result.ok.reason=result.err.code]
    SYS_CG --> SYS_UI : [step=S4b.4]\n[vals result.outcome=ok; result.ok.status=NEEDS_CHANGE; result.ok.reason=result.err.code]
    SYS_UI --> Human : update_view_state(status="needs_change", reason=result.err.code)\n[step=S4b.5]
    deactivate SYS_AR
    deactivate SYS_CG
    deactivate SYS_UI

  else [COND=result.outcome=ok]
    note over SYS_AR
      AgentStore returned a feasible candidate set.
      (Optional) AgentRuntime may keep candidates summary for plan-build UX, but persistence is not required here.
    end note
  end
end

group S5 "AgentRuntime persists prepared execution intent"
  SYS_AR -> SYS_RS : IF_SYS_RUNTIME_STORE.put_prepared_execution_intent(ctx:CallContext, intent:PreparedExecutionIntent) -> Result[PreparedExecutionIntentRef]\n[step=S5.1]\n[connection use_port=P_AR_USE_RUNTIME_STORE; prov_port=P_RS_PROV_RUNTIME_STORE; conn=C_AR__RS__RUNTIME_STORE]\n[vals intent.execution_kind=<unit_or_workflow>; intent.review_policy=<resolved_review_policy>; intent.target_ref=<resolved_target_ref>; intent.planning_basis.basis_kind=<normalized_basis_kind>; intent.planning_basis.task_seeds=<normalized_task_seeds>; intent.source_artifact_kind=<normalized_source_kind>; intent.realization_mode=<normalized_realization_mode>]

  ref over SYS_RS, SYS_Tools, EXT_AIOS
    expand=S_SYS_RUNTIME_STORE_PUT_PREPARED_EXECUTION_INTENT
    ref_mode=call_return
  end ref

  SYS_RS --> SYS_AR : [step=S5.1r]\n[vals result.outcome=(ok|err); result.err.code=PREPARED_INTENT_PERSIST_FAILED]

  alt [COND=result.outcome=err and result.err.code=PREPARED_INTENT_PERSIST_FAILED]
    SYS_AR -> SYS_Obs : IF_SYS_OBSERVABILITY.emit(ctx:CallContext, event:EventEnvelope) -> Result[EmitAck]\n[step=S5.2]\n[connection use_port=P_AR_USE_OBSERVABILITY; prov_port=P_OBS_PROV_OBSERVABILITY; conn=C_AR__OBS__OBSERVABILITY]\n[vals event.ev=EXECUTION_REQUEST_PREPARE_FAILED; event.severity=ERROR; event.visibility=internal; event.data.reason=PREPARED_INTENT_PERSIST_FAILED]
    ref over SYS_AR, SYS_Obs
      expand=S_SYS_OBSERVABILITY_EMIT
      ref_mode=call_return
    end ref
    SYS_Obs --> SYS_AR : [step=S5.2r]\n[vals result.outcome=ok]

    SYS_AR --> SYS_CG : [step=S5.3]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=PREPARED_INTENT_PERSIST_FAILED]
    SYS_CG --> SYS_UI : [step=S5.4]\n[vals result.outcome=err; result.err.category=DEPENDENCY; result.err.code=PREPARED_INTENT_PERSIST_FAILED]
    SYS_UI --> Human : show_error("Prepared execution intent could not be stored")\n[step=S5.5]
    deactivate SYS_AR
    deactivate SYS_CG
    deactivate SYS_UI

  else [COND=result.outcome=ok]
  end
end

group S6 "Prepared execution request result is returned through entry path"
  SYS_AR -> SYS_Obs : IF_SYS_OBSERVABILITY.emit(ctx:CallContext, event:EventEnvelope) -> Result[EmitAck]\n[step=S6.1]\n[connection use_port=P_AR_USE_OBSERVABILITY; prov_port=P_OBS_PROV_OBSERVABILITY; conn=C_AR__OBS__OBSERVABILITY]\n[vals event.ev=EXECUTION_REQUEST_PREPARE_DONE; event.severity=INFO; event.visibility=internal]
  ref over SYS_AR, SYS_Obs
    expand=S_SYS_OBSERVABILITY_EMIT
    ref_mode=call_return
  end ref
  SYS_Obs --> SYS_AR : [step=S6.1r]\n[vals result.outcome=ok]

  SYS_AR --> SYS_CG : [step=S6.2]\n[vals result.outcome=ok; result.ok.status=READY_FOR_PLAN_BUILD; result.ok.prepared_intent_ref=<prepared_intent_ref>; result.ok.execution_kind=<unit_or_workflow>; result.ok.review_policy=<resolved_review_policy>; result.ok.target_ref=<resolved_target_ref>]
  SYS_CG --> SYS_UI : [step=S6.3]\n[vals result.outcome=ok; result.ok.status=READY_FOR_PLAN_BUILD; result.ok.prepared_intent_ref=<prepared_intent_ref>; result.ok.execution_kind=<unit_or_workflow>; result.ok.review_policy=<resolved_review_policy>; result.ok.target_ref=<resolved_target_ref>]
  SYS_UI --> Human : show_prepared_execution_request(status="READY_FOR_PLAN_BUILD", prepared_intent_ref=<prepared_intent_ref>)\n[step=S6.4]

  deactivate SYS_AR
  deactivate SYS_CG
  deactivate SYS_UI
end

@enduml
