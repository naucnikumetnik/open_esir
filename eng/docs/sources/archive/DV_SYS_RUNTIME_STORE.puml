  class "CORR_OP_EVIDENCE_WRITES" as CORR_OP_EVIDENCE_WRITES {
    kind=operation_writes_entities
    from=IF_SYS_RUNTIME_STORE.put_evidence_blob
    to=[E_EVIDENCE_PAYLOAD,E_EVIDENCE_META,E_EVIDENCE_INDEX]
    rule=evidence_index_best_effort
  }
}

' Relationships
E_DRAFT_PLAN_DOCUMENT "1" --> "0..1" E_RUN_EXECUTION_PLAN : R_DRAFT_ACTIVATES_RUN_PLAN|activation|1..0..1
E_DRAFT_PLAN_DOCUMENT "1" --> "0..1" E_RUN_META : R_DRAFT_ACTIVATES_RUN_META|activation|1..0..1
E_DRAFT_PLAN_DOCUMENT "1" --> "0..1" E_TASK_RUNTIME_INDEX : R_DRAFT_ACTIVATES_TASK_INDEX|activation|1..0..1

E_RUN_META "1" --> "1" E_RUN_EXECUTION_PLAN : R_RUN_HAS_EXECUTION_PLAN|association|1..1
E_RUN_META "1" --> "1" E_TASK_RUNTIME_INDEX : R_RUN_HAS_TASK_RUNTIME_INDEX|association|1..1
E_RUN_META "1" --> "N" E_EVIDENCE_META : R_RUN_HAS_EVIDENCE|association|1..N
E_RUN_META "1" --> "N" E_TELEMETRY_EVENT : R_RUN_HAS_ACTIVITY|association|1..N
E_RUN_META "1" ..> E_PROGRESS_SNAPSHOT : R_RUN_DERIVES_PROGRESS|derived_from|1..0..1

E_TASK_RUNTIME_INDEX "1" --> "N" E_BATCH_EXECUTION_UNIT : R_TASK_HAS_BATCH_UNITS|association|1..N
E_TASK_RUNTIME_INDEX "1" --> "N" E_BATCH_EXECUTION_UNIT_INDEX : R_TASK_HAS_BATCH_UNIT_INDEX|association|1..N
E_BATCH_EXECUTION_UNIT "1" --> "0..1" E_BATCH_ATTEMPT_INDEX : R_BATCH_HAS_ATTEMPT_INDEX|association|1..0..1
E_BATCH_EXECUTION_UNIT "1" --> "N" E_BATCH_ATTEMPT_RECORD : R_BATCH_HAS_ATTEMPTS|association|1..N

E_EVIDENCE_META "1" --> "1" E_EVIDENCE_PAYLOAD : R_EVIDENCE_META_DESCRIBES_PAYLOAD|pair|1..1
E_TELEMETRY_EVENT "N" --> "1" E_TIMELINE_INDEX : R_TIMELINE_INDEXES_EVENTS|index_of|N..1

@enduml
