  }

  class "CORR_EVIDENCE_META_PAYLOAD" as CORR_EVIDENCE_META_PAYLOAD {
    kind=type_is_payload_of_entity
    from=TL_RUNTIME_STORE.EvidenceMeta
    to=E_EVIDENCE_META
  }

  class "CORR_TELEMETRY_PAYLOAD" as CORR_TELEMETRY_PAYLOAD {
    kind=type_is_payload_of_entity
    from=TL_OBSERVABILITY.EventEnvelope
    to=E_TELEMETRY_EVENT
  }

  class "CORR_TIMELINE_INDEX_PAYLOAD" as CORR_TIMELINE_INDEX_PAYLOAD {
    kind=type_is_payload_of_entity
    from=TL_RUNTIME_STORE.TimelineIndex
    to=E_TIMELINE_INDEX
  }

  class "CORR_OP_APPEND_TELEMETRY" as CORR_OP_APPEND_TELEMETRY {
    kind=operation_writes_entities
    from=IF_SYS_RUNTIME_STORE.append_telemetry
    to=[E_TELEMETRY_EVENT,E_TIMELINE_INDEX]
  }

  class "CORR_OP_PROGRESS_READS" as CORR_OP_PROGRESS_READS {
    kind=operation_reads_entities
    from=IF_SYS_RUNTIME_STORE.get_progress_snapshot
