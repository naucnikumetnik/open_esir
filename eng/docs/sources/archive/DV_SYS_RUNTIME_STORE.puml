  class "CORR_PROFILE_PAYLOAD" as CORR_PROFILE_PAYLOAD {
    kind=type_is_payload_of_entity
    from=TL_RUNTIME_STORE.ProjectProfile
    to=E_PROJECT_PROFILE
  }

  class "CORR_CM_CATALOGUE_PAYLOAD" as CORR_CM_CATALOGUE_PAYLOAD {
    kind=type_is_payload_of_entity
    from=TL_RUNTIME_STORE.CMCatalogue
    to=E_CM_CATALOGUE
  }

  class "CORR_PREPARED_INTENT_PAYLOAD" as CORR_PREPARED_INTENT_PAYLOAD {
    kind=type_is_payload_of_entity
    from=TL_RUNTIME_STORE.PreparedExecutionIntent
    to=E_PREPARED_EXECUTION_INTENT
  }

  class "CORR_DRAFT_PLAN_DOC_PAYLOAD" as CORR_DRAFT_PLAN_DOC_PAYLOAD {
    kind=type_is_payload_of_entity
    from=TL_RUNTIME_STORE.DraftPlanDocument
    to=E_DRAFT_PLAN_DOCUMENT
  }

  class "CORR_RUN_META_PAYLOAD" as CORR_RUN_META_PAYLOAD {
