    from=TL_RUNTIME_STORE.BatchExecutionUnitIndex
    to=E_BATCH_EXECUTION_UNIT_INDEX
  }

  class "CORR_ATTEMPT_RECORD_PAYLOAD" as CORR_ATTEMPT_RECORD_PAYLOAD {
    kind=type_is_payload_of_entity
    from=TL_RUNTIME_STORE.BatchAttemptRecord
