<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup rules for Android 12+
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude EncryptedSharedPreferences to prevent InvalidProtocolBufferException on restore -->
        <exclude domain="sharedpref" path="online.taxcore.possecured.prefs.xml"/>
        <!-- Also exclude the Tink keyset preferences -->
        <exclude domain="sharedpref" path="__androidx_security_crypto_encrypted_prefs__.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- Exclude encrypted prefs from device-to-device transfer as well -->
        <exclude domain="sharedpref" path="online.taxcore.possecured.prefs.xml"/>
        <exclude domain="sharedpref" path="__androidx_security_crypto_encrypted_prefs__.xml"/>
    </device-transfer>
</data-extraction-rules>