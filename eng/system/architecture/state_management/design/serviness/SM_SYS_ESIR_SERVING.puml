@startuml
title SM_SYS_ESIR_SERVING — ESIR serving / availability state machine

hide empty description

<style>
stateDiagram {
  BackgroundColor transparent
  LineColor #2f2f2f
  FontName Monospace
  FontSize 13
  ArrowColor #2f2f2f
}
state {
  BackgroundColor #f9f9f9
  LineColor #2f2f2f
  RoundCorner 12
  Padding 8
}
state<<mode>> {
  BackgroundColor #eef6ff
}
state<<wait>> {
  BackgroundColor #fff8e8
}
state<<error>> {
  BackgroundColor #fff1f1
}
legend {
  FontName Monospace
  FontSize 12
}
</style>

legend right
MACHINE
  id: SM_SYS_ESIR_SERVING
  owner: C_ESIR
  scope: SYS
  purpose: Control whether ESIR should admit new fiscalization work.

NAMING
  states:    ST_ESIR_<STATE>
  events:    EV_ESIR_<EVENT>
  guards:    G_ESIR_<RULE>
  behaviors: B_ESIR_<ACTION>

EVENTS
  EV_ESIR_BOOTSTRAP_COMPLETED(status:StatusResponse)
  EV_ESIR_CONFIGURATION_INVALID(reason_code)
  EV_ESIR_STATUS_REFRESHED(status:StatusResponse)
  EV_ESIR_ONLINE_PATH_AVAILABLE()
  EV_ESIR_ONLINE_PATH_LOST(reason_code)
  EV_ESIR_LOCAL_PATH_AVAILABLE()
  EV_ESIR_LOCAL_PATH_LOST(reason_code)
  EV_ESIR_FATAL_RUNTIME_FAULT(code)

GUARDS
  G_ESIR_CONFIG_VALID() -> bool
  G_ESIR_STATUS_SERVICEABLE(status:StatusResponse) -> bool
  G_ESIR_ONLINE_PATH_USABLE() -> bool
  G_ESIR_ANY_FISCALIZATION_PATH_USABLE() -> bool
  G_ESIR_OFFLINE_CAPABLE() -> bool

BEHAVIORS
  B_ESIR_MARK_STARTING()
  B_ESIR_EVALUATE_STATUS(status:StatusResponse)
  B_ESIR_EVALUATE_PATH_AVAILABILITY()
  B_ESIR_BEGIN_ACCEPTING()
  B_ESIR_STOP_ACCEPTING()
  B_ESIR_PUBLISH_ACCEPTING()
  B_ESIR_PUBLISH_DEGRADED_OFFLINE_CAPABLE()
  B_ESIR_PUBLISH_BLOCKED()
  B_ESIR_NOTE_PATH_CHANGE(path_id, availability)
  B_ESIR_RECORD_CONFIGURATION_PROBLEM(reason_code)
  B_ESIR_RECORD_FATAL_FAULT(code)

RULES
  - serving state is not fiscalization workflow state
  - health is projected separately from serving state + runtime facts
  - behavior ids remain semantic and stable
  - dynamic diagrams are linked through dynamic_view_ref + group_ref
endlegend

' REALIZATION ANCHORS
' B_ESIR_MARK_STARTING()
'   -> S_SYS_BOOTSTRAP_AND_CONFIGURATION / GRP_BOOTSTRAP_READ_SHARED_TAXCORE_DATA
' B_ESIR_EVALUATE_STATUS(status)
'   -> S_SYS_STATUS_AND_OPERATOR_RECOVERY / GRP_STATUS_READ_CURRENT_STATUS
' B_ESIR_EVALUATE_PATH_AVAILABILITY()
'   -> S_SYS_STATUS_AND_OPERATOR_RECOVERY / GRP_STATUS_PROBE_ESDC_AVAILABILITY
'   -> S_SYS_STATUS_AND_OPERATOR_RECOVERY / GRP_STATUS_EVALUATE_RECOVERY_NEEDS
' B_ESIR_BEGIN_ACCEPTING()
'   -> S_SYS_BOOTSTRAP_AND_CONFIGURATION / GRP_BOOTSTRAP_PERSIST_READINESS_STATE
' B_ESIR_STOP_ACCEPTING()
'   -> S_SYS_STATUS_AND_OPERATOR_RECOVERY / GRP_STATUS_EVALUATE_RECOVERY_NEEDS
' B_ESIR_PUBLISH_ACCEPTING()
'   -> S_SYS_BOOTSTRAP_AND_CONFIGURATION / GRP_BOOTSTRAP_PERSIST_READINESS_STATE
' B_ESIR_PUBLISH_DEGRADED_OFFLINE_CAPABLE()
'   -> S_SYS_STATUS_AND_OPERATOR_RECOVERY / GRP_STATUS_HANDLE_TIME_OR_CERTIFICATE_DEGRADED
' B_ESIR_PUBLISH_BLOCKED()
'   -> S_SYS_STATUS_AND_OPERATOR_RECOVERY / GRP_STATUS_RECOVER_PIN_REQUIRED_STATE
' B_ESIR_NOTE_PATH_CHANGE(path_id, availability)
'   -> S_SYS_STATUS_AND_OPERATOR_RECOVERY / GRP_STATUS_PROBE_ESDC_AVAILABILITY
'   -> S_SYS_BACKEND_SYNC_AND_COMMAND_LIFECYCLE / GRP_BACKEND_SYNC_CLOSE_SYNC_OUTCOME
' B_ESIR_RECORD_CONFIGURATION_PROBLEM(reason_code)
'   -> S_SYS_BOOTSTRAP_AND_CONFIGURATION / GRP_BOOTSTRAP_APPLY_AND_ACKNOWLEDGE_COMMANDS
'   -> S_SYS_BOOTSTRAP_AND_CONFIGURATION / GRP_BOOTSTRAP_PERSIST_READINESS_STATE
' B_ESIR_RECORD_FATAL_FAULT(code)
'   -> S_SYS_STATUS_AND_OPERATOR_RECOVERY / GRP_STATUS_EVALUATE_RECOVERY_NEEDS

[*] --> ST_ESIR_STARTING

state "ST_ESIR_STARTING" as ST_ESIR_STARTING <<wait>>
ST_ESIR_STARTING : entry / B_ESIR_MARK_STARTING()
ST_ESIR_STARTING : do / B_ESIR_EVALUATE_PATH_AVAILABILITY()
ST_ESIR_STARTING : evaluating configuration and serving paths

state "ST_ESIR_ACCEPTING" as ST_ESIR_ACCEPTING <<mode>>
ST_ESIR_ACCEPTING : entry / B_ESIR_BEGIN_ACCEPTING()
ST_ESIR_ACCEPTING : do / B_ESIR_PUBLISH_ACCEPTING()
ST_ESIR_ACCEPTING : exit / B_ESIR_STOP_ACCEPTING()
ST_ESIR_ACCEPTING : admits new fiscalization work
ST_ESIR_ACCEPTING : at least one acceptable path is usable

state "ST_ESIR_DEGRADED_OFFLINE_CAPABLE" as ST_ESIR_DEGRADED_OFFLINE_CAPABLE <<error>>
ST_ESIR_DEGRADED_OFFLINE_CAPABLE : entry / B_ESIR_PUBLISH_DEGRADED_OFFLINE_CAPABLE()
ST_ESIR_DEGRADED_OFFLINE_CAPABLE : do / B_ESIR_EVALUATE_PATH_AVAILABILITY()
ST_ESIR_DEGRADED_OFFLINE_CAPABLE : admits work only through remaining usable paths

state "ST_ESIR_BLOCKED" as ST_ESIR_BLOCKED <<error>>
ST_ESIR_BLOCKED : entry / B_ESIR_PUBLISH_BLOCKED()
ST_ESIR_BLOCKED : do / B_ESIR_STOP_ACCEPTING()
ST_ESIR_BLOCKED : does not admit new fiscalization work

ST_ESIR_STARTING --> ST_ESIR_ACCEPTING : EV_ESIR_BOOTSTRAP_COMPLETED(status)\n[G_ESIR_CONFIG_VALID() && G_ESIR_ANY_FISCALIZATION_PATH_USABLE() && G_ESIR_STATUS_SERVICEABLE(status)]\n/ B_ESIR_EVALUATE_STATUS(status)

ST_ESIR_STARTING --> ST_ESIR_DEGRADED_OFFLINE_CAPABLE : EV_ESIR_BOOTSTRAP_COMPLETED(status)\n[G_ESIR_CONFIG_VALID() && G_ESIR_OFFLINE_CAPABLE() && !G_ESIR_ONLINE_PATH_USABLE()]\n/ B_ESIR_EVALUATE_STATUS(status)

ST_ESIR_STARTING --> ST_ESIR_BLOCKED : EV_ESIR_CONFIGURATION_INVALID(reason_code)\n/ B_ESIR_RECORD_CONFIGURATION_PROBLEM(reason_code)

ST_ESIR_STARTING --> ST_ESIR_BLOCKED : EV_ESIR_BOOTSTRAP_COMPLETED(status)\n[!G_ESIR_CONFIG_VALID() || !G_ESIR_ANY_FISCALIZATION_PATH_USABLE() || !G_ESIR_STATUS_SERVICEABLE(status)]\n/ B_ESIR_EVALUATE_STATUS(status)

ST_ESIR_ACCEPTING --> ST_ESIR_DEGRADED_OFFLINE_CAPABLE : EV_ESIR_ONLINE_PATH_LOST(reason_code)\n[G_ESIR_OFFLINE_CAPABLE()]\n/ B_ESIR_NOTE_PATH_CHANGE(online_path, unavailable)

ST_ESIR_ACCEPTING --> ST_ESIR_BLOCKED : EV_ESIR_LOCAL_PATH_LOST(reason_code)\n[!G_ESIR_ANY_FISCALIZATION_PATH_USABLE()]\n/ B_ESIR_NOTE_PATH_CHANGE(local_path, unavailable)

ST_ESIR_ACCEPTING --> ST_ESIR_BLOCKED : EV_ESIR_CONFIGURATION_INVALID(reason_code)\n/ B_ESIR_RECORD_CONFIGURATION_PROBLEM(reason_code)

ST_ESIR_ACCEPTING --> ST_ESIR_BLOCKED : EV_ESIR_FATAL_RUNTIME_FAULT(code)\n/ B_ESIR_RECORD_FATAL_FAULT(code)

ST_ESIR_DEGRADED_OFFLINE_CAPABLE --> ST_ESIR_ACCEPTING : EV_ESIR_ONLINE_PATH_AVAILABLE()\n[G_ESIR_CONFIG_VALID() && G_ESIR_ONLINE_PATH_USABLE()]\n/ B_ESIR_NOTE_PATH_CHANGE(online_path, available)

ST_ESIR_DEGRADED_OFFLINE_CAPABLE --> ST_ESIR_ACCEPTING : EV_ESIR_STATUS_REFRESHED(status)\n[G_ESIR_STATUS_SERVICEABLE(status) && G_ESIR_ONLINE_PATH_USABLE()]\n/ B_ESIR_EVALUATE_STATUS(status)

ST_ESIR_DEGRADED_OFFLINE_CAPABLE --> ST_ESIR_BLOCKED : EV_ESIR_LOCAL_PATH_LOST(reason_code)\n[!G_ESIR_ANY_FISCALIZATION_PATH_USABLE()]\n/ B_ESIR_NOTE_PATH_CHANGE(local_path, unavailable)

ST_ESIR_DEGRADED_OFFLINE_CAPABLE --> ST_ESIR_BLOCKED : EV_ESIR_CONFIGURATION_INVALID(reason_code)\n/ B_ESIR_RECORD_CONFIGURATION_PROBLEM(reason_code)

ST_ESIR_DEGRADED_OFFLINE_CAPABLE --> ST_ESIR_BLOCKED : EV_ESIR_FATAL_RUNTIME_FAULT(code)\n/ B_ESIR_RECORD_FATAL_FAULT(code)

ST_ESIR_BLOCKED --> ST_ESIR_DEGRADED_OFFLINE_CAPABLE : EV_ESIR_LOCAL_PATH_AVAILABLE()\n[G_ESIR_CONFIG_VALID() && G_ESIR_OFFLINE_CAPABLE() && !G_ESIR_ONLINE_PATH_USABLE()]\n/ B_ESIR_NOTE_PATH_CHANGE(local_path, available)

ST_ESIR_BLOCKED --> ST_ESIR_ACCEPTING : EV_ESIR_STATUS_REFRESHED(status)\n[G_ESIR_CONFIG_VALID() && G_ESIR_ANY_FISCALIZATION_PATH_USABLE() && G_ESIR_STATUS_SERVICEABLE(status)]\n/ B_ESIR_EVALUATE_STATUS(status)

@enduml
