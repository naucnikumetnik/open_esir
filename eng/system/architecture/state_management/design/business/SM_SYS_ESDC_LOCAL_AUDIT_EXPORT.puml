@startuml
title SM_SYS_ESDC_LOCAL_AUDIT_EXPORT — E-SDC local audit export lifecycle state machine

hide empty description

<style>
stateDiagram {
  BackgroundColor transparent
  LineColor #2f2f2f
  FontName Monospace
  FontSize 13
  ArrowColor #2f2f2f
}
state {
  BackgroundColor #f9f9f9
  LineColor #2f2f2f
  RoundCorner 12
  Padding 8
}
state<<mode>> {
  BackgroundColor #eef6ff
}
state<<wait>> {
  BackgroundColor #fff8e8
}
state<<error>> {
  BackgroundColor #fff1f1
}
state<<terminal>> {
  BackgroundColor #f1f1f1
  LineStyle 2
}
legend {
  FontName Monospace
  FontSize 12
}
</style>

legend right
MACHINE
  id: SM_SYS_ESDC_LOCAL_AUDIT_EXPORT
  owner: C_ESDC
  scope: SYS
  purpose: Control operator-triggered local audit export through removable media.

NAMING
  states:    ST_ESDC_LOCAL_AUDIT_EXPORT_<STATE>
  events:    EV_ESDC_LOCAL_AUDIT_EXPORT_<EVENT>
  guards:    G_ESDC_LOCAL_AUDIT_EXPORT_<RULE>
  behaviors: B_ESDC_LOCAL_AUDIT_EXPORT_<ACTION>

EVENTS
  EV_ESDC_LOCAL_AUDIT_EXPORT_MEDIA_INSERTED()
  EV_ESDC_LOCAL_AUDIT_EXPORT_COMMAND_FILE_DETECTED()
  EV_ESDC_LOCAL_AUDIT_EXPORT_COMMAND_IMPORT_COMPLETED()
  EV_ESDC_LOCAL_AUDIT_EXPORT_COMMAND_IMPORT_FAILED(error_code)
  EV_ESDC_LOCAL_AUDIT_EXPORT_COMMAND_RESULT_WRITE_SUCCEEDED()
  EV_ESDC_LOCAL_AUDIT_EXPORT_COMMAND_RESULT_WRITE_FAILED(error_code)
  EV_ESDC_LOCAL_AUDIT_EXPORT_EXPORT_SET_DETERMINED(export_batch_ref)
  EV_ESDC_LOCAL_AUDIT_EXPORT_ARTIFACTS_STAGED(export_batch_ref)
  EV_ESDC_LOCAL_AUDIT_EXPORT_MEDIA_WRITE_SUCCEEDED(export_batch_ref)
  EV_ESDC_LOCAL_AUDIT_EXPORT_MEDIA_WRITE_FAILED(error_code)
  EV_ESDC_LOCAL_AUDIT_EXPORT_OUTCOME_RECORDED(export_batch_ref)

GUARDS
  G_ESDC_LOCAL_AUDIT_EXPORT_COMMAND_FILE_PRESENT() -> bool
  G_ESDC_LOCAL_AUDIT_EXPORT_HAS_EXPORTABLE_AUDIT_PACKAGES() -> bool
  G_ESDC_LOCAL_AUDIT_EXPORT_EXPORT_SET_READY(export_batch_ref) -> bool
  G_ESDC_LOCAL_AUDIT_EXPORT_MEDIA_WRITEABLE() -> bool
  G_ESDC_LOCAL_AUDIT_EXPORT_RESULT_FILE_REQUIRED() -> bool
  G_ESDC_LOCAL_AUDIT_EXPORT_CAN_DEFER(reason_code) -> bool

BEHAVIORS
  B_ESDC_LOCAL_AUDIT_EXPORT_START_CYCLE()
  B_ESDC_LOCAL_AUDIT_EXPORT_DETECT_MEDIA()
  B_ESDC_LOCAL_AUDIT_EXPORT_IMPORT_COMMANDS_FROM_MEDIA()
  B_ESDC_LOCAL_AUDIT_EXPORT_RECORD_COMMAND_IMPORT_FAILURE(error_code)
  B_ESDC_LOCAL_AUDIT_EXPORT_DETERMINE_EXPORT_SET()
  B_ESDC_LOCAL_AUDIT_EXPORT_STAGE_ARTIFACTS(export_batch_ref)
  B_ESDC_LOCAL_AUDIT_EXPORT_WRITE_AUDIT_PACKAGES_TO_MEDIA(export_batch_ref)
  B_ESDC_LOCAL_AUDIT_EXPORT_WRITE_ARP_TO_MEDIA(export_batch_ref)
  B_ESDC_LOCAL_AUDIT_EXPORT_WRITE_COMMAND_RESULTS_TO_MEDIA()
  B_ESDC_LOCAL_AUDIT_EXPORT_RECORD_MEDIA_WRITE_FAILURE(error_code)
  B_ESDC_LOCAL_AUDIT_EXPORT_RECORD_OUTCOME(export_batch_ref)
  B_ESDC_LOCAL_AUDIT_EXPORT_DEFER_CYCLE(reason_code)
  B_ESDC_LOCAL_AUDIT_EXPORT_FINALIZE_SUCCESS()
  B_ESDC_LOCAL_AUDIT_EXPORT_FINALIZE_FAILURE(error_code)

RULES
  - this machine models removable-media local audit exchange only
  - command import from media takes precedence over audit export
  - audit package staging is separated from physical media write
  - export outcome recording is separated from command-result file generation
endlegend

' REALIZATION ANCHORS
' B_ESDC_LOCAL_AUDIT_EXPORT_START_CYCLE()
'   -> S_SYS_LOCAL_AUDIT_EXPORT / GRP_LOCAL_EXPORT_DETECT_MEDIA_TRIGGER
' B_ESDC_LOCAL_AUDIT_EXPORT_DETECT_MEDIA()
'   -> S_SYS_LOCAL_AUDIT_EXPORT / GRP_LOCAL_EXPORT_DETECT_MEDIA_TRIGGER
' B_ESDC_LOCAL_AUDIT_EXPORT_IMPORT_COMMANDS_FROM_MEDIA()
'   -> S_SYS_LOCAL_AUDIT_EXPORT / GRP_LOCAL_EXPORT_INSPECT_MEDIA_FOR_COMMAND_FILE
'   -> S_SYS_LOCAL_AUDIT_EXPORT / GRP_LOCAL_EXPORT_EXECUTE_MEDIA_COMMANDS
' B_ESDC_LOCAL_AUDIT_EXPORT_RECORD_COMMAND_IMPORT_FAILURE(error_code)
'   -> S_SYS_LOCAL_AUDIT_EXPORT / GRP_LOCAL_EXPORT_EXECUTE_MEDIA_COMMANDS
'   -> S_SYS_LOCAL_AUDIT_EXPORT / GRP_LOCAL_EXPORT_CLOSE_EXPORT_OUTCOME
' B_ESDC_LOCAL_AUDIT_EXPORT_DETERMINE_EXPORT_SET()
'   -> S_SYS_LOCAL_AUDIT_EXPORT / GRP_LOCAL_EXPORT_DETERMINE_EXPORT_SET
'   -> DV_SYS_OPEN_FISCAL_CORE_RUNTIME_STORE_COMMAND_RECOVERY_AND_EXPORT / AP_STAGE_LOCAL_AUDIT_EXPORT
' B_ESDC_LOCAL_AUDIT_EXPORT_STAGE_ARTIFACTS(export_batch_ref)
'   -> S_SYS_LOCAL_AUDIT_EXPORT / GRP_LOCAL_EXPORT_PREPARE_MEDIA_FOLDER_STRUCTURE
'   -> S_SYS_LOCAL_AUDIT_EXPORT / GRP_LOCAL_EXPORT_EXPORT_AUDIT_PACKAGES
'   -> DV_SYS_OPEN_FISCAL_CORE_RUNTIME_STORE_COMMAND_RECOVERY_AND_EXPORT / AP_STAGE_LOCAL_AUDIT_EXPORT
' B_ESDC_LOCAL_AUDIT_EXPORT_WRITE_AUDIT_PACKAGES_TO_MEDIA(export_batch_ref)
'   -> S_SYS_LOCAL_AUDIT_EXPORT / GRP_LOCAL_EXPORT_EXPORT_AUDIT_PACKAGES
' B_ESDC_LOCAL_AUDIT_EXPORT_WRITE_ARP_TO_MEDIA(export_batch_ref)
'   -> S_SYS_LOCAL_AUDIT_EXPORT / GRP_LOCAL_EXPORT_EXPORT_ARP_FILE
' B_ESDC_LOCAL_AUDIT_EXPORT_WRITE_COMMAND_RESULTS_TO_MEDIA()
'   -> S_SYS_LOCAL_AUDIT_EXPORT / GRP_LOCAL_EXPORT_EXECUTE_MEDIA_COMMANDS
' B_ESDC_LOCAL_AUDIT_EXPORT_RECORD_MEDIA_WRITE_FAILURE(error_code)
'   -> S_SYS_LOCAL_AUDIT_EXPORT / GRP_LOCAL_EXPORT_CLOSE_EXPORT_OUTCOME
' B_ESDC_LOCAL_AUDIT_EXPORT_RECORD_OUTCOME(export_batch_ref)
'   -> S_SYS_LOCAL_AUDIT_EXPORT / GRP_LOCAL_EXPORT_CLOSE_EXPORT_OUTCOME
'   -> DV_SYS_OPEN_FISCAL_CORE_RUNTIME_STORE_COMMAND_RECOVERY_AND_EXPORT / AP_RECORD_LOCAL_EXPORT_OUTCOME
' B_ESDC_LOCAL_AUDIT_EXPORT_DEFER_CYCLE(reason_code)
'   -> S_SYS_LOCAL_AUDIT_EXPORT / GRP_LOCAL_EXPORT_CLOSE_EXPORT_OUTCOME
' B_ESDC_LOCAL_AUDIT_EXPORT_FINALIZE_SUCCESS()
'   -> S_SYS_LOCAL_AUDIT_EXPORT / GRP_LOCAL_EXPORT_CLOSE_EXPORT_OUTCOME
' B_ESDC_LOCAL_AUDIT_EXPORT_FINALIZE_FAILURE(error_code)
'   -> S_SYS_LOCAL_AUDIT_EXPORT / GRP_LOCAL_EXPORT_CLOSE_EXPORT_OUTCOME

[*] --> ST_ESDC_LOCAL_AUDIT_EXPORT_IDLE

state "ST_ESDC_LOCAL_AUDIT_EXPORT_IDLE" as ST_ESDC_LOCAL_AUDIT_EXPORT_IDLE <<wait>>
ST_ESDC_LOCAL_AUDIT_EXPORT_IDLE : waiting for removable media insertion

state "ST_ESDC_LOCAL_AUDIT_EXPORT_MEDIA_DETECTED" as ST_ESDC_LOCAL_AUDIT_EXPORT_MEDIA_DETECTED <<mode>>
ST_ESDC_LOCAL_AUDIT_EXPORT_MEDIA_DETECTED : entry / B_ESDC_LOCAL_AUDIT_EXPORT_DETECT_MEDIA()
ST_ESDC_LOCAL_AUDIT_EXPORT_MEDIA_DETECTED : media detected and initial local-audit checks performed

state "ST_ESDC_LOCAL_AUDIT_EXPORT_IMPORTING_COMMANDS" as ST_ESDC_LOCAL_AUDIT_EXPORT_IMPORTING_COMMANDS <<mode>>
ST_ESDC_LOCAL_AUDIT_EXPORT_IMPORTING_COMMANDS : do / B_ESDC_LOCAL_AUDIT_EXPORT_IMPORT_COMMANDS_FROM_MEDIA()
ST_ESDC_LOCAL_AUDIT_EXPORT_IMPORTING_COMMANDS : importing and executing commands from media before export

state "ST_ESDC_LOCAL_AUDIT_EXPORT_DETERMINING_EXPORT_SET" as ST_ESDC_LOCAL_AUDIT_EXPORT_DETERMINING_EXPORT_SET <<mode>>
ST_ESDC_LOCAL_AUDIT_EXPORT_DETERMINING_EXPORT_SET : do / B_ESDC_LOCAL_AUDIT_EXPORT_DETERMINE_EXPORT_SET()
ST_ESDC_LOCAL_AUDIT_EXPORT_DETERMINING_EXPORT_SET : selecting audit packages and optional ARP for this batch

state "ST_ESDC_LOCAL_AUDIT_EXPORT_STAGING_ARTIFACTS" as ST_ESDC_LOCAL_AUDIT_EXPORT_STAGING_ARTIFACTS <<mode>>
ST_ESDC_LOCAL_AUDIT_EXPORT_STAGING_ARTIFACTS : do / B_ESDC_LOCAL_AUDIT_EXPORT_STAGE_ARTIFACTS(export_batch_ref)
ST_ESDC_LOCAL_AUDIT_EXPORT_STAGING_ARTIFACTS : preparing file set before physical media write

state "ST_ESDC_LOCAL_AUDIT_EXPORT_WRITING_MEDIA" as ST_ESDC_LOCAL_AUDIT_EXPORT_WRITING_MEDIA <<mode>>
ST_ESDC_LOCAL_AUDIT_EXPORT_WRITING_MEDIA : do / B_ESDC_LOCAL_AUDIT_EXPORT_WRITE_AUDIT_PACKAGES_TO_MEDIA(export_batch_ref)
ST_ESDC_LOCAL_AUDIT_EXPORT_WRITING_MEDIA : do / B_ESDC_LOCAL_AUDIT_EXPORT_WRITE_ARP_TO_MEDIA(export_batch_ref)
ST_ESDC_LOCAL_AUDIT_EXPORT_WRITING_MEDIA : writing audit artifacts to removable media

state "ST_ESDC_LOCAL_AUDIT_EXPORT_RECORDING_MEDIA_RESULTS" as ST_ESDC_LOCAL_AUDIT_EXPORT_RECORDING_MEDIA_RESULTS <<mode>>
ST_ESDC_LOCAL_AUDIT_EXPORT_RECORDING_MEDIA_RESULTS : recording command-result or export-outcome artifacts

state "ST_ESDC_LOCAL_AUDIT_EXPORT_SUCCEEDED" as ST_ESDC_LOCAL_AUDIT_EXPORT_SUCCEEDED <<terminal>>
ST_ESDC_LOCAL_AUDIT_EXPORT_SUCCEEDED : entry / B_ESDC_LOCAL_AUDIT_EXPORT_FINALIZE_SUCCESS()
ST_ESDC_LOCAL_AUDIT_EXPORT_SUCCEEDED : local audit export completed successfully

state "ST_ESDC_LOCAL_AUDIT_EXPORT_DEFERRED" as ST_ESDC_LOCAL_AUDIT_EXPORT_DEFERRED <<wait>>
ST_ESDC_LOCAL_AUDIT_EXPORT_DEFERRED : entry / B_ESDC_LOCAL_AUDIT_EXPORT_DEFER_CYCLE(reason_code)
ST_ESDC_LOCAL_AUDIT_EXPORT_DEFERRED : local audit export deferred for later retry or continuation

state "ST_ESDC_LOCAL_AUDIT_EXPORT_FAILED" as ST_ESDC_LOCAL_AUDIT_EXPORT_FAILED <<error>>
ST_ESDC_LOCAL_AUDIT_EXPORT_FAILED : entry / B_ESDC_LOCAL_AUDIT_EXPORT_FINALIZE_FAILURE(error_code)
ST_ESDC_LOCAL_AUDIT_EXPORT_FAILED : local audit export failed

ST_ESDC_LOCAL_AUDIT_EXPORT_IDLE --> ST_ESDC_LOCAL_AUDIT_EXPORT_MEDIA_DETECTED : EV_ESDC_LOCAL_AUDIT_EXPORT_MEDIA_INSERTED()\n/ B_ESDC_LOCAL_AUDIT_EXPORT_START_CYCLE()

ST_ESDC_LOCAL_AUDIT_EXPORT_MEDIA_DETECTED --> ST_ESDC_LOCAL_AUDIT_EXPORT_IMPORTING_COMMANDS : EV_ESDC_LOCAL_AUDIT_EXPORT_COMMAND_FILE_DETECTED()\n[G_ESDC_LOCAL_AUDIT_EXPORT_COMMAND_FILE_PRESENT()]\n/ B_ESDC_LOCAL_AUDIT_EXPORT_IMPORT_COMMANDS_FROM_MEDIA()

ST_ESDC_LOCAL_AUDIT_EXPORT_MEDIA_DETECTED --> ST_ESDC_LOCAL_AUDIT_EXPORT_DETERMINING_EXPORT_SET : EV_ESDC_LOCAL_AUDIT_EXPORT_MEDIA_INSERTED()\n[!G_ESDC_LOCAL_AUDIT_EXPORT_COMMAND_FILE_PRESENT() && G_ESDC_LOCAL_AUDIT_EXPORT_HAS_EXPORTABLE_AUDIT_PACKAGES()]\n/ B_ESDC_LOCAL_AUDIT_EXPORT_DETERMINE_EXPORT_SET()

ST_ESDC_LOCAL_AUDIT_EXPORT_MEDIA_DETECTED --> ST_ESDC_LOCAL_AUDIT_EXPORT_DEFERRED : EV_ESDC_LOCAL_AUDIT_EXPORT_MEDIA_INSERTED()\n[!G_ESDC_LOCAL_AUDIT_EXPORT_COMMAND_FILE_PRESENT() && !G_ESDC_LOCAL_AUDIT_EXPORT_HAS_EXPORTABLE_AUDIT_PACKAGES()]\n/ B_ESDC_LOCAL_AUDIT_EXPORT_DEFER_CYCLE(no_exportable_audit_packages)

ST_ESDC_LOCAL_AUDIT_EXPORT_IMPORTING_COMMANDS --> ST_ESDC_LOCAL_AUDIT_EXPORT_RECORDING_MEDIA_RESULTS : EV_ESDC_LOCAL_AUDIT_EXPORT_COMMAND_IMPORT_COMPLETED()\n[G_ESDC_LOCAL_AUDIT_EXPORT_RESULT_FILE_REQUIRED()]\n/ B_ESDC_LOCAL_AUDIT_EXPORT_WRITE_COMMAND_RESULTS_TO_MEDIA()

ST_ESDC_LOCAL_AUDIT_EXPORT_IMPORTING_COMMANDS --> ST_ESDC_LOCAL_AUDIT_EXPORT_DEFERRED : EV_ESDC_LOCAL_AUDIT_EXPORT_COMMAND_IMPORT_FAILED(error_code)\n[G_ESDC_LOCAL_AUDIT_EXPORT_CAN_DEFER(error_code)]\n/ B_ESDC_LOCAL_AUDIT_EXPORT_RECORD_COMMAND_IMPORT_FAILURE(error_code), B_ESDC_LOCAL_AUDIT_EXPORT_DEFER_CYCLE(error_code)

ST_ESDC_LOCAL_AUDIT_EXPORT_IMPORTING_COMMANDS --> ST_ESDC_LOCAL_AUDIT_EXPORT_FAILED : EV_ESDC_LOCAL_AUDIT_EXPORT_COMMAND_IMPORT_FAILED(error_code)\n[!G_ESDC_LOCAL_AUDIT_EXPORT_CAN_DEFER(error_code)]\n/ B_ESDC_LOCAL_AUDIT_EXPORT_RECORD_COMMAND_IMPORT_FAILURE(error_code)

ST_ESDC_LOCAL_AUDIT_EXPORT_RECORDING_MEDIA_RESULTS --> ST_ESDC_LOCAL_AUDIT_EXPORT_DETERMINING_EXPORT_SET : EV_ESDC_LOCAL_AUDIT_EXPORT_COMMAND_RESULT_WRITE_SUCCEEDED()\n/ B_ESDC_LOCAL_AUDIT_EXPORT_DETERMINE_EXPORT_SET()

ST_ESDC_LOCAL_AUDIT_EXPORT_RECORDING_MEDIA_RESULTS --> ST_ESDC_LOCAL_AUDIT_EXPORT_DEFERRED : EV_ESDC_LOCAL_AUDIT_EXPORT_COMMAND_RESULT_WRITE_FAILED(error_code)\n[G_ESDC_LOCAL_AUDIT_EXPORT_CAN_DEFER(error_code)]\n/ B_ESDC_LOCAL_AUDIT_EXPORT_DEFER_CYCLE(error_code)

ST_ESDC_LOCAL_AUDIT_EXPORT_RECORDING_MEDIA_RESULTS --> ST_ESDC_LOCAL_AUDIT_EXPORT_FAILED : EV_ESDC_LOCAL_AUDIT_EXPORT_COMMAND_RESULT_WRITE_FAILED(error_code)\n[!G_ESDC_LOCAL_AUDIT_EXPORT_CAN_DEFER(error_code)]\n/ B_ESDC_LOCAL_AUDIT_EXPORT_FINALIZE_FAILURE(error_code)

ST_ESDC_LOCAL_AUDIT_EXPORT_DETERMINING_EXPORT_SET --> ST_ESDC_LOCAL_AUDIT_EXPORT_STAGING_ARTIFACTS : EV_ESDC_LOCAL_AUDIT_EXPORT_EXPORT_SET_DETERMINED(export_batch_ref)\n[G_ESDC_LOCAL_AUDIT_EXPORT_EXPORT_SET_READY(export_batch_ref)]\n/ B_ESDC_LOCAL_AUDIT_EXPORT_STAGE_ARTIFACTS(export_batch_ref)

ST_ESDC_LOCAL_AUDIT_EXPORT_DETERMINING_EXPORT_SET --> ST_ESDC_LOCAL_AUDIT_EXPORT_DEFERRED : EV_ESDC_LOCAL_AUDIT_EXPORT_EXPORT_SET_DETERMINED(export_batch_ref)\n[!G_ESDC_LOCAL_AUDIT_EXPORT_EXPORT_SET_READY(export_batch_ref)]\n/ B_ESDC_LOCAL_AUDIT_EXPORT_DEFER_CYCLE(export_set_not_ready)

ST_ESDC_LOCAL_AUDIT_EXPORT_STAGING_ARTIFACTS --> ST_ESDC_LOCAL_AUDIT_EXPORT_WRITING_MEDIA : EV_ESDC_LOCAL_AUDIT_EXPORT_ARTIFACTS_STAGED(export_batch_ref)\n[G_ESDC_LOCAL_AUDIT_EXPORT_MEDIA_WRITEABLE()]\n/ B_ESDC_LOCAL_AUDIT_EXPORT_WRITE_AUDIT_PACKAGES_TO_MEDIA(export_batch_ref), B_ESDC_LOCAL_AUDIT_EXPORT_WRITE_ARP_TO_MEDIA(export_batch_ref)

ST_ESDC_LOCAL_AUDIT_EXPORT_STAGING_ARTIFACTS --> ST_ESDC_LOCAL_AUDIT_EXPORT_DEFERRED : EV_ESDC_LOCAL_AUDIT_EXPORT_ARTIFACTS_STAGED(export_batch_ref)\n[!G_ESDC_LOCAL_AUDIT_EXPORT_MEDIA_WRITEABLE() && G_ESDC_LOCAL_AUDIT_EXPORT_CAN_DEFER(media_not_writeable)]\n/ B_ESDC_LOCAL_AUDIT_EXPORT_DEFER_CYCLE(media_not_writeable)

ST_ESDC_LOCAL_AUDIT_EXPORT_STAGING_ARTIFACTS --> ST_ESDC_LOCAL_AUDIT_EXPORT_FAILED : EV_ESDC_LOCAL_AUDIT_EXPORT_ARTIFACTS_STAGED(export_batch_ref)\n[!G_ESDC_LOCAL_AUDIT_EXPORT_MEDIA_WRITEABLE() && !G_ESDC_LOCAL_AUDIT_EXPORT_CAN_DEFER(media_not_writeable)]\n/ B_ESDC_LOCAL_AUDIT_EXPORT_FINALIZE_FAILURE(media_not_writeable)

ST_ESDC_LOCAL_AUDIT_EXPORT_WRITING_MEDIA --> ST_ESDC_LOCAL_AUDIT_EXPORT_RECORDING_MEDIA_RESULTS : EV_ESDC_LOCAL_AUDIT_EXPORT_MEDIA_WRITE_SUCCEEDED(export_batch_ref)\n/ B_ESDC_LOCAL_AUDIT_EXPORT_RECORD_OUTCOME(export_batch_ref)

ST_ESDC_LOCAL_AUDIT_EXPORT_WRITING_MEDIA --> ST_ESDC_LOCAL_AUDIT_EXPORT_DEFERRED : EV_ESDC_LOCAL_AUDIT_EXPORT_MEDIA_WRITE_FAILED(error_code)\n[G_ESDC_LOCAL_AUDIT_EXPORT_CAN_DEFER(error_code)]\n/ B_ESDC_LOCAL_AUDIT_EXPORT_RECORD_MEDIA_WRITE_FAILURE(error_code), B_ESDC_LOCAL_AUDIT_EXPORT_DEFER_CYCLE(error_code)

ST_ESDC_LOCAL_AUDIT_EXPORT_WRITING_MEDIA --> ST_ESDC_LOCAL_AUDIT_EXPORT_FAILED : EV_ESDC_LOCAL_AUDIT_EXPORT_MEDIA_WRITE_FAILED(error_code)\n[!G_ESDC_LOCAL_AUDIT_EXPORT_CAN_DEFER(error_code)]\n/ B_ESDC_LOCAL_AUDIT_EXPORT_RECORD_MEDIA_WRITE_FAILURE(error_code)

ST_ESDC_LOCAL_AUDIT_EXPORT_RECORDING_MEDIA_RESULTS --> ST_ESDC_LOCAL_AUDIT_EXPORT_SUCCEEDED : EV_ESDC_LOCAL_AUDIT_EXPORT_OUTCOME_RECORDED(export_batch_ref)\n/ B_ESDC_LOCAL_AUDIT_EXPORT_RECORD_OUTCOME(export_batch_ref)

ST_ESDC_LOCAL_AUDIT_EXPORT_SUCCEEDED --> [*]
ST_ESDC_LOCAL_AUDIT_EXPORT_DEFERRED --> [*]
ST_ESDC_LOCAL_AUDIT_EXPORT_FAILED --> [*]

@enduml
