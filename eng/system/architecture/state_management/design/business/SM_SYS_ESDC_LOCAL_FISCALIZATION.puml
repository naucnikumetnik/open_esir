@startuml
title SM_SYS_ESDC_LOCAL_FISCALIZATION — E-SDC local fiscalization business state machine

hide empty description

<style>
stateDiagram {
  BackgroundColor transparent
  LineColor #2f2f2f
  FontName Monospace
  FontSize 13
  ArrowColor #2f2f2f
}
state {
  BackgroundColor #f9f9f9
  LineColor #2f2f2f
  RoundCorner 12
  Padding 8
}
state<<mode>> {
  BackgroundColor #eef6ff
}
state<<wait>> {
  BackgroundColor #fff8e8
}
state<<error>> {
  BackgroundColor #fff1f1
}
state<<terminal>> {
  BackgroundColor #f1f1f1
  LineStyle 2
}
legend {
  FontName Monospace
  FontSize 12
}
</style>

legend right
MACHINE
  id: SM_SYS_ESDC_LOCAL_FISCALIZATION
  owner: C_ESDC
  scope: SYS
  purpose: Control one local E-SDC fiscalization request from intake through signing, local evidence persistence, and returned result.

NAMING
  states:    ST_ESDC_LOCAL_FISCALIZATION_<STATE>
  events:    EV_ESDC_LOCAL_FISCALIZATION_<EVENT>
  guards:    G_ESDC_LOCAL_FISCALIZATION_<RULE>
  behaviors: B_ESDC_LOCAL_FISCALIZATION_<ACTION>

EVENTS
  EV_ESDC_LOCAL_FISCALIZATION_REQUEST_RECEIVED(request:InvoiceRequest)
  EV_ESDC_LOCAL_FISCALIZATION_SIGN_INPUT_PREPARED(sign_request:SignInvoiceApduRequest)
  EV_ESDC_LOCAL_FISCALIZATION_SIGNING_SUCCEEDED(sign_response:SignInvoiceApduResponse,result:InvoiceResult)
  EV_ESDC_LOCAL_FISCALIZATION_SIGNING_FAILED(error_code)
  EV_ESDC_LOCAL_FISCALIZATION_LOCAL_EVIDENCE_PERSISTED(result:InvoiceResult)
  EV_ESDC_LOCAL_FISCALIZATION_LOCAL_EVIDENCE_PERSIST_FAILED(error_code)

GUARDS
  G_ESDC_LOCAL_FISCALIZATION_REQUEST_ACCEPTABLE(request:InvoiceRequest) -> bool
  G_ESDC_LOCAL_FISCALIZATION_SIGN_INPUT_READY(sign_request:SignInvoiceApduRequest) -> bool
  G_ESDC_LOCAL_FISCALIZATION_SIGNING_SUCCEEDED(sign_response:SignInvoiceApduResponse) -> bool
  G_ESDC_LOCAL_FISCALIZATION_LOCAL_EVIDENCE_REQUIRED() -> bool
  G_ESDC_LOCAL_FISCALIZATION_RESULT_SUCCESS(result:InvoiceResult) -> bool

BEHAVIORS
  B_ESDC_LOCAL_FISCALIZATION_ACCEPT_REQUEST(request:InvoiceRequest)
  B_ESDC_LOCAL_FISCALIZATION_PREPARE_SIGN_INPUT(request:InvoiceRequest)
  B_ESDC_LOCAL_FISCALIZATION_INVOKE_SIGNING(sign_request:SignInvoiceApduRequest)
  B_ESDC_LOCAL_FISCALIZATION_BUILD_RESULT(sign_response:SignInvoiceApduResponse)
  B_ESDC_LOCAL_FISCALIZATION_CAPTURE_SIGNING_FAILURE(error_code)
  B_ESDC_LOCAL_FISCALIZATION_PERSIST_LOCAL_EVIDENCE(result:InvoiceResult)
  B_ESDC_LOCAL_FISCALIZATION_CAPTURE_PERSISTENCE_FAILURE(error_code)
  B_ESDC_LOCAL_FISCALIZATION_RETURN_RESULT(result:InvoiceResult)
  B_ESDC_LOCAL_FISCALIZATION_FINALIZE_SUCCESS(result:InvoiceResult)
  B_ESDC_LOCAL_FISCALIZATION_FINALIZE_FAILURE(error)

RULES
  - this machine models only local E-SDC invoice execution
  - serving/recovery, backend sync, audit/proof follow-up, and export stay outside this machine
  - local evidence persistence is part of the success path, not a best-effort side effect
  - dynamic diagrams are linked through dynamic_view_ref + group_ref
endlegend

' REALIZATION ANCHORS
' B_ESDC_LOCAL_FISCALIZATION_ACCEPT_REQUEST(request)
'   -> S_SYS_FISCALIZE_INVOICE / GRP_FISCALIZE_ROUTE_LOCAL
' B_ESDC_LOCAL_FISCALIZATION_PREPARE_SIGN_INPUT(request)
'   -> S_SYS_FISCALIZE_INVOICE / GRP_FISCALIZE_ROUTE_LOCAL
' B_ESDC_LOCAL_FISCALIZATION_INVOKE_SIGNING(sign_request)
'   -> S_SYS_FISCALIZE_INVOICE / GRP_FISCALIZE_ROUTE_LOCAL
' B_ESDC_LOCAL_FISCALIZATION_BUILD_RESULT(sign_response)
'   -> S_SYS_FISCALIZE_INVOICE / GRP_FISCALIZE_ROUTE_LOCAL
' B_ESDC_LOCAL_FISCALIZATION_CAPTURE_SIGNING_FAILURE(error_code)
'   -> S_SYS_FISCALIZE_INVOICE / GRP_FISCALIZE_ROUTE_LOCAL
' B_ESDC_LOCAL_FISCALIZATION_PERSIST_LOCAL_EVIDENCE(result)
'   -> S_SYS_FISCALIZE_INVOICE / GRP_FISCALIZE_ROUTE_LOCAL
'   -> DV_SYS_OPEN_FISCAL_CORE_RUNTIME_STORE_AUDIT_AND_PROOF / AP_PERSIST_LOCAL_FISCAL_EVIDENCE
' B_ESDC_LOCAL_FISCALIZATION_CAPTURE_PERSISTENCE_FAILURE(error_code)
'   -> S_SYS_FISCALIZE_INVOICE / GRP_FISCALIZE_ROUTE_LOCAL
'   -> DV_SYS_OPEN_FISCAL_CORE_RUNTIME_STORE_AUDIT_AND_PROOF / AP_PERSIST_LOCAL_FISCAL_EVIDENCE
' B_ESDC_LOCAL_FISCALIZATION_RETURN_RESULT(result)
'   -> S_SYS_FISCALIZE_INVOICE / GRP_FISCALIZE_RETURN_RESULT
' B_ESDC_LOCAL_FISCALIZATION_FINALIZE_SUCCESS(result)
'   -> S_SYS_FISCALIZE_INVOICE / GRP_FISCALIZE_RETURN_RESULT
' B_ESDC_LOCAL_FISCALIZATION_FINALIZE_FAILURE(error)
'   -> S_SYS_FISCALIZE_INVOICE / GRP_FISCALIZE_RETURN_RESULT

[*] --> ST_ESDC_LOCAL_FISCALIZATION_REQUEST_RECEIVED

state "ST_ESDC_LOCAL_FISCALIZATION_REQUEST_RECEIVED" as ST_ESDC_LOCAL_FISCALIZATION_REQUEST_RECEIVED <<wait>>
ST_ESDC_LOCAL_FISCALIZATION_REQUEST_RECEIVED : entry / B_ESDC_LOCAL_FISCALIZATION_ACCEPT_REQUEST(request)
ST_ESDC_LOCAL_FISCALIZATION_REQUEST_RECEIVED : local create-invoice request accepted

state "ST_ESDC_LOCAL_FISCALIZATION_PREPARING_SIGN_INPUT" as ST_ESDC_LOCAL_FISCALIZATION_PREPARING_SIGN_INPUT <<mode>>
ST_ESDC_LOCAL_FISCALIZATION_PREPARING_SIGN_INPUT : entry / B_ESDC_LOCAL_FISCALIZATION_PREPARE_SIGN_INPUT(request)
ST_ESDC_LOCAL_FISCALIZATION_PREPARING_SIGN_INPUT : preparing secure-element signing input

state "ST_ESDC_LOCAL_FISCALIZATION_SIGNING" as ST_ESDC_LOCAL_FISCALIZATION_SIGNING <<mode>>
ST_ESDC_LOCAL_FISCALIZATION_SIGNING : do / B_ESDC_LOCAL_FISCALIZATION_INVOKE_SIGNING(sign_request)
ST_ESDC_LOCAL_FISCALIZATION_SIGNING : secure-element signing in progress

state "ST_ESDC_LOCAL_FISCALIZATION_PERSISTING_LOCAL_EVIDENCE" as ST_ESDC_LOCAL_FISCALIZATION_PERSISTING_LOCAL_EVIDENCE <<mode>>
ST_ESDC_LOCAL_FISCALIZATION_PERSISTING_LOCAL_EVIDENCE : do / B_ESDC_LOCAL_FISCALIZATION_PERSIST_LOCAL_EVIDENCE(result)
ST_ESDC_LOCAL_FISCALIZATION_PERSISTING_LOCAL_EVIDENCE : persisting local journal and audit evidence

state "ST_ESDC_LOCAL_FISCALIZATION_SUCCEEDED" as ST_ESDC_LOCAL_FISCALIZATION_SUCCEEDED <<terminal>>
ST_ESDC_LOCAL_FISCALIZATION_SUCCEEDED : entry / B_ESDC_LOCAL_FISCALIZATION_FINALIZE_SUCCESS(result)
ST_ESDC_LOCAL_FISCALIZATION_SUCCEEDED : successful local fiscalization result returned

state "ST_ESDC_LOCAL_FISCALIZATION_FAILED" as ST_ESDC_LOCAL_FISCALIZATION_FAILED <<error>>
ST_ESDC_LOCAL_FISCALIZATION_FAILED : entry / B_ESDC_LOCAL_FISCALIZATION_FINALIZE_FAILURE(error)
ST_ESDC_LOCAL_FISCALIZATION_FAILED : local fiscalization failed

ST_ESDC_LOCAL_FISCALIZATION_REQUEST_RECEIVED --> ST_ESDC_LOCAL_FISCALIZATION_PREPARING_SIGN_INPUT : EV_ESDC_LOCAL_FISCALIZATION_REQUEST_RECEIVED(request)\n[G_ESDC_LOCAL_FISCALIZATION_REQUEST_ACCEPTABLE(request)]\n/ B_ESDC_LOCAL_FISCALIZATION_ACCEPT_REQUEST(request)

ST_ESDC_LOCAL_FISCALIZATION_REQUEST_RECEIVED --> ST_ESDC_LOCAL_FISCALIZATION_FAILED : EV_ESDC_LOCAL_FISCALIZATION_REQUEST_RECEIVED(request)\n[!G_ESDC_LOCAL_FISCALIZATION_REQUEST_ACCEPTABLE(request)]\n/ B_ESDC_LOCAL_FISCALIZATION_FINALIZE_FAILURE(request_rejected)

ST_ESDC_LOCAL_FISCALIZATION_PREPARING_SIGN_INPUT --> ST_ESDC_LOCAL_FISCALIZATION_SIGNING : EV_ESDC_LOCAL_FISCALIZATION_SIGN_INPUT_PREPARED(sign_request)\n[G_ESDC_LOCAL_FISCALIZATION_SIGN_INPUT_READY(sign_request)]\n/ B_ESDC_LOCAL_FISCALIZATION_PREPARE_SIGN_INPUT(request)

ST_ESDC_LOCAL_FISCALIZATION_PREPARING_SIGN_INPUT --> ST_ESDC_LOCAL_FISCALIZATION_FAILED : EV_ESDC_LOCAL_FISCALIZATION_SIGN_INPUT_PREPARED(sign_request)\n[!G_ESDC_LOCAL_FISCALIZATION_SIGN_INPUT_READY(sign_request)]\n/ B_ESDC_LOCAL_FISCALIZATION_FINALIZE_FAILURE(sign_input_invalid)

ST_ESDC_LOCAL_FISCALIZATION_SIGNING --> ST_ESDC_LOCAL_FISCALIZATION_PERSISTING_LOCAL_EVIDENCE : EV_ESDC_LOCAL_FISCALIZATION_SIGNING_SUCCEEDED(sign_response,result)\n[G_ESDC_LOCAL_FISCALIZATION_SIGNING_SUCCEEDED(sign_response) && G_ESDC_LOCAL_FISCALIZATION_LOCAL_EVIDENCE_REQUIRED()]\n/ B_ESDC_LOCAL_FISCALIZATION_BUILD_RESULT(sign_response)

ST_ESDC_LOCAL_FISCALIZATION_SIGNING --> ST_ESDC_LOCAL_FISCALIZATION_FAILED : EV_ESDC_LOCAL_FISCALIZATION_SIGNING_FAILED(error_code)\n/ B_ESDC_LOCAL_FISCALIZATION_CAPTURE_SIGNING_FAILURE(error_code)

ST_ESDC_LOCAL_FISCALIZATION_PERSISTING_LOCAL_EVIDENCE --> ST_ESDC_LOCAL_FISCALIZATION_SUCCEEDED : EV_ESDC_LOCAL_FISCALIZATION_LOCAL_EVIDENCE_PERSISTED(result)\n[G_ESDC_LOCAL_FISCALIZATION_RESULT_SUCCESS(result)]\n/ B_ESDC_LOCAL_FISCALIZATION_RETURN_RESULT(result)

ST_ESDC_LOCAL_FISCALIZATION_PERSISTING_LOCAL_EVIDENCE --> ST_ESDC_LOCAL_FISCALIZATION_FAILED : EV_ESDC_LOCAL_FISCALIZATION_LOCAL_EVIDENCE_PERSIST_FAILED(error_code)\n/ B_ESDC_LOCAL_FISCALIZATION_CAPTURE_PERSISTENCE_FAILURE(error_code)

ST_ESDC_LOCAL_FISCALIZATION_SUCCEEDED --> [*]
ST_ESDC_LOCAL_FISCALIZATION_FAILED --> [*]

@enduml
