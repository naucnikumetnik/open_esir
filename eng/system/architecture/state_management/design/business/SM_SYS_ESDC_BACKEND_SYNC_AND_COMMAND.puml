@startuml
title SM_SYS_ESDC_BACKEND_SYNC_AND_COMMAND — E-SDC backend sync and command lifecycle state machine

hide empty description

<style>
stateDiagram {
  BackgroundColor transparent
  LineColor #2f2f2f
  FontName Monospace
  FontSize 13
  ArrowColor #2f2f2f
}
state {
  BackgroundColor #f9f9f9
  LineColor #2f2f2f
  RoundCorner 12
  Padding 8
}
state<<mode>> {
  BackgroundColor #eef6ff
}
state<<wait>> {
