legend right
MACHINE
  id: SM_SYS_ESDC_BACKEND_SYNC_AND_COMMAND
  owner: C_ESDC
  scope: SYS
  purpose: Control one backend sync cycle including auth, status announce, command intake, command execution, and command outcome reporting.

NAMING
  states:    ST_ESDC_BACKEND_SYNC_<STATE>
  events:    EV_ESDC_BACKEND_SYNC_<EVENT>
  guards:    G_ESDC_BACKEND_SYNC_<RULE>
  behaviors: B_ESDC_BACKEND_SYNC_<ACTION>

EVENTS
  EV_ESDC_BACKEND_SYNC_CYCLE_TRIGGERED()
  EV_ESDC_BACKEND_SYNC_AUTH_CONTEXT_AVAILABLE(auth:AuthenticationTokenResponse)
  EV_ESDC_BACKEND_SYNC_AUTH_CONTEXT_REFRESH_REQUIRED()
  EV_ESDC_BACKEND_SYNC_AUTH_CONTEXT_OBTAINED(auth:AuthenticationTokenResponse)
  EV_ESDC_BACKEND_SYNC_AUTH_CONTEXT_FAILED(error_code)
  EV_ESDC_BACKEND_SYNC_STATUS_ANNOUNCED(commands:CommandList)
  EV_ESDC_BACKEND_SYNC_INITIALIZATION_COMMANDS_RECEIVED(commands:CommandList)
  EV_ESDC_BACKEND_SYNC_NO_COMMANDS_RECEIVED()
  EV_ESDC_BACKEND_SYNC_COMMANDS_CAPTURED(commands:CommandList)
  EV_ESDC_BACKEND_SYNC_COMMAND_EXECUTION_SUCCEEDED(command:Command)
  EV_ESDC_BACKEND_SYNC_COMMAND_EXECUTION_FAILED(command:Command,error_code)
  EV_ESDC_BACKEND_SYNC_COMMAND_OUTCOME_REPORTED(command:Command)
  EV_ESDC_BACKEND_SYNC_COMMAND_OUTCOME_REPORT_FAILED(command:Command,error_code)
  EV_ESDC_BACKEND_SYNC_CYCLE_COMPLETED()

GUARDS
  G_ESDC_BACKEND_SYNC_AUTH_CONTEXT_USABLE(auth:AuthenticationTokenResponse) -> bool
  G_ESDC_BACKEND_SYNC_HAS_COMMANDS(commands:CommandList) -> bool
  G_ESDC_BACKEND_SYNC_COMMAND_REPORTABLE(command:Command) -> bool
  G_ESDC_BACKEND_SYNC_CAN_DEFER(reason_code) -> bool

BEHAVIORS
  B_ESDC_BACKEND_SYNC_START_CYCLE()
  B_ESDC_BACKEND_SYNC_LOAD_AUTH_CONTEXT()
  B_ESDC_BACKEND_SYNC_REQUEST_AUTH_CONTEXT()
  B_ESDC_BACKEND_SYNC_CACHE_AUTH_CONTEXT(auth:AuthenticationTokenResponse)
  B_ESDC_BACKEND_SYNC_ANNOUNCE_STATUS()
  B_ESDC_BACKEND_SYNC_REQUEST_INITIALIZATION_COMMANDS()
  B_ESDC_BACKEND_SYNC_CAPTURE_COMMANDS(commands:CommandList)
  B_ESDC_BACKEND_SYNC_SELECT_NEXT_COMMAND()
  B_ESDC_BACKEND_SYNC_EXECUTE_COMMAND(command:Command)
  B_ESDC_BACKEND_SYNC_RECORD_COMMAND_EXECUTION_SUCCESS(command:Command)
  B_ESDC_BACKEND_SYNC_RECORD_COMMAND_EXECUTION_FAILURE(command:Command,error_code)
  B_ESDC_BACKEND_SYNC_REPORT_COMMAND_OUTCOME(command:Command,success_flag:TaxCoreBooleanFlagBody)
  B_ESDC_BACKEND_SYNC_RECORD_REPORT_FAILURE(command:Command,error_code)
  B_ESDC_BACKEND_SYNC_DEFER_CYCLE(reason_code)
  B_ESDC_BACKEND_SYNC_FINALIZE_SUCCESS()
  B_ESDC_BACKEND_SYNC_FINALIZE_FAILURE(error_code)

RULES
  - this machine models backend sync and command lifecycle only
  - audit package submission and proof lifecycle stay outside this machine as primary flows
  - command outcome reporting uses boolean success or failure body, not Command payload
  - dynamic diagrams are linked through dynamic_view_ref + group_ref
endlegend

' REALIZATION ANCHORS
' B_ESDC_BACKEND_SYNC_START_CYCLE()
'   -> S_SYS_BACKEND_SYNC_AND_COMMAND_LIFECYCLE / GRP_BACKEND_SYNC_ENSURE_AUTHENTICATION_CAPABILITY
' B_ESDC_BACKEND_SYNC_LOAD_AUTH_CONTEXT()
'   -> S_SYS_BACKEND_SYNC_AND_COMMAND_LIFECYCLE / GRP_BACKEND_SYNC_ENSURE_AUTHENTICATION_CAPABILITY
'   -> DV_SYS_OPEN_FISCAL_CORE_RUNTIME_STORE_COMMAND_RECOVERY_AND_EXPORT / AP_CACHE_BACKEND_AUTH_CONTEXT
' B_ESDC_BACKEND_SYNC_REQUEST_AUTH_CONTEXT()
'   -> S_SYS_BACKEND_SYNC_AND_COMMAND_LIFECYCLE / GRP_BACKEND_SYNC_ENSURE_AUTHENTICATION_CAPABILITY
' B_ESDC_BACKEND_SYNC_CACHE_AUTH_CONTEXT(auth)
'   -> S_SYS_BACKEND_SYNC_AND_COMMAND_LIFECYCLE / GRP_BACKEND_SYNC_ENSURE_AUTHENTICATION_CAPABILITY
'   -> DV_SYS_OPEN_FISCAL_CORE_RUNTIME_STORE_COMMAND_RECOVERY_AND_EXPORT / AP_CACHE_BACKEND_AUTH_CONTEXT
' B_ESDC_BACKEND_SYNC_ANNOUNCE_STATUS()
'   -> S_SYS_BACKEND_SYNC_AND_COMMAND_LIFECYCLE / GRP_BACKEND_SYNC_ANNOUNCE_ONLINE_STATUS
' B_ESDC_BACKEND_SYNC_REQUEST_INITIALIZATION_COMMANDS()
'   -> S_SYS_BACKEND_SYNC_AND_COMMAND_LIFECYCLE / GRP_BACKEND_SYNC_PULL_INITIALIZATION_COMMANDS
' B_ESDC_BACKEND_SYNC_CAPTURE_COMMANDS(commands)
'   -> S_SYS_BACKEND_SYNC_AND_COMMAND_LIFECYCLE / GRP_BACKEND_SYNC_PROCESS_STATUS_COMMANDS
'   -> DV_SYS_OPEN_FISCAL_CORE_RUNTIME_STORE_COMMAND_RECOVERY_AND_EXPORT / AP_CAPTURE_BACKEND_COMMANDS
' B_ESDC_BACKEND_SYNC_SELECT_NEXT_COMMAND()
'   -> S_SYS_BACKEND_SYNC_AND_COMMAND_LIFECYCLE / GRP_BACKEND_SYNC_PROCESS_STATUS_COMMANDS
'   -> S_SYS_BACKEND_SYNC_AND_COMMAND_LIFECYCLE / GRP_BACKEND_SYNC_PULL_INITIALIZATION_COMMANDS
' B_ESDC_BACKEND_SYNC_EXECUTE_COMMAND(command)
'   -> S_SYS_BACKEND_SYNC_AND_COMMAND_LIFECYCLE / GRP_BACKEND_SYNC_PROCESS_STATUS_COMMANDS
' B_ESDC_BACKEND_SYNC_RECORD_COMMAND_EXECUTION_SUCCESS(command)
'   -> S_SYS_BACKEND_SYNC_AND_COMMAND_LIFECYCLE / GRP_BACKEND_SYNC_PROCESS_STATUS_COMMANDS
'   -> S_SYS_BACKEND_SYNC_AND_COMMAND_LIFECYCLE / GRP_BACKEND_SYNC_PULL_INITIALIZATION_COMMANDS
' B_ESDC_BACKEND_SYNC_RECORD_COMMAND_EXECUTION_FAILURE(command,error_code)
'   -> S_SYS_BACKEND_SYNC_AND_COMMAND_LIFECYCLE / GRP_BACKEND_SYNC_PROCESS_STATUS_COMMANDS
'   -> S_SYS_BACKEND_SYNC_AND_COMMAND_LIFECYCLE / GRP_BACKEND_SYNC_PULL_INITIALIZATION_COMMANDS
' B_ESDC_BACKEND_SYNC_REPORT_COMMAND_OUTCOME(command,success_flag)
'   -> S_SYS_BACKEND_SYNC_AND_COMMAND_LIFECYCLE / GRP_BACKEND_SYNC_PROCESS_STATUS_COMMANDS
' B_ESDC_BACKEND_SYNC_RECORD_REPORT_FAILURE(command,error_code)
'   -> S_SYS_BACKEND_SYNC_AND_COMMAND_LIFECYCLE / GRP_BACKEND_SYNC_PROCESS_STATUS_COMMANDS
'   -> S_SYS_BACKEND_SYNC_AND_COMMAND_LIFECYCLE / GRP_BACKEND_SYNC_CLOSE_SYNC_OUTCOME
' B_ESDC_BACKEND_SYNC_FINALIZE_SUCCESS()
'   -> S_SYS_BACKEND_SYNC_AND_COMMAND_LIFECYCLE / GRP_BACKEND_SYNC_CLOSE_SYNC_OUTCOME
' B_ESDC_BACKEND_SYNC_DEFER_CYCLE(reason_code)
'   -> S_SYS_BACKEND_SYNC_AND_COMMAND_LIFECYCLE / GRP_BACKEND_SYNC_CLOSE_SYNC_OUTCOME
' B_ESDC_BACKEND_SYNC_FINALIZE_FAILURE(error_code)
'   -> S_SYS_BACKEND_SYNC_AND_COMMAND_LIFECYCLE / GRP_BACKEND_SYNC_CLOSE_SYNC_OUTCOME

[*] --> ST_ESDC_BACKEND_SYNC_IDLE

state "ST_ESDC_BACKEND_SYNC_IDLE" as ST_ESDC_BACKEND_SYNC_IDLE <<wait>>
ST_ESDC_BACKEND_SYNC_IDLE : waiting for next backend sync cycle

state "ST_ESDC_BACKEND_SYNC_ENSURING_AUTH_CONTEXT" as ST_ESDC_BACKEND_SYNC_ENSURING_AUTH_CONTEXT <<mode>>
ST_ESDC_BACKEND_SYNC_ENSURING_AUTH_CONTEXT : entry / B_ESDC_BACKEND_SYNC_LOAD_AUTH_CONTEXT()
ST_ESDC_BACKEND_SYNC_ENSURING_AUTH_CONTEXT : ensuring usable backend authentication context

state "ST_ESDC_BACKEND_SYNC_ANNOUNCING_STATUS" as ST_ESDC_BACKEND_SYNC_ANNOUNCING_STATUS <<mode>>
ST_ESDC_BACKEND_SYNC_ANNOUNCING_STATUS : do / B_ESDC_BACKEND_SYNC_ANNOUNCE_STATUS()
ST_ESDC_BACKEND_SYNC_ANNOUNCING_STATUS : announcing online or offline posture to backend

state "ST_ESDC_BACKEND_SYNC_PULLING_INITIALIZATION_COMMANDS" as ST_ESDC_BACKEND_SYNC_PULLING_INITIALIZATION_COMMANDS <<mode>>
ST_ESDC_BACKEND_SYNC_PULLING_INITIALIZATION_COMMANDS : do / B_ESDC_BACKEND_SYNC_REQUEST_INITIALIZATION_COMMANDS()
ST_ESDC_BACKEND_SYNC_PULLING_INITIALIZATION_COMMANDS : explicitly refreshing backend initialization commands

state "ST_ESDC_BACKEND_SYNC_CAPTURING_COMMANDS" as ST_ESDC_BACKEND_SYNC_CAPTURING_COMMANDS <<mode>>
ST_ESDC_BACKEND_SYNC_CAPTURING_COMMANDS : do / B_ESDC_BACKEND_SYNC_CAPTURE_COMMANDS(commands)
ST_ESDC_BACKEND_SYNC_CAPTURING_COMMANDS : persisting received backend commands

state "ST_ESDC_BACKEND_SYNC_EXECUTING_COMMANDS" as ST_ESDC_BACKEND_SYNC_EXECUTING_COMMANDS <<mode>>
ST_ESDC_BACKEND_SYNC_EXECUTING_COMMANDS : do / B_ESDC_BACKEND_SYNC_EXECUTE_COMMAND(command)
ST_ESDC_BACKEND_SYNC_EXECUTING_COMMANDS : executing captured backend commands

state "ST_ESDC_BACKEND_SYNC_REPORTING_COMMAND_OUTCOMES" as ST_ESDC_BACKEND_SYNC_REPORTING_COMMAND_OUTCOMES <<mode>>
ST_ESDC_BACKEND_SYNC_REPORTING_COMMAND_OUTCOMES : do / B_ESDC_BACKEND_SYNC_REPORT_COMMAND_OUTCOME(command,success_flag)
ST_ESDC_BACKEND_SYNC_REPORTING_COMMAND_OUTCOMES : reporting command processing result to backend

state "ST_ESDC_BACKEND_SYNC_SUCCEEDED" as ST_ESDC_BACKEND_SYNC_SUCCEEDED <<terminal>>
ST_ESDC_BACKEND_SYNC_SUCCEEDED : entry / B_ESDC_BACKEND_SYNC_FINALIZE_SUCCESS()
ST_ESDC_BACKEND_SYNC_SUCCEEDED : backend sync cycle completed successfully

state "ST_ESDC_BACKEND_SYNC_DEFERRED" as ST_ESDC_BACKEND_SYNC_DEFERRED <<wait>>
ST_ESDC_BACKEND_SYNC_DEFERRED : entry / B_ESDC_BACKEND_SYNC_DEFER_CYCLE(reason_code)
ST_ESDC_BACKEND_SYNC_DEFERRED : backend sync cycle deferred for later retry

state "ST_ESDC_BACKEND_SYNC_FAILED" as ST_ESDC_BACKEND_SYNC_FAILED <<error>>
ST_ESDC_BACKEND_SYNC_FAILED : entry / B_ESDC_BACKEND_SYNC_FINALIZE_FAILURE(error_code)
ST_ESDC_BACKEND_SYNC_FAILED : backend sync cycle failed

ST_ESDC_BACKEND_SYNC_IDLE --> ST_ESDC_BACKEND_SYNC_ENSURING_AUTH_CONTEXT : EV_ESDC_BACKEND_SYNC_CYCLE_TRIGGERED()\n/ B_ESDC_BACKEND_SYNC_START_CYCLE()

ST_ESDC_BACKEND_SYNC_ENSURING_AUTH_CONTEXT --> ST_ESDC_BACKEND_SYNC_ANNOUNCING_STATUS : EV_ESDC_BACKEND_SYNC_AUTH_CONTEXT_AVAILABLE(auth)\n[G_ESDC_BACKEND_SYNC_AUTH_CONTEXT_USABLE(auth)]\n/ B_ESDC_BACKEND_SYNC_ANNOUNCE_STATUS()

ST_ESDC_BACKEND_SYNC_ENSURING_AUTH_CONTEXT --> ST_ESDC_BACKEND_SYNC_ENSURING_AUTH_CONTEXT : EV_ESDC_BACKEND_SYNC_AUTH_CONTEXT_REFRESH_REQUIRED()\n/ B_ESDC_BACKEND_SYNC_REQUEST_AUTH_CONTEXT()

ST_ESDC_BACKEND_SYNC_ENSURING_AUTH_CONTEXT --> ST_ESDC_BACKEND_SYNC_ANNOUNCING_STATUS : EV_ESDC_BACKEND_SYNC_AUTH_CONTEXT_OBTAINED(auth)\n/ B_ESDC_BACKEND_SYNC_CACHE_AUTH_CONTEXT(auth)

ST_ESDC_BACKEND_SYNC_ENSURING_AUTH_CONTEXT --> ST_ESDC_BACKEND_SYNC_DEFERRED : EV_ESDC_BACKEND_SYNC_AUTH_CONTEXT_FAILED(error_code)\n[G_ESDC_BACKEND_SYNC_CAN_DEFER(error_code)]\n/ B_ESDC_BACKEND_SYNC_DEFER_CYCLE(error_code)

ST_ESDC_BACKEND_SYNC_ENSURING_AUTH_CONTEXT --> ST_ESDC_BACKEND_SYNC_FAILED : EV_ESDC_BACKEND_SYNC_AUTH_CONTEXT_FAILED(error_code)\n[!G_ESDC_BACKEND_SYNC_CAN_DEFER(error_code)]\n/ B_ESDC_BACKEND_SYNC_FINALIZE_FAILURE(error_code)

ST_ESDC_BACKEND_SYNC_ANNOUNCING_STATUS --> ST_ESDC_BACKEND_SYNC_CAPTURING_COMMANDS : EV_ESDC_BACKEND_SYNC_STATUS_ANNOUNCED(commands)\n[G_ESDC_BACKEND_SYNC_HAS_COMMANDS(commands)]\n/ B_ESDC_BACKEND_SYNC_CAPTURE_COMMANDS(commands)

ST_ESDC_BACKEND_SYNC_ANNOUNCING_STATUS --> ST_ESDC_BACKEND_SYNC_PULLING_INITIALIZATION_COMMANDS : EV_ESDC_BACKEND_SYNC_NO_COMMANDS_RECEIVED()\n/ B_ESDC_BACKEND_SYNC_REQUEST_INITIALIZATION_COMMANDS()

ST_ESDC_BACKEND_SYNC_PULLING_INITIALIZATION_COMMANDS --> ST_ESDC_BACKEND_SYNC_CAPTURING_COMMANDS : EV_ESDC_BACKEND_SYNC_INITIALIZATION_COMMANDS_RECEIVED(commands)\n[G_ESDC_BACKEND_SYNC_HAS_COMMANDS(commands)]\n/ B_ESDC_BACKEND_SYNC_CAPTURE_COMMANDS(commands)

ST_ESDC_BACKEND_SYNC_PULLING_INITIALIZATION_COMMANDS --> ST_ESDC_BACKEND_SYNC_SUCCEEDED : EV_ESDC_BACKEND_SYNC_NO_COMMANDS_RECEIVED()\n/ B_ESDC_BACKEND_SYNC_FINALIZE_SUCCESS()

ST_ESDC_BACKEND_SYNC_CAPTURING_COMMANDS --> ST_ESDC_BACKEND_SYNC_EXECUTING_COMMANDS : EV_ESDC_BACKEND_SYNC_COMMANDS_CAPTURED(commands)\n/ B_ESDC_BACKEND_SYNC_SELECT_NEXT_COMMAND()

ST_ESDC_BACKEND_SYNC_EXECUTING_COMMANDS --> ST_ESDC_BACKEND_SYNC_REPORTING_COMMAND_OUTCOMES : EV_ESDC_BACKEND_SYNC_COMMAND_EXECUTION_SUCCEEDED(command)\n[G_ESDC_BACKEND_SYNC_COMMAND_REPORTABLE(command)]\n/ B_ESDC_BACKEND_SYNC_RECORD_COMMAND_EXECUTION_SUCCESS(command)

ST_ESDC_BACKEND_SYNC_EXECUTING_COMMANDS --> ST_ESDC_BACKEND_SYNC_REPORTING_COMMAND_OUTCOMES : EV_ESDC_BACKEND_SYNC_COMMAND_EXECUTION_FAILED(command,error_code)\n[G_ESDC_BACKEND_SYNC_COMMAND_REPORTABLE(command)]\n/ B_ESDC_BACKEND_SYNC_RECORD_COMMAND_EXECUTION_FAILURE(command,error_code)

ST_ESDC_BACKEND_SYNC_EXECUTING_COMMANDS --> ST_ESDC_BACKEND_SYNC_FAILED : EV_ESDC_BACKEND_SYNC_COMMAND_EXECUTION_FAILED(command,error_code)\n[!G_ESDC_BACKEND_SYNC_COMMAND_REPORTABLE(command)]\n/ B_ESDC_BACKEND_SYNC_FINALIZE_FAILURE(error_code)

ST_ESDC_BACKEND_SYNC_REPORTING_COMMAND_OUTCOMES --> ST_ESDC_BACKEND_SYNC_EXECUTING_COMMANDS : EV_ESDC_BACKEND_SYNC_COMMAND_OUTCOME_REPORTED(command)\n/ B_ESDC_BACKEND_SYNC_SELECT_NEXT_COMMAND()

ST_ESDC_BACKEND_SYNC_REPORTING_COMMAND_OUTCOMES --> ST_ESDC_BACKEND_SYNC_DEFERRED : EV_ESDC_BACKEND_SYNC_COMMAND_OUTCOME_REPORT_FAILED(command,error_code)\n[G_ESDC_BACKEND_SYNC_CAN_DEFER(error_code)]\n/ B_ESDC_BACKEND_SYNC_RECORD_REPORT_FAILURE(command,error_code)

ST_ESDC_BACKEND_SYNC_REPORTING_COMMAND_OUTCOMES --> ST_ESDC_BACKEND_SYNC_FAILED : EV_ESDC_BACKEND_SYNC_COMMAND_OUTCOME_REPORT_FAILED(command,error_code)\n[!G_ESDC_BACKEND_SYNC_CAN_DEFER(error_code)]\n/ B_ESDC_BACKEND_SYNC_RECORD_REPORT_FAILURE(command,error_code)

ST_ESDC_BACKEND_SYNC_REPORTING_COMMAND_OUTCOMES --> ST_ESDC_BACKEND_SYNC_SUCCEEDED : EV_ESDC_BACKEND_SYNC_CYCLE_COMPLETED()\n/ B_ESDC_BACKEND_SYNC_FINALIZE_SUCCESS()

ST_ESDC_BACKEND_SYNC_SUCCEEDED --> [*]
ST_ESDC_BACKEND_SYNC_DEFERRED --> [*]
ST_ESDC_BACKEND_SYNC_FAILED --> [*]

@enduml
