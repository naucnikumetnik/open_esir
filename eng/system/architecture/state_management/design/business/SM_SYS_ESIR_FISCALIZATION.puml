@startuml
title SM_SYS_ESIR_FISCALIZATION — ESIR fiscalization business state machine

hide empty description

<style>
stateDiagram {
  BackgroundColor transparent
  LineColor #2f2f2f
  FontName Monospace
  FontSize 13
  ArrowColor #2f2f2f
}
state {
  BackgroundColor #f9f9f9
  LineColor #2f2f2f
  RoundCorner 12
  Padding 8
}
state<<mode>> {
  BackgroundColor #eef6ff
}
state<<wait>> {
  BackgroundColor #fff8e8
}
state<<error>> {
  BackgroundColor #fff1f1
}
state<<terminal>> {
  BackgroundColor #f1f1f1
  LineStyle 2
}
legend {
  FontName Monospace
  FontSize 12
}
</style>

legend right
MACHINE
  id: SM_SYS_ESIR_FISCALIZATION
  owner: C_ESIR
  scope: SYS
  purpose: Control one fiscalization request from intake through route selection and returned result.

NAMING
  states:    ST_ESIR_FISCALIZATION_<STATE>
  events:    EV_ESIR_FISCALIZATION_<EVENT>
  guards:    G_ESIR_FISCALIZATION_<RULE>
  behaviors: B_ESIR_FISCALIZATION_<ACTION>

EVENTS
  EV_ESIR_FISCALIZATION_REQUEST_RECEIVED(request:InvoiceRequest)
  EV_ESIR_FISCALIZATION_VALIDATION_SUCCEEDED(prepared_request:InvoiceRequest)
  EV_ESIR_FISCALIZATION_VALIDATION_FAILED(error:ValidationErrorResponse)
  EV_ESIR_FISCALIZATION_ONLINE_ROUTE_SELECTED()
  EV_ESIR_FISCALIZATION_LOCAL_ROUTE_SELECTED()
  EV_ESIR_FISCALIZATION_ONLINE_RESULT_RETURNED(result:InvoiceResult)
  EV_ESIR_FISCALIZATION_LOCAL_RESULT_RETURNED(result:InvoiceResult)

GUARDS
  G_ESIR_FISCALIZATION_REQUEST_VALID(request:InvoiceRequest) -> bool
  G_ESIR_FISCALIZATION_ONLINE_ALLOWED() -> bool
  G_ESIR_FISCALIZATION_LOCAL_ALLOWED() -> bool
  G_ESIR_FISCALIZATION_RESULT_SUCCESS(result:InvoiceResult) -> bool

BEHAVIORS
  B_ESIR_FISCALIZATION_ACCEPT_REQUEST(request:InvoiceRequest)
  B_ESIR_FISCALIZATION_VALIDATE_REQUEST(request:InvoiceRequest)
  B_ESIR_FISCALIZATION_PREPARE_RECEIPT(request:InvoiceRequest)
  B_ESIR_FISCALIZATION_SELECT_ROUTE()
  B_ESIR_FISCALIZATION_ROUTE_ONLINE(prepared_request:InvoiceRequest)
  B_ESIR_FISCALIZATION_ROUTE_LOCAL(prepared_request:InvoiceRequest)
  B_ESIR_FISCALIZATION_CAPTURE_VALIDATION_FAILURE(error:ValidationErrorResponse)
  B_ESIR_FISCALIZATION_RETURN_RESULT(result:InvoiceResult)
  B_ESIR_FISCALIZATION_FINALIZE_SUCCESS(result:InvoiceResult)
  B_ESIR_FISCALIZATION_FINALIZE_FAILURE(error)

RULES
  - this machine models ESIR-owned business orchestration only
  - local signing, audit persistence, backend sync, and proof lifecycle stay outside this machine
  - dynamic diagrams are linked through dynamic_view_ref + group_ref
endlegend

' REALIZATION ANCHORS
' B_ESIR_FISCALIZATION_ACCEPT_REQUEST(request)
'   -> S_SYS_FISCALIZE_INVOICE / GRP_FISCALIZE_RECEIVE_INVOICE_REQUEST
' B_ESIR_FISCALIZATION_VALIDATE_REQUEST(request)
'   -> S_SYS_FISCALIZE_INVOICE / GRP_FISCALIZE_VALIDATE_AND_PREPARE_REQUEST
' B_ESIR_FISCALIZATION_PREPARE_RECEIPT(request)
'   -> S_SYS_FISCALIZE_INVOICE / GRP_FISCALIZE_VALIDATE_AND_PREPARE_REQUEST
' B_ESIR_FISCALIZATION_SELECT_ROUTE()
'   -> S_SYS_FISCALIZE_INVOICE / GRP_FISCALIZE_VALIDATE_AND_PREPARE_REQUEST
' B_ESIR_FISCALIZATION_ROUTE_ONLINE(prepared_request)
'   -> S_SYS_FISCALIZE_INVOICE / GRP_FISCALIZE_ROUTE_ONLINE
' B_ESIR_FISCALIZATION_ROUTE_LOCAL(prepared_request)
'   -> S_SYS_FISCALIZE_INVOICE / GRP_FISCALIZE_ROUTE_LOCAL
' B_ESIR_FISCALIZATION_CAPTURE_VALIDATION_FAILURE(error)
'   -> S_SYS_FISCALIZE_INVOICE / GRP_FISCALIZE_VALIDATE_AND_PREPARE_REQUEST
' B_ESIR_FISCALIZATION_RETURN_RESULT(result)
'   -> S_SYS_FISCALIZE_INVOICE / GRP_FISCALIZE_RETURN_RESULT
' B_ESIR_FISCALIZATION_FINALIZE_SUCCESS(result)
'   -> S_SYS_FISCALIZE_INVOICE / GRP_FISCALIZE_RETURN_RESULT
' B_ESIR_FISCALIZATION_FINALIZE_FAILURE(error)
'   -> S_SYS_FISCALIZE_INVOICE / GRP_FISCALIZE_RETURN_RESULT

[*] --> ST_ESIR_FISCALIZATION_REQUEST_RECEIVED

state "ST_ESIR_FISCALIZATION_REQUEST_RECEIVED" as ST_ESIR_FISCALIZATION_REQUEST_RECEIVED <<wait>>
ST_ESIR_FISCALIZATION_REQUEST_RECEIVED : entry / B_ESIR_FISCALIZATION_ACCEPT_REQUEST(request)
ST_ESIR_FISCALIZATION_REQUEST_RECEIVED : request accepted for ESIR orchestration

state "ST_ESIR_FISCALIZATION_VALIDATING_AND_PREPARING" as ST_ESIR_FISCALIZATION_VALIDATING_AND_PREPARING <<mode>>
ST_ESIR_FISCALIZATION_VALIDATING_AND_PREPARING : entry / B_ESIR_FISCALIZATION_VALIDATE_REQUEST(request)
ST_ESIR_FISCALIZATION_VALIDATING_AND_PREPARING : do / B_ESIR_FISCALIZATION_PREPARE_RECEIPT(request)
ST_ESIR_FISCALIZATION_VALIDATING_AND_PREPARING : validates and composes fiscal receipt input

state "ST_ESIR_FISCALIZATION_ROUTE_DECISION" as ST_ESIR_FISCALIZATION_ROUTE_DECISION <<mode>>
ST_ESIR_FISCALIZATION_ROUTE_DECISION : entry / B_ESIR_FISCALIZATION_SELECT_ROUTE()
ST_ESIR_FISCALIZATION_ROUTE_DECISION : chooses online or local fiscalization path

state "ST_ESIR_FISCALIZATION_EXECUTING_ONLINE" as ST_ESIR_FISCALIZATION_EXECUTING_ONLINE <<mode>>
ST_ESIR_FISCALIZATION_EXECUTING_ONLINE : do / B_ESIR_FISCALIZATION_ROUTE_ONLINE(prepared_request)
ST_ESIR_FISCALIZATION_EXECUTING_ONLINE : delegated to V-SDC create-invoice path

state "ST_ESIR_FISCALIZATION_EXECUTING_LOCAL" as ST_ESIR_FISCALIZATION_EXECUTING_LOCAL <<mode>>
ST_ESIR_FISCALIZATION_EXECUTING_LOCAL : do / B_ESIR_FISCALIZATION_ROUTE_LOCAL(prepared_request)
ST_ESIR_FISCALIZATION_EXECUTING_LOCAL : delegated to E-SDC create-invoice path

state "ST_ESIR_FISCALIZATION_SUCCEEDED" as ST_ESIR_FISCALIZATION_SUCCEEDED <<terminal>>
ST_ESIR_FISCALIZATION_SUCCEEDED : entry / B_ESIR_FISCALIZATION_FINALIZE_SUCCESS(result)
ST_ESIR_FISCALIZATION_SUCCEEDED : successful InvoiceResult returned

state "ST_ESIR_FISCALIZATION_FAILED" as ST_ESIR_FISCALIZATION_FAILED <<error>>
ST_ESIR_FISCALIZATION_FAILED : entry / B_ESIR_FISCALIZATION_FINALIZE_FAILURE(error)
ST_ESIR_FISCALIZATION_FAILED : validation or execution failed

ST_ESIR_FISCALIZATION_REQUEST_RECEIVED --> ST_ESIR_FISCALIZATION_VALIDATING_AND_PREPARING : EV_ESIR_FISCALIZATION_REQUEST_RECEIVED(request)\n/ B_ESIR_FISCALIZATION_ACCEPT_REQUEST(request)

ST_ESIR_FISCALIZATION_VALIDATING_AND_PREPARING --> ST_ESIR_FISCALIZATION_ROUTE_DECISION : EV_ESIR_FISCALIZATION_VALIDATION_SUCCEEDED(prepared_request)\n[G_ESIR_FISCALIZATION_REQUEST_VALID(prepared_request)]\n/ B_ESIR_FISCALIZATION_PREPARE_RECEIPT(prepared_request)

ST_ESIR_FISCALIZATION_VALIDATING_AND_PREPARING --> ST_ESIR_FISCALIZATION_FAILED : EV_ESIR_FISCALIZATION_VALIDATION_FAILED(error)\n/ B_ESIR_FISCALIZATION_CAPTURE_VALIDATION_FAILURE(error)

ST_ESIR_FISCALIZATION_ROUTE_DECISION --> ST_ESIR_FISCALIZATION_EXECUTING_ONLINE : EV_ESIR_FISCALIZATION_ONLINE_ROUTE_SELECTED()\n[G_ESIR_FISCALIZATION_ONLINE_ALLOWED()]\n/ B_ESIR_FISCALIZATION_ROUTE_ONLINE(prepared_request)

ST_ESIR_FISCALIZATION_ROUTE_DECISION --> ST_ESIR_FISCALIZATION_EXECUTING_LOCAL : EV_ESIR_FISCALIZATION_LOCAL_ROUTE_SELECTED()\n[G_ESIR_FISCALIZATION_LOCAL_ALLOWED()]\n/ B_ESIR_FISCALIZATION_ROUTE_LOCAL(prepared_request)

ST_ESIR_FISCALIZATION_ROUTE_DECISION --> ST_ESIR_FISCALIZATION_FAILED : EV_ESIR_FISCALIZATION_ONLINE_ROUTE_SELECTED()\n[!G_ESIR_FISCALIZATION_ONLINE_ALLOWED() && !G_ESIR_FISCALIZATION_LOCAL_ALLOWED()]\n/ B_ESIR_FISCALIZATION_FINALIZE_FAILURE(route_unavailable)

ST_ESIR_FISCALIZATION_ROUTE_DECISION --> ST_ESIR_FISCALIZATION_FAILED : EV_ESIR_FISCALIZATION_LOCAL_ROUTE_SELECTED()\n[!G_ESIR_FISCALIZATION_LOCAL_ALLOWED() && !G_ESIR_FISCALIZATION_ONLINE_ALLOWED()]\n/ B_ESIR_FISCALIZATION_FINALIZE_FAILURE(route_unavailable)

ST_ESIR_FISCALIZATION_EXECUTING_ONLINE --> ST_ESIR_FISCALIZATION_SUCCEEDED : EV_ESIR_FISCALIZATION_ONLINE_RESULT_RETURNED(result)\n[G_ESIR_FISCALIZATION_RESULT_SUCCESS(result)]\n/ B_ESIR_FISCALIZATION_RETURN_RESULT(result)

ST_ESIR_FISCALIZATION_EXECUTING_ONLINE --> ST_ESIR_FISCALIZATION_FAILED : EV_ESIR_FISCALIZATION_ONLINE_RESULT_RETURNED(result)\n[!G_ESIR_FISCALIZATION_RESULT_SUCCESS(result)]\n/ B_ESIR_FISCALIZATION_RETURN_RESULT(result)

ST_ESIR_FISCALIZATION_EXECUTING_LOCAL --> ST_ESIR_FISCALIZATION_SUCCEEDED : EV_ESIR_FISCALIZATION_LOCAL_RESULT_RETURNED(result)\n[G_ESIR_FISCALIZATION_RESULT_SUCCESS(result)]\n/ B_ESIR_FISCALIZATION_RETURN_RESULT(result)

ST_ESIR_FISCALIZATION_EXECUTING_LOCAL --> ST_ESIR_FISCALIZATION_FAILED : EV_ESIR_FISCALIZATION_LOCAL_RESULT_RETURNED(result)\n[!G_ESIR_FISCALIZATION_RESULT_SUCCESS(result)]\n/ B_ESIR_FISCALIZATION_RETURN_RESULT(result)

ST_ESIR_FISCALIZATION_SUCCEEDED --> [*]
ST_ESIR_FISCALIZATION_FAILED --> [*]

@enduml
