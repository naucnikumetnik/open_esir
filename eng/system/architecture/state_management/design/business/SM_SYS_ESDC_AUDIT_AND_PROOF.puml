legend right
MACHINE
  id: SM_SYS_ESDC_AUDIT_AND_PROOF
  owner: C_ESDC
  scope: SYS
  purpose: Control audit backlog submission and proof-of-audit lifecycle.

NAMING
  states:    ST_ESDC_AUDIT_AND_PROOF_<STATE>
  events:    EV_ESDC_AUDIT_AND_PROOF_<EVENT>
  guards:    G_ESDC_AUDIT_AND_PROOF_<RULE>
  behaviors: B_ESDC_AUDIT_AND_PROOF_<ACTION>

EVENTS
  EV_ESDC_AUDIT_AND_PROOF_CYCLE_TRIGGERED()
  EV_ESDC_AUDIT_AND_PROOF_AUDIT_PACKAGE_SUBMITTED(status:AuditDataStatus)
  EV_ESDC_AUDIT_AND_PROOF_AUDIT_PACKAGE_SUBMIT_FAILED(error_code)
  EV_ESDC_AUDIT_AND_PROOF_PROOF_CYCLE_REQUESTED(uid:Uid)
  EV_ESDC_AUDIT_AND_PROOF_START_AUDIT_COMPLETED(arp:AuditRequestPayload)
  EV_ESDC_AUDIT_AND_PROOF_START_AUDIT_FAILED(error_code)
  EV_ESDC_AUDIT_AND_PROOF_AMOUNT_STATUS_COMPLETED(amount_status:AmountStatusResponse)
  EV_ESDC_AUDIT_AND_PROOF_AMOUNT_STATUS_FAILED(error_code)
  EV_ESDC_AUDIT_AND_PROOF_PROOF_REQUEST_COMPOSED(request:ProofOfAuditRequest)
  EV_ESDC_AUDIT_AND_PROOF_PROOF_REQUEST_SUBMIT_FAILED(error_code)
  EV_ESDC_AUDIT_AND_PROOF_PROOF_COMPLETION_RECEIVED(proof:ProofOfAudit)
  EV_ESDC_AUDIT_AND_PROOF_PROOF_COMPLETION_DEFERRED(reason_code)
  EV_ESDC_AUDIT_AND_PROOF_PROOF_CYCLE_COMPLETED()

GUARDS
  G_ESDC_AUDIT_AND_PROOF_HAS_PENDING_AUDIT_PACKAGE() -> bool
  G_ESDC_AUDIT_AND_PROOF_AUDIT_STATUS_RETRYABLE(status:AuditDataStatus) -> bool
  G_ESDC_AUDIT_AND_PROOF_AUDIT_STATUS_DELETE_LOCAL(status:AuditDataStatus) -> bool
  G_ESDC_AUDIT_AND_PROOF_AUDIT_STATUS_HOLD_LOCAL(status:AuditDataStatus) -> bool
  G_ESDC_AUDIT_AND_PROOF_PROOF_CYCLE_NEEDED() -> bool
  G_ESDC_AUDIT_AND_PROOF_ARP_AVAILABLE(arp:AuditRequestPayload) -> bool
  G_ESDC_AUDIT_AND_PROOF_PROOF_REQUEST_READY(request:ProofOfAuditRequest) -> bool
  G_ESDC_AUDIT_AND_PROOF_PROOF_COMPLETION_AVAILABLE(proof:ProofOfAudit) -> bool
  G_ESDC_AUDIT_AND_PROOF_CAN_DEFER(reason_code) -> bool

BEHAVIORS
  B_ESDC_AUDIT_AND_PROOF_START_CYCLE()
  B_ESDC_AUDIT_AND_PROOF_SELECT_NEXT_AUDIT_PACKAGE()
  B_ESDC_AUDIT_AND_PROOF_SUBMIT_AUDIT_PACKAGE(audit_package:AuditPackage)
  B_ESDC_AUDIT_AND_PROOF_CAPTURE_AUDIT_STATUS(status:AuditDataStatus)
  B_ESDC_AUDIT_AND_PROOF_PERSIST_RETURNED_COMMANDS(status:AuditDataStatus)
  B_ESDC_AUDIT_AND_PROOF_DELETE_LOCAL_AUDIT_PACKAGE()
  B_ESDC_AUDIT_AND_PROOF_MARK_AUDIT_PACKAGE_FOR_RETRY()
  B_ESDC_AUDIT_AND_PROOF_MARK_AUDIT_PACKAGE_ON_HOLD()
  B_ESDC_AUDIT_AND_PROOF_START_PROOF_CYCLE(uid:Uid)
  B_ESDC_AUDIT_AND_PROOF_INVOKE_START_AUDIT_APDU()
  B_ESDC_AUDIT_AND_PROOF_INVOKE_AMOUNT_STATUS_APDU()
  B_ESDC_AUDIT_AND_PROOF_COMPOSE_PROOF_REQUEST(arp:AuditRequestPayload,amount_status:AmountStatusResponse)
  B_ESDC_AUDIT_AND_PROOF_SUBMIT_PROOF_REQUEST(request:ProofOfAuditRequest)
  B_ESDC_AUDIT_AND_PROOF_WAIT_FOR_PROOF_COMPLETION()
  B_ESDC_AUDIT_AND_PROOF_CAPTURE_PROOF_COMPLETION(proof:ProofOfAudit)
  B_ESDC_AUDIT_AND_PROOF_COMPLETE_PROOF_CYCLE(proof:ProofOfAudit)
  B_ESDC_AUDIT_AND_PROOF_DEFER_CYCLE(reason_code)
  B_ESDC_AUDIT_AND_PROOF_FINALIZE_SUCCESS()
  B_ESDC_AUDIT_AND_PROOF_FINALIZE_FAILURE(error_code)

RULES
  - this machine models audit backlog and proof-of-audit lifecycle only
  - returned commands from AuditDataStatus are persisted as a side effect, not as a primary state branch
  - returned AuditDataStatus.commands[] are captured regardless of whether disposition becomes delete, retry, or hold
  - backend auth/status sync, local fiscalization, serving recovery, and export stay outside this machine
  - amount-status completion is treated as part of compact proof-request preparation before backend proof submission
  - dynamic diagrams are linked through dynamic_view_ref + group_ref
endlegend

' REALIZATION ANCHORS
' B_ESDC_AUDIT_AND_PROOF_START_CYCLE()
'   -> S_SYS_AUDIT_AND_PROOF_LIFECYCLE / GRP_AUDIT_DETECT_PENDING_OBLIGATIONS
' B_ESDC_AUDIT_AND_PROOF_SELECT_NEXT_AUDIT_PACKAGE()
'   -> S_SYS_AUDIT_AND_PROOF_LIFECYCLE / GRP_AUDIT_DETECT_PENDING_OBLIGATIONS
' B_ESDC_AUDIT_AND_PROOF_SUBMIT_AUDIT_PACKAGE(audit_package)
'   -> S_SYS_AUDIT_AND_PROOF_LIFECYCLE / GRP_AUDIT_SUBMIT_PENDING_PACKAGE
' B_ESDC_AUDIT_AND_PROOF_CAPTURE_AUDIT_STATUS(status)
'   -> S_SYS_AUDIT_AND_PROOF_LIFECYCLE / GRP_AUDIT_DETERMINE_PACKAGE_DISPOSITION
'   -> DV_SYS_OPEN_FISCAL_CORE_RUNTIME_STORE_AUDIT_AND_PROOF / AP_RESOLVE_AUDIT_BACKLOG_DISPOSITION
' B_ESDC_AUDIT_AND_PROOF_PERSIST_RETURNED_COMMANDS(status)
'   -> S_SYS_AUDIT_AND_PROOF_LIFECYCLE / GRP_AUDIT_PROCESS_RETURNED_COMMANDS
'   -> S_SYS_AUDIT_AND_PROOF_LIFECYCLE / GRP_AUDIT_DETERMINE_PACKAGE_DISPOSITION
' B_ESDC_AUDIT_AND_PROOF_DELETE_LOCAL_AUDIT_PACKAGE()
'   -> S_SYS_AUDIT_AND_PROOF_LIFECYCLE / GRP_AUDIT_DETERMINE_PACKAGE_DISPOSITION
' B_ESDC_AUDIT_AND_PROOF_MARK_AUDIT_PACKAGE_FOR_RETRY()
'   -> S_SYS_AUDIT_AND_PROOF_LIFECYCLE / GRP_AUDIT_DETERMINE_PACKAGE_DISPOSITION
' B_ESDC_AUDIT_AND_PROOF_MARK_AUDIT_PACKAGE_ON_HOLD()
'   -> S_SYS_AUDIT_AND_PROOF_LIFECYCLE / GRP_AUDIT_DETERMINE_PACKAGE_DISPOSITION
' B_ESDC_AUDIT_AND_PROOF_START_PROOF_CYCLE(uid)
'   -> S_SYS_AUDIT_AND_PROOF_LIFECYCLE / GRP_PROOF_GENERATE_REQUEST_INPUTS
'   -> DV_SYS_OPEN_FISCAL_CORE_RUNTIME_STORE_AUDIT_AND_PROOF / AP_START_PROOF_CYCLE
' B_ESDC_AUDIT_AND_PROOF_INVOKE_START_AUDIT_APDU()
'   -> S_SYS_AUDIT_AND_PROOF_LIFECYCLE / GRP_PROOF_GENERATE_REQUEST_INPUTS
' B_ESDC_AUDIT_AND_PROOF_INVOKE_AMOUNT_STATUS_APDU()
'   -> S_SYS_AUDIT_AND_PROOF_LIFECYCLE / GRP_PROOF_GENERATE_REQUEST_INPUTS
' B_ESDC_AUDIT_AND_PROOF_COMPOSE_PROOF_REQUEST(arp,amount_status)
'   -> S_SYS_AUDIT_AND_PROOF_LIFECYCLE / GRP_PROOF_SUBMIT_REQUEST
'   -> DV_SYS_OPEN_FISCAL_CORE_RUNTIME_STORE_AUDIT_AND_PROOF / AP_START_PROOF_CYCLE
' B_ESDC_AUDIT_AND_PROOF_SUBMIT_PROOF_REQUEST(request)
'   -> S_SYS_AUDIT_AND_PROOF_LIFECYCLE / GRP_PROOF_SUBMIT_REQUEST
' B_ESDC_AUDIT_AND_PROOF_WAIT_FOR_PROOF_COMPLETION()
'   -> S_SYS_AUDIT_AND_PROOF_LIFECYCLE / GRP_PROOF_KEEP_PENDING
' B_ESDC_AUDIT_AND_PROOF_CAPTURE_PROOF_COMPLETION(proof)
'   -> S_SYS_AUDIT_AND_PROOF_LIFECYCLE / GRP_PROOF_COMPLETE_WITH_RETURNED_COMMAND
' B_ESDC_AUDIT_AND_PROOF_COMPLETE_PROOF_CYCLE(proof)
'   -> S_SYS_AUDIT_AND_PROOF_LIFECYCLE / GRP_PROOF_COMPLETE_WITH_RETURNED_COMMAND
'   -> DV_SYS_OPEN_FISCAL_CORE_RUNTIME_STORE_AUDIT_AND_PROOF / AP_COMPLETE_PROOF_CYCLE
' B_ESDC_AUDIT_AND_PROOF_DEFER_CYCLE(reason_code)
'   -> S_SYS_AUDIT_AND_PROOF_LIFECYCLE / GRP_AUDIT_SKIP_REMOTE_SUBMISSION
'   -> S_SYS_AUDIT_AND_PROOF_LIFECYCLE / GRP_PROOF_SKIP_CYCLE
' B_ESDC_AUDIT_AND_PROOF_FINALIZE_SUCCESS()
'   -> S_SYS_AUDIT_AND_PROOF_LIFECYCLE / GRP_AUDIT_CLOSE_OUTCOME
' B_ESDC_AUDIT_AND_PROOF_FINALIZE_FAILURE(error_code)
'   -> S_SYS_AUDIT_AND_PROOF_LIFECYCLE / GRP_AUDIT_CLOSE_OUTCOME

[*] --> ST_ESDC_AUDIT_AND_PROOF_IDLE

state "ST_ESDC_AUDIT_AND_PROOF_IDLE" as ST_ESDC_AUDIT_AND_PROOF_IDLE <<wait>>
ST_ESDC_AUDIT_AND_PROOF_IDLE : waiting for pending audit backlog or proof cycle trigger

state "ST_ESDC_AUDIT_AND_PROOF_SUBMITTING_AUDIT_PACKAGE" as ST_ESDC_AUDIT_AND_PROOF_SUBMITTING_AUDIT_PACKAGE <<mode>>
ST_ESDC_AUDIT_AND_PROOF_SUBMITTING_AUDIT_PACKAGE : do / B_ESDC_AUDIT_AND_PROOF_SUBMIT_AUDIT_PACKAGE(audit_package)
ST_ESDC_AUDIT_AND_PROOF_SUBMITTING_AUDIT_PACKAGE : submitting local audit package to backend

state "ST_ESDC_AUDIT_AND_PROOF_RESOLVING_AUDIT_STATUS" as ST_ESDC_AUDIT_AND_PROOF_RESOLVING_AUDIT_STATUS <<mode>>
ST_ESDC_AUDIT_AND_PROOF_RESOLVING_AUDIT_STATUS : do / B_ESDC_AUDIT_AND_PROOF_CAPTURE_AUDIT_STATUS(status)
ST_ESDC_AUDIT_AND_PROOF_RESOLVING_AUDIT_STATUS : resolving local disposition from returned audit status

state "ST_ESDC_AUDIT_AND_PROOF_STARTING_PROOF_CYCLE" as ST_ESDC_AUDIT_AND_PROOF_STARTING_PROOF_CYCLE <<mode>>
ST_ESDC_AUDIT_AND_PROOF_STARTING_PROOF_CYCLE : entry / B_ESDC_AUDIT_AND_PROOF_START_PROOF_CYCLE(uid)
ST_ESDC_AUDIT_AND_PROOF_STARTING_PROOF_CYCLE : do / B_ESDC_AUDIT_AND_PROOF_INVOKE_START_AUDIT_APDU()
ST_ESDC_AUDIT_AND_PROOF_STARTING_PROOF_CYCLE : acquiring ARP and preparing proof inputs

state "ST_ESDC_AUDIT_AND_PROOF_SUBMITTING_PROOF_REQUEST" as ST_ESDC_AUDIT_AND_PROOF_SUBMITTING_PROOF_REQUEST <<mode>>
ST_ESDC_AUDIT_AND_PROOF_SUBMITTING_PROOF_REQUEST : do / B_ESDC_AUDIT_AND_PROOF_SUBMIT_PROOF_REQUEST(request)
ST_ESDC_AUDIT_AND_PROOF_SUBMITTING_PROOF_REQUEST : submitting composed proof request to backend

state "ST_ESDC_AUDIT_AND_PROOF_WAITING_FOR_PROOF_COMPLETION" as ST_ESDC_AUDIT_AND_PROOF_WAITING_FOR_PROOF_COMPLETION <<wait>>
ST_ESDC_AUDIT_AND_PROOF_WAITING_FOR_PROOF_COMPLETION : do / B_ESDC_AUDIT_AND_PROOF_WAIT_FOR_PROOF_COMPLETION()
ST_ESDC_AUDIT_AND_PROOF_WAITING_FOR_PROOF_COMPLETION : waiting for proof completion or returned completion context

state "ST_ESDC_AUDIT_AND_PROOF_COMPLETING_PROOF_CYCLE" as ST_ESDC_AUDIT_AND_PROOF_COMPLETING_PROOF_CYCLE <<mode>>
ST_ESDC_AUDIT_AND_PROOF_COMPLETING_PROOF_CYCLE : do / B_ESDC_AUDIT_AND_PROOF_COMPLETE_PROOF_CYCLE(proof)
ST_ESDC_AUDIT_AND_PROOF_COMPLETING_PROOF_CYCLE : recording proof artifact and closing proof cycle

state "ST_ESDC_AUDIT_AND_PROOF_SUCCEEDED" as ST_ESDC_AUDIT_AND_PROOF_SUCCEEDED <<terminal>>
ST_ESDC_AUDIT_AND_PROOF_SUCCEEDED : entry / B_ESDC_AUDIT_AND_PROOF_FINALIZE_SUCCESS()
ST_ESDC_AUDIT_AND_PROOF_SUCCEEDED : audit and proof cycle completed successfully

state "ST_ESDC_AUDIT_AND_PROOF_DEFERRED" as ST_ESDC_AUDIT_AND_PROOF_DEFERRED <<wait>>
ST_ESDC_AUDIT_AND_PROOF_DEFERRED : entry / B_ESDC_AUDIT_AND_PROOF_DEFER_CYCLE(reason_code)
ST_ESDC_AUDIT_AND_PROOF_DEFERRED : cycle deferred for later retry or completion

state "ST_ESDC_AUDIT_AND_PROOF_FAILED" as ST_ESDC_AUDIT_AND_PROOF_FAILED <<error>>
ST_ESDC_AUDIT_AND_PROOF_FAILED : entry / B_ESDC_AUDIT_AND_PROOF_FINALIZE_FAILURE(error_code)
ST_ESDC_AUDIT_AND_PROOF_FAILED : audit or proof cycle failed

ST_ESDC_AUDIT_AND_PROOF_IDLE --> ST_ESDC_AUDIT_AND_PROOF_SUBMITTING_AUDIT_PACKAGE : EV_ESDC_AUDIT_AND_PROOF_CYCLE_TRIGGERED()\n[G_ESDC_AUDIT_AND_PROOF_HAS_PENDING_AUDIT_PACKAGE()]\n/ B_ESDC_AUDIT_AND_PROOF_START_CYCLE(), B_ESDC_AUDIT_AND_PROOF_SELECT_NEXT_AUDIT_PACKAGE()

ST_ESDC_AUDIT_AND_PROOF_IDLE --> ST_ESDC_AUDIT_AND_PROOF_STARTING_PROOF_CYCLE : EV_ESDC_AUDIT_AND_PROOF_PROOF_CYCLE_REQUESTED(uid)\n/ B_ESDC_AUDIT_AND_PROOF_START_CYCLE(), B_ESDC_AUDIT_AND_PROOF_START_PROOF_CYCLE(uid)

ST_ESDC_AUDIT_AND_PROOF_SUBMITTING_AUDIT_PACKAGE --> ST_ESDC_AUDIT_AND_PROOF_RESOLVING_AUDIT_STATUS : EV_ESDC_AUDIT_AND_PROOF_AUDIT_PACKAGE_SUBMITTED(status)\n/ B_ESDC_AUDIT_AND_PROOF_CAPTURE_AUDIT_STATUS(status)

ST_ESDC_AUDIT_AND_PROOF_SUBMITTING_AUDIT_PACKAGE --> ST_ESDC_AUDIT_AND_PROOF_DEFERRED : EV_ESDC_AUDIT_AND_PROOF_AUDIT_PACKAGE_SUBMIT_FAILED(error_code)\n[G_ESDC_AUDIT_AND_PROOF_CAN_DEFER(error_code)]\n/ B_ESDC_AUDIT_AND_PROOF_DEFER_CYCLE(error_code)

ST_ESDC_AUDIT_AND_PROOF_SUBMITTING_AUDIT_PACKAGE --> ST_ESDC_AUDIT_AND_PROOF_FAILED : EV_ESDC_AUDIT_AND_PROOF_AUDIT_PACKAGE_SUBMIT_FAILED(error_code)\n[!G_ESDC_AUDIT_AND_PROOF_CAN_DEFER(error_code)]\n/ B_ESDC_AUDIT_AND_PROOF_FINALIZE_FAILURE(error_code)

ST_ESDC_AUDIT_AND_PROOF_RESOLVING_AUDIT_STATUS --> ST_ESDC_AUDIT_AND_PROOF_STARTING_PROOF_CYCLE : EV_ESDC_AUDIT_AND_PROOF_AUDIT_PACKAGE_SUBMITTED(status)\n[G_ESDC_AUDIT_AND_PROOF_AUDIT_STATUS_DELETE_LOCAL(status) && G_ESDC_AUDIT_AND_PROOF_PROOF_CYCLE_NEEDED()]\n/ B_ESDC_AUDIT_AND_PROOF_PERSIST_RETURNED_COMMANDS(status), B_ESDC_AUDIT_AND_PROOF_DELETE_LOCAL_AUDIT_PACKAGE()

ST_ESDC_AUDIT_AND_PROOF_RESOLVING_AUDIT_STATUS --> ST_ESDC_AUDIT_AND_PROOF_DEFERRED : EV_ESDC_AUDIT_AND_PROOF_AUDIT_PACKAGE_SUBMITTED(status)\n[G_ESDC_AUDIT_AND_PROOF_AUDIT_STATUS_RETRYABLE(status)]\n/ B_ESDC_AUDIT_AND_PROOF_PERSIST_RETURNED_COMMANDS(status), B_ESDC_AUDIT_AND_PROOF_MARK_AUDIT_PACKAGE_FOR_RETRY(), B_ESDC_AUDIT_AND_PROOF_DEFER_CYCLE(retry_required)

ST_ESDC_AUDIT_AND_PROOF_RESOLVING_AUDIT_STATUS --> ST_ESDC_AUDIT_AND_PROOF_DEFERRED : EV_ESDC_AUDIT_AND_PROOF_AUDIT_PACKAGE_SUBMITTED(status)\n[G_ESDC_AUDIT_AND_PROOF_AUDIT_STATUS_HOLD_LOCAL(status)]\n/ B_ESDC_AUDIT_AND_PROOF_PERSIST_RETURNED_COMMANDS(status), B_ESDC_AUDIT_AND_PROOF_MARK_AUDIT_PACKAGE_ON_HOLD(), B_ESDC_AUDIT_AND_PROOF_DEFER_CYCLE(hold_local)

ST_ESDC_AUDIT_AND_PROOF_RESOLVING_AUDIT_STATUS --> ST_ESDC_AUDIT_AND_PROOF_SUCCEEDED : EV_ESDC_AUDIT_AND_PROOF_AUDIT_PACKAGE_SUBMITTED(status)\n[G_ESDC_AUDIT_AND_PROOF_AUDIT_STATUS_DELETE_LOCAL(status) && !G_ESDC_AUDIT_AND_PROOF_PROOF_CYCLE_NEEDED()]\n/ B_ESDC_AUDIT_AND_PROOF_PERSIST_RETURNED_COMMANDS(status), B_ESDC_AUDIT_AND_PROOF_DELETE_LOCAL_AUDIT_PACKAGE()

ST_ESDC_AUDIT_AND_PROOF_STARTING_PROOF_CYCLE --> ST_ESDC_AUDIT_AND_PROOF_SUBMITTING_PROOF_REQUEST : EV_ESDC_AUDIT_AND_PROOF_START_AUDIT_COMPLETED(arp)\n[G_ESDC_AUDIT_AND_PROOF_ARP_AVAILABLE(arp)]\n/ B_ESDC_AUDIT_AND_PROOF_INVOKE_AMOUNT_STATUS_APDU()

ST_ESDC_AUDIT_AND_PROOF_STARTING_PROOF_CYCLE --> ST_ESDC_AUDIT_AND_PROOF_FAILED : EV_ESDC_AUDIT_AND_PROOF_START_AUDIT_FAILED(error_code)\n/ B_ESDC_AUDIT_AND_PROOF_FINALIZE_FAILURE(error_code)

ST_ESDC_AUDIT_AND_PROOF_SUBMITTING_PROOF_REQUEST --> ST_ESDC_AUDIT_AND_PROOF_SUBMITTING_PROOF_REQUEST : EV_ESDC_AUDIT_AND_PROOF_AMOUNT_STATUS_COMPLETED(amount_status)\n/ B_ESDC_AUDIT_AND_PROOF_COMPOSE_PROOF_REQUEST(arp,amount_status)

ST_ESDC_AUDIT_AND_PROOF_SUBMITTING_PROOF_REQUEST --> ST_ESDC_AUDIT_AND_PROOF_FAILED : EV_ESDC_AUDIT_AND_PROOF_AMOUNT_STATUS_FAILED(error_code)\n/ B_ESDC_AUDIT_AND_PROOF_FINALIZE_FAILURE(error_code)

ST_ESDC_AUDIT_AND_PROOF_SUBMITTING_PROOF_REQUEST --> ST_ESDC_AUDIT_AND_PROOF_WAITING_FOR_PROOF_COMPLETION : EV_ESDC_AUDIT_AND_PROOF_PROOF_REQUEST_COMPOSED(request)\n[G_ESDC_AUDIT_AND_PROOF_PROOF_REQUEST_READY(request)]\n/ B_ESDC_AUDIT_AND_PROOF_SUBMIT_PROOF_REQUEST(request)

ST_ESDC_AUDIT_AND_PROOF_SUBMITTING_PROOF_REQUEST --> ST_ESDC_AUDIT_AND_PROOF_DEFERRED : EV_ESDC_AUDIT_AND_PROOF_PROOF_REQUEST_SUBMIT_FAILED(error_code)\n[G_ESDC_AUDIT_AND_PROOF_CAN_DEFER(error_code)]\n/ B_ESDC_AUDIT_AND_PROOF_DEFER_CYCLE(error_code)

ST_ESDC_AUDIT_AND_PROOF_SUBMITTING_PROOF_REQUEST --> ST_ESDC_AUDIT_AND_PROOF_FAILED : EV_ESDC_AUDIT_AND_PROOF_PROOF_REQUEST_SUBMIT_FAILED(error_code)\n[!G_ESDC_AUDIT_AND_PROOF_CAN_DEFER(error_code)]\n/ B_ESDC_AUDIT_AND_PROOF_FINALIZE_FAILURE(error_code)

ST_ESDC_AUDIT_AND_PROOF_WAITING_FOR_PROOF_COMPLETION --> ST_ESDC_AUDIT_AND_PROOF_COMPLETING_PROOF_CYCLE : EV_ESDC_AUDIT_AND_PROOF_PROOF_COMPLETION_RECEIVED(proof)\n[G_ESDC_AUDIT_AND_PROOF_PROOF_COMPLETION_AVAILABLE(proof)]\n/ B_ESDC_AUDIT_AND_PROOF_CAPTURE_PROOF_COMPLETION(proof)

ST_ESDC_AUDIT_AND_PROOF_WAITING_FOR_PROOF_COMPLETION --> ST_ESDC_AUDIT_AND_PROOF_DEFERRED : EV_ESDC_AUDIT_AND_PROOF_PROOF_COMPLETION_DEFERRED(reason_code)\n[G_ESDC_AUDIT_AND_PROOF_CAN_DEFER(reason_code)]\n/ B_ESDC_AUDIT_AND_PROOF_WAIT_FOR_PROOF_COMPLETION(), B_ESDC_AUDIT_AND_PROOF_DEFER_CYCLE(reason_code)

ST_ESDC_AUDIT_AND_PROOF_WAITING_FOR_PROOF_COMPLETION --> ST_ESDC_AUDIT_AND_PROOF_FAILED : EV_ESDC_AUDIT_AND_PROOF_PROOF_COMPLETION_DEFERRED(reason_code)\n[!G_ESDC_AUDIT_AND_PROOF_CAN_DEFER(reason_code)]\n/ B_ESDC_AUDIT_AND_PROOF_FINALIZE_FAILURE(reason_code)

ST_ESDC_AUDIT_AND_PROOF_COMPLETING_PROOF_CYCLE --> ST_ESDC_AUDIT_AND_PROOF_SUCCEEDED : EV_ESDC_AUDIT_AND_PROOF_PROOF_CYCLE_COMPLETED()\n/ B_ESDC_AUDIT_AND_PROOF_COMPLETE_PROOF_CYCLE(proof)

ST_ESDC_AUDIT_AND_PROOF_SUCCEEDED --> [*]
ST_ESDC_AUDIT_AND_PROOF_DEFERRED --> [*]
ST_ESDC_AUDIT_AND_PROOF_FAILED --> [*]

@enduml
