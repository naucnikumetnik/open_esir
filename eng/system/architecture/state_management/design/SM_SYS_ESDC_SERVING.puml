@startuml
title SM_SYS_ESDC_SERVING — E-SDC serving / availability state machine

hide empty description

<style>
stateDiagram {
  BackgroundColor transparent
  LineColor #2f2f2f
  FontName Monospace
  FontSize 13
  ArrowColor #2f2f2f
}
state {
  BackgroundColor #f9f9f9
  LineColor #2f2f2f
  RoundCorner 12
  Padding 8
}
state<<mode>> {
  BackgroundColor #eef6ff
}
state<<wait>> {
  BackgroundColor #fff8e8
}
state<<error>> {
  BackgroundColor #fff1f1
}
legend {
  FontName Monospace
  FontSize 12
}
</style>

legend right
MACHINE
  id: SM_SYS_ESDC_SERVING
  owner: C_ESDC
  scope: SYS
  purpose: Control whether E-SDC should admit new local fiscalization and operational work.

NAMING
  states:    ST_ESDC_<STATE>
  events:    EV_ESDC_<EVENT>
  guards:    G_ESDC_<RULE>
  behaviors: B_ESDC_<ACTION>

EVENTS
  EV_ESDC_BOOTSTRAP_COMPLETED(status:StatusResponse)
  EV_ESDC_ATTENTION_FAILED(reason_code)
  EV_ESDC_STATUS_REFRESHED(status:StatusResponse)
  EV_ESDC_PIN_REQUIRED_DETECTED()
  EV_ESDC_PIN_VERIFIED_OK()
  EV_ESDC_PIN_VERIFIED_FAILED(reason_code)
  EV_ESDC_AUDIT_REQUIRED_DETECTED()
  EV_ESDC_AUDIT_REQUIREMENT_CLEARED()
  EV_ESDC_TIME_OR_CERT_DEGRADED_DETECTED(reason_code)
  EV_ESDC_TIME_AND_CERT_OK()
  EV_ESDC_BACKEND_PATH_LOST(reason_code)
  EV_ESDC_BACKEND_PATH_AVAILABLE()
  EV_ESDC_SECURE_ELEMENT_PATH_LOST(reason_code)
  EV_ESDC_SECURE_ELEMENT_PATH_RESTORED()
  EV_ESDC_FATAL_RUNTIME_FAULT(code)

GUARDS
  G_ESDC_RUNTIME_RESPONSIVE() -> bool
  G_ESDC_STATUS_SERVICEABLE(status:StatusResponse) -> bool
  G_ESDC_SECURE_ELEMENT_PATH_USABLE() -> bool
  G_ESDC_BACKEND_PATH_USABLE() -> bool
  G_ESDC_LOCAL_ONLY_OPERATION_POSSIBLE() -> bool
  G_ESDC_PIN_REQUIRED(status:StatusResponse) -> bool
  G_ESDC_AUDIT_REQUIRED(status:StatusResponse) -> bool
  G_ESDC_TIME_OR_CERT_OK() -> bool

BEHAVIORS
  B_ESDC_MARK_STARTING()
  B_ESDC_PROBE_AVAILABILITY()
  B_ESDC_EVALUATE_STATUS(status:StatusResponse)
  B_ESDC_EVALUATE_RECOVERY_NEEDS()
  B_ESDC_BEGIN_ACCEPTING()
  B_ESDC_STOP_ACCEPTING()
  B_ESDC_PUBLISH_ACCEPTING()
  B_ESDC_PUBLISH_DEGRADED_LOCAL_ONLY()
  B_ESDC_PUBLISH_BLOCKED()
  B_ESDC_RECORD_PIN_REQUIRED()
  B_ESDC_RECORD_AUDIT_REQUIRED()
  B_ESDC_RECORD_TIME_OR_CERT_DEGRADED(reason_code)
  B_ESDC_NOTE_BACKEND_PATH_CHANGE(availability)
  B_ESDC_NOTE_SECURE_ELEMENT_PATH_CHANGE(availability)
  B_ESDC_RECORD_FATAL_FAULT(code)
  B_ESDC_APPLY_PIN_RECOVERY_SUCCESS()
  B_ESDC_APPLY_PIN_RECOVERY_FAILURE(reason_code)

RULES
  - serving state is not backend-sync or audit workflow state
  - health is projected separately from serving state + runtime facts
  - behavior ids remain semantic and stable
  - dynamic diagrams are linked through dynamic_view_ref + group_ref
endlegend

' REALIZATION ANCHORS
' B_ESDC_PROBE_AVAILABILITY()
'   -> S_SYS_STATUS_AND_OPERATOR_RECOVERY / GRP_STATUS_PROBE_ESDC_AVAILABILITY
' B_ESDC_EVALUATE_STATUS(status)
'   -> S_SYS_STATUS_AND_OPERATOR_RECOVERY / GRP_STATUS_READ_CURRENT_STATUS
' B_ESDC_EVALUATE_RECOVERY_NEEDS()
'   -> S_SYS_STATUS_AND_OPERATOR_RECOVERY / GRP_STATUS_EVALUATE_RECOVERY_NEEDS
' B_ESDC_RECORD_AUDIT_REQUIRED()
'   -> S_SYS_STATUS_AND_OPERATOR_RECOVERY / GRP_STATUS_BLOCK_ON_AUDIT_REQUIRED
' B_ESDC_APPLY_PIN_RECOVERY_SUCCESS()
'   -> S_SYS_STATUS_AND_OPERATOR_RECOVERY / GRP_STATUS_RECOVER_PIN_REQUIRED_STATE
' B_ESDC_APPLY_PIN_RECOVERY_FAILURE(reason_code)
'   -> S_SYS_STATUS_AND_OPERATOR_RECOVERY / GRP_STATUS_RECOVER_PIN_REQUIRED_STATE
' B_ESDC_RECORD_TIME_OR_CERT_DEGRADED(reason_code)
'   -> S_SYS_STATUS_AND_OPERATOR_RECOVERY / GRP_STATUS_HANDLE_TIME_OR_CERTIFICATE_DEGRADED

[*] --> ST_ESDC_STARTING

state "ST_ESDC_STARTING" as ST_ESDC_STARTING <<wait>>
ST_ESDC_STARTING : entry / B_ESDC_MARK_STARTING()
ST_ESDC_STARTING : do / B_ESDC_PROBE_AVAILABILITY()
ST_ESDC_STARTING : evaluating local runtime and serving prerequisites

state "ST_ESDC_ACCEPTING" as ST_ESDC_ACCEPTING <<mode>>
ST_ESDC_ACCEPTING : entry / B_ESDC_BEGIN_ACCEPTING()
ST_ESDC_ACCEPTING : do / B_ESDC_PUBLISH_ACCEPTING()
ST_ESDC_ACCEPTING : exit / B_ESDC_STOP_ACCEPTING()
ST_ESDC_ACCEPTING : admits local fiscalization and operational work

state "ST_ESDC_DEGRADED_LOCAL_ONLY" as ST_ESDC_DEGRADED_LOCAL_ONLY <<error>>
ST_ESDC_DEGRADED_LOCAL_ONLY : entry / B_ESDC_PUBLISH_DEGRADED_LOCAL_ONLY()
ST_ESDC_DEGRADED_LOCAL_ONLY : do / B_ESDC_PROBE_AVAILABILITY()
ST_ESDC_DEGRADED_LOCAL_ONLY : local-only serving remains possible while backend path is degraded

state "ST_ESDC_BLOCKED" as ST_ESDC_BLOCKED <<error>>
ST_ESDC_BLOCKED : entry / B_ESDC_PUBLISH_BLOCKED()
ST_ESDC_BLOCKED : do / B_ESDC_STOP_ACCEPTING()
ST_ESDC_BLOCKED : does not admit new local fiscalization work

ST_ESDC_STARTING --> ST_ESDC_ACCEPTING : EV_ESDC_BOOTSTRAP_COMPLETED(status)\n[G_ESDC_RUNTIME_RESPONSIVE() && G_ESDC_STATUS_SERVICEABLE(status) && G_ESDC_SECURE_ELEMENT_PATH_USABLE() && !G_ESDC_PIN_REQUIRED(status) && !G_ESDC_AUDIT_REQUIRED(status) && G_ESDC_TIME_OR_CERT_OK()]\n/ B_ESDC_EVALUATE_STATUS(status)

ST_ESDC_STARTING --> ST_ESDC_DEGRADED_LOCAL_ONLY : EV_ESDC_BOOTSTRAP_COMPLETED(status)\n[G_ESDC_RUNTIME_RESPONSIVE() && G_ESDC_LOCAL_ONLY_OPERATION_POSSIBLE() && G_ESDC_SECURE_ELEMENT_PATH_USABLE() && !G_ESDC_PIN_REQUIRED(status) && !G_ESDC_AUDIT_REQUIRED(status) && G_ESDC_TIME_OR_CERT_OK() && !G_ESDC_BACKEND_PATH_USABLE()]\n/ B_ESDC_EVALUATE_STATUS(status)

ST_ESDC_STARTING --> ST_ESDC_BLOCKED : EV_ESDC_ATTENTION_FAILED(reason_code)\n/ B_ESDC_PUBLISH_BLOCKED()

ST_ESDC_STARTING --> ST_ESDC_BLOCKED : EV_ESDC_BOOTSTRAP_COMPLETED(status)\n[!G_ESDC_RUNTIME_RESPONSIVE() || !G_ESDC_SECURE_ELEMENT_PATH_USABLE() || G_ESDC_PIN_REQUIRED(status) || G_ESDC_AUDIT_REQUIRED(status) || !G_ESDC_TIME_OR_CERT_OK()]\n/ B_ESDC_EVALUATE_STATUS(status)

ST_ESDC_ACCEPTING --> ST_ESDC_DEGRADED_LOCAL_ONLY : EV_ESDC_BACKEND_PATH_LOST(reason_code)\n[G_ESDC_LOCAL_ONLY_OPERATION_POSSIBLE() && G_ESDC_SECURE_ELEMENT_PATH_USABLE()]\n/ B_ESDC_NOTE_BACKEND_PATH_CHANGE(unavailable)

ST_ESDC_ACCEPTING --> ST_ESDC_BLOCKED : EV_ESDC_PIN_REQUIRED_DETECTED()\n/ B_ESDC_RECORD_PIN_REQUIRED()

ST_ESDC_ACCEPTING --> ST_ESDC_BLOCKED : EV_ESDC_AUDIT_REQUIRED_DETECTED()\n/ B_ESDC_RECORD_AUDIT_REQUIRED()

ST_ESDC_ACCEPTING --> ST_ESDC_BLOCKED : EV_ESDC_TIME_OR_CERT_DEGRADED_DETECTED(reason_code)\n/ B_ESDC_RECORD_TIME_OR_CERT_DEGRADED(reason_code)

ST_ESDC_ACCEPTING --> ST_ESDC_BLOCKED : EV_ESDC_SECURE_ELEMENT_PATH_LOST(reason_code)\n/ B_ESDC_NOTE_SECURE_ELEMENT_PATH_CHANGE(unavailable)

ST_ESDC_ACCEPTING --> ST_ESDC_BLOCKED : EV_ESDC_FATAL_RUNTIME_FAULT(code)\n/ B_ESDC_RECORD_FATAL_FAULT(code)

ST_ESDC_DEGRADED_LOCAL_ONLY --> ST_ESDC_ACCEPTING : EV_ESDC_STATUS_REFRESHED(status)\n[G_ESDC_RUNTIME_RESPONSIVE() && G_ESDC_STATUS_SERVICEABLE(status) && G_ESDC_SECURE_ELEMENT_PATH_USABLE() && G_ESDC_BACKEND_PATH_USABLE() && !G_ESDC_PIN_REQUIRED(status) && !G_ESDC_AUDIT_REQUIRED(status) && G_ESDC_TIME_OR_CERT_OK()]\n/ B_ESDC_EVALUATE_STATUS(status)

ST_ESDC_DEGRADED_LOCAL_ONLY --> ST_ESDC_BLOCKED : EV_ESDC_PIN_REQUIRED_DETECTED()\n/ B_ESDC_RECORD_PIN_REQUIRED()

ST_ESDC_DEGRADED_LOCAL_ONLY --> ST_ESDC_BLOCKED : EV_ESDC_AUDIT_REQUIRED_DETECTED()\n/ B_ESDC_RECORD_AUDIT_REQUIRED()

ST_ESDC_DEGRADED_LOCAL_ONLY --> ST_ESDC_BLOCKED : EV_ESDC_TIME_OR_CERT_DEGRADED_DETECTED(reason_code)\n/ B_ESDC_RECORD_TIME_OR_CERT_DEGRADED(reason_code)

ST_ESDC_DEGRADED_LOCAL_ONLY --> ST_ESDC_BLOCKED : EV_ESDC_SECURE_ELEMENT_PATH_LOST(reason_code)\n/ B_ESDC_NOTE_SECURE_ELEMENT_PATH_CHANGE(unavailable)

ST_ESDC_DEGRADED_LOCAL_ONLY --> ST_ESDC_BLOCKED : EV_ESDC_FATAL_RUNTIME_FAULT(code)\n/ B_ESDC_RECORD_FATAL_FAULT(code)

ST_ESDC_BLOCKED --> ST_ESDC_ACCEPTING : EV_ESDC_STATUS_REFRESHED(status)\n[G_ESDC_RUNTIME_RESPONSIVE() && G_ESDC_STATUS_SERVICEABLE(status) && G_ESDC_SECURE_ELEMENT_PATH_USABLE() && !G_ESDC_PIN_REQUIRED(status) && !G_ESDC_AUDIT_REQUIRED(status) && G_ESDC_TIME_OR_CERT_OK() && G_ESDC_BACKEND_PATH_USABLE()]\n/ B_ESDC_EVALUATE_STATUS(status)

ST_ESDC_BLOCKED --> ST_ESDC_DEGRADED_LOCAL_ONLY : EV_ESDC_STATUS_REFRESHED(status)\n[G_ESDC_RUNTIME_RESPONSIVE() && G_ESDC_LOCAL_ONLY_OPERATION_POSSIBLE() && G_ESDC_SECURE_ELEMENT_PATH_USABLE() && !G_ESDC_PIN_REQUIRED(status) && !G_ESDC_AUDIT_REQUIRED(status) && G_ESDC_TIME_OR_CERT_OK() && !G_ESDC_BACKEND_PATH_USABLE()]\n/ B_ESDC_EVALUATE_STATUS(status)

ST_ESDC_BLOCKED --> ST_ESDC_ACCEPTING : EV_ESDC_PIN_VERIFIED_OK()\n[G_ESDC_RUNTIME_RESPONSIVE() && G_ESDC_SECURE_ELEMENT_PATH_USABLE() && G_ESDC_BACKEND_PATH_USABLE()]\n/ B_ESDC_APPLY_PIN_RECOVERY_SUCCESS()

ST_ESDC_BLOCKED --> ST_ESDC_DEGRADED_LOCAL_ONLY : EV_ESDC_PIN_VERIFIED_OK()\n[G_ESDC_RUNTIME_RESPONSIVE() && G_ESDC_SECURE_ELEMENT_PATH_USABLE() && G_ESDC_LOCAL_ONLY_OPERATION_POSSIBLE() && !G_ESDC_BACKEND_PATH_USABLE()]\n/ B_ESDC_APPLY_PIN_RECOVERY_SUCCESS()

@enduml