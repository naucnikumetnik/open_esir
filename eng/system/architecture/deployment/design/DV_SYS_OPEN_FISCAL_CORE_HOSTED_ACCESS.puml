@startuml
title Open Fiscal Core Deployment — hosted access variant

hide footbox
skinparam Shadowing false
skinparam PackageStyle rectangle
skinparam DefaultFontName Monospace
skinparam ComponentStyle rectangle

package "Z_CLIENT_ACCESS — Business and operator access" as Z_CLIENT_ACCESS <<zone>> {

  node "N_BUSINESS_DEVICE\nPOS / ERP client / cashier device" as N_BUSINESS_DEVICE <<physical_machine,external>> {
    artifact "RB_BUSINESS_APP_RUNTIME\nBusiness application runtime" as RB_BUSINESS_APP_RUNTIME <<runtime_boundary,process_space,external>>
  }

  node "N_OPERATOR_DEVICE\nOperator workstation / service console" as N_OPERATOR_DEVICE <<physical_machine,external,optional>> {
    artifact "RB_OPERATOR_RUNTIME\nOperator runtime" as RB_OPERATOR_RUNTIME <<runtime_boundary,process_space,external,optional>>
  }
}

package "Z_CLOUD_OPEN_FISCAL_CORE — Hosted business-facing access" as Z_CLOUD_OPEN_FISCAL_CORE <<zone>> {

  node "N_OFC_CLOUD_RUNTIME\nCloud runtime" as N_OFC_CLOUD_RUNTIME <<cloud_service>> {

    artifact "RB_OFC_CLOUD_RUNTIME\nHosted OFC runtime" as RB_OFC_CLOUD_RUNTIME <<runtime_boundary,service>> {
      component "DEP_ESIR_CLOUD\nESIR" as DEP_ESIR_CLOUD <<hosted_component>>
      component "DEP_REMOTE_COORDINATION\nRemoteCoordination" as DEP_REMOTE_COORDINATION <<hosted_component,optional>>
    }

    folder "FS_OFC_CLOUD_CONFIG\ncloud config / tenant metadata" as FS_OFC_CLOUD_CONFIG <<storage>>
    folder "FS_COUNTER_STORE_CLOUD\nreceipt counters / sequence state" as FS_COUNTER_STORE_CLOUD <<storage>>

    interface "EP_ESIR_PROV_ESIR_SERVICE_HOSTED\nprovider=ESIR Service\ncm=CI_BIND_EP_ESIR_PROV_ESIR_SERVICE_HOSTED" as EP_ESIR_PROV_ESIR_SERVICE_HOSTED <<endpoint>>

    N_OFC_CLOUD_RUNTIME o-- RB_OFC_CLOUD_RUNTIME
    N_OFC_CLOUD_RUNTIME o-- FS_OFC_CLOUD_CONFIG
    N_OFC_CLOUD_RUNTIME o-- FS_COUNTER_STORE_CLOUD
    RB_OFC_CLOUD_RUNTIME o-- EP_ESIR_PROV_ESIR_SERVICE_HOSTED
  }

  note right of RB_OFC_CLOUD_RUNTIME
    Hosted access exposes the ESIR-facing business API from cloud.
    This does not eliminate the tenant-local edge part.
    Secure-element access, local audit journal, backend sync,
    and removable-media export remain tenant-local.
  end note
  
}

package "Z_TENANT_SITE — Tenant-local edge capability" as Z_TENANT_SITE <<zone>> {

  node "N_TENANT_EDGE_HOST\nTenant edge host\n(local gateway / mini-PC / site service)" as N_TENANT_EDGE_HOST <<physical_machine>> {

    artifact "RB_OFC_EDGE_RUNTIME\nTenant edge runtime" as RB_OFC_EDGE_RUNTIME <<runtime_boundary,process_space>> {
      component "DEP_BOOTSTRAP_EDGE\nBootstrap" as DEP_BOOTSTRAP_EDGE <<hosted_component>>
      component "DEP_ESDC_EDGE\nE-SDC" as DEP_ESDC_EDGE <<hosted_component>>
      component "DEP_STATUS_RECOVERY_EDGE\nStatusAndOperatorRecovery" as DEP_STATUS_RECOVERY_EDGE <<hosted_component>>
      component "DEP_AUDIT_PROOF_EDGE\nAuditAndProofLifecycle" as DEP_AUDIT_PROOF_EDGE <<hosted_component>>
      component "DEP_EXPORT_EDGE\nLocalAuditExport" as DEP_EXPORT_EDGE <<hosted_component,optional>>
    }

    folder "FS_EDGE_CONFIG\nedge managed config storage" as FS_EDGE_CONFIG <<storage>>
    folder "FS_LOCAL_AUDIT_JOURNAL\nlocal audit journal" as FS_LOCAL_AUDIT_JOURNAL <<storage>>
    folder "FS_PROOF_STORE\nproof / verification evidence" as FS_PROOF_STORE <<storage>>
    folder "FS_COMMAND_STATE\nbackend command state" as FS_COMMAND_STATE <<storage>>
    folder "FS_EXPORT_STAGING\nexport staging area" as FS_EXPORT_STAGING <<storage,optional>>

    interface "EP_ESDC_PROV_ESDC_SERVICE_EDGE\nprovider=E-SDC Service\ncm=CI_BIND_EP_ESDC_PROV_ESDC_SERVICE_EDGE" as EP_ESDC_PROV_ESDC_SERVICE_EDGE <<endpoint>>

    N_TENANT_EDGE_HOST o-- RB_OFC_EDGE_RUNTIME
    N_TENANT_EDGE_HOST o-- FS_EDGE_CONFIG
    N_TENANT_EDGE_HOST o-- FS_LOCAL_AUDIT_JOURNAL
    N_TENANT_EDGE_HOST o-- FS_PROOF_STORE
    N_TENANT_EDGE_HOST o-- FS_COMMAND_STATE
    N_TENANT_EDGE_HOST o-- FS_EXPORT_STAGING

    RB_OFC_EDGE_RUNTIME o-- EP_ESDC_PROV_ESDC_SERVICE_EDGE
  }

  note right of RB_OFC_EDGE_RUNTIME
    Edge runtime remains tenant-local because it owns:
    - secure-element access
    - local audit persistence
    - backend sync / command lifecycle
    - local export capability
    Edge-to-cloud connectivity should be modeled as outbound,
    edge-initiated reachability.
    No direct inbound internet reachability to tenant edge
    is assumed by default.
  end note

  node "N_SE_DEVICE\nSecurity Element access device" as N_SE_DEVICE <<other,external>> {
    artifact "DEP_EXT_SE\nEXT_SECURITY_ELEMENT" as DEP_EXT_SE <<deployment,service,external>>
    interface "EP_SE_PROV_SECURE_ELEMENT_LOCAL\nprovider=Secure Element\ncm=CI_BIND_EP_SE_PROV_SECURE_ELEMENT_LOCAL" as EP_SE_PROV_SECURE_ELEMENT_LOCAL <<endpoint>>
    DEP_EXT_SE o-- EP_SE_PROV_SECURE_ELEMENT_LOCAL
  }

  node "N_PKI_CONTEXT\nPKI Applet / Client Certificate context" as N_PKI_CONTEXT <<other,external>> {
    artifact "DEP_EXT_PKI_CONTEXT\nEXT_PKI_CLIENT_CONTEXT" as DEP_EXT_PKI_CONTEXT <<deployment,service,external>>
    interface "EP_PKI_PROV_CLIENT_CERT_CONTEXT_LOCAL\nprovider=PKI Client Context\ncm=CI_BIND_EP_PKI_PROV_CLIENT_CERT_CONTEXT_LOCAL" as EP_PKI_PROV_CLIENT_CERT_CONTEXT_LOCAL <<endpoint>>
    DEP_EXT_PKI_CONTEXT o-- EP_PKI_PROV_CLIENT_CERT_CONTEXT_LOCAL
  }

  node "N_REMOVABLE_MEDIA\nUSB / SD / removable medium" as N_REMOVABLE_MEDIA <<other,external,optional>> {
    artifact "DEP_EXT_REMOVABLE_MEDIA\nEXT_REMOVABLE_MEDIA_IO" as DEP_EXT_REMOVABLE_MEDIA <<deployment,service,external,optional>>
    interface "EP_MEDIA_PROV_REMOVABLE_MEDIA_IO_LOCAL\nprovider=Removable Media I/O\ncm=CI_BIND_EP_MEDIA_PROV_REMOVABLE_MEDIA_IO_LOCAL" as EP_MEDIA_PROV_REMOVABLE_MEDIA_IO_LOCAL <<endpoint,optional>>
    DEP_EXT_REMOVABLE_MEDIA o-- EP_MEDIA_PROV_REMOVABLE_MEDIA_IO_LOCAL
  }
}

package "Z_TAXCORE_EXTERNAL — External fiscal / tax services" as Z_TAXCORE_EXTERNAL <<zone>> {

  node "N_VSDC\nV-SDC / TaxCore Cloud" as N_VSDC <<cloud_service,external>> {
    artifact "DEP_EXT_VSDC\nEXT_VSDC" as DEP_EXT_VSDC <<deployment,service,external>>
    interface "EP_VSDC_PROV_TAXCORE_VSDC_REMOTE\nprovider=TaxCore V-SDC\ncm=CI_BIND_EP_VSDC_PROV_TAXCORE_VSDC_REMOTE" as EP_VSDC_PROV_TAXCORE_VSDC_REMOTE <<endpoint>>
    N_VSDC o-- DEP_EXT_VSDC
    DEP_EXT_VSDC o-- EP_VSDC_PROV_TAXCORE_VSDC_REMOTE
  }

  node "N_TAXCORE_SHARED\nTaxCore.API Shared" as N_TAXCORE_SHARED <<cloud_service,external>> {
    artifact "DEP_EXT_TCS\nEXT_TAXCORE_SHARED" as DEP_EXT_TCS <<deployment,service,external>>
    interface "EP_TCS_PROV_TAXCORE_SHARED_REMOTE\nprovider=TaxCore Shared\ncm=CI_BIND_EP_TCS_PROV_TAXCORE_SHARED_REMOTE" as EP_TCS_PROV_TAXCORE_SHARED_REMOTE <<endpoint>>
    N_TAXCORE_SHARED o-- DEP_EXT_TCS
    DEP_EXT_TCS o-- EP_TCS_PROV_TAXCORE_SHARED_REMOTE
  }

  node "N_TAXCORE_BACKEND\nTaxCore Backend (E-SDC API)" as N_TAXCORE_BACKEND <<cloud_service,external>> {
    artifact "DEP_EXT_TCB\nEXT_TAXCORE_ESDC_BACKEND" as DEP_EXT_TCB <<deployment,service,external>>
    interface "EP_TCB_PROV_TAXCORE_ESDC_BACKEND_REMOTE\nprovider=TaxCore E-SDC Backend\ncm=CI_BIND_EP_TCB_PROV_TAXCORE_ESDC_BACKEND_REMOTE" as EP_TCB_PROV_TAXCORE_ESDC_BACKEND_REMOTE <<endpoint>>
    N_TAXCORE_BACKEND o-- DEP_EXT_TCB
    DEP_EXT_TCB o-- EP_TCB_PROV_TAXCORE_ESDC_BACKEND_REMOTE
  }
}

  'Hosted access deployment variant.
  'Business-facing ESIR access is cloud-hosted, while E-SDC and all
  'secure/offline-sensitive capabilities remain tenant-local on edge.
  'This variant optimizes central access and remote operations,
  'not maximum tenant-side autonomy during WAN outage.
  'Local journaling, proof/evidence retention, and secure-element
  'ownership still remain tenant-local in this variant.


' -------------------------
' COMM PATHS (CP_*)
' -------------------------
RB_BUSINESS_APP_RUNTIME --> EP_ESIR_PROV_ESIR_SERVICE_HOSTED : CP_BA__ESIR__ESIR_SERVICE_HOSTED_ACCESS | network | remote_api
RB_OPERATOR_RUNTIME --> EP_ESIR_PROV_ESIR_SERVICE_HOSTED : CP_OP__ESIR__ESIR_SERVICE_HOSTED_ACCESS | network | remote_api
N_TENANT_EDGE_HOST --> N_OFC_CLOUD_RUNTIME : CP_ESIR__ESDC__ESDC_SERVICE_HOSTED_ACCESS | network | edge_initiated_secure_tunnel
N_TENANT_EDGE_HOST --> N_SE_DEVICE : CP_ESDC__SE__SECURE_ELEMENT_HOSTED_ACCESS | local_device | device_local
N_TENANT_EDGE_HOST --> N_PKI_CONTEXT : CP_ESDC__PKI__CLIENT_CERT_CONTEXT_HOSTED_ACCESS | local_device | local_api / applet
N_TENANT_EDGE_HOST --> N_TAXCORE_SHARED : CP_ESDC__TCS__TAXCORE_SHARED_HOSTED_ACCESS | network | remote_api
N_OFC_CLOUD_RUNTIME --> N_VSDC : CP_ESIR__VSDC__TAXCORE_VSDC_HOSTED_ACCESS | network | remote_api
N_TENANT_EDGE_HOST --> N_TAXCORE_BACKEND : CP_ESDC__TCB__TAXCORE_ESDC_BACKEND_HOSTED_ACCESS | network | remote_api
N_TENANT_EDGE_HOST --> N_REMOVABLE_MEDIA : CP_ESDC__MEDIA__REMOVABLE_MEDIA_IO_HOSTED_ACCESS | local_device | filesystem / removable_media

' -------------------------
' STORAGE BINDINGS
' -------------------------
DEP_REMOTE_COORDINATION ..> FS_OFC_CLOUD_CONFIG : CB_REMOTE_COORDINATION__FS_OFC_CLOUD_CONFIG_HOSTED_ACCESS | transport=managed_storage | root=tenant_config
DEP_ESIR_CLOUD ..> FS_COUNTER_STORE_CLOUD : CB_ESIR_CLOUD__FS_COUNTER_STORE_CLOUD_HOSTED_ACCESS | transport=managed_storage | root=counters
DEP_BOOTSTRAP_EDGE ..> FS_EDGE_CONFIG : CB_BOOTSTRAP_EDGE__FS_EDGE_CONFIG_HOSTED_ACCESS | transport=local_fs | root=config
DEP_ESDC_EDGE ..> FS_LOCAL_AUDIT_JOURNAL : CB_ESDC_EDGE__FS_LOCAL_AUDIT_JOURNAL_HOSTED_ACCESS | transport=local_fs | root=audit_journal
DEP_AUDIT_PROOF_EDGE ..> FS_PROOF_STORE : CB_AUDIT_PROOF_EDGE__FS_PROOF_STORE_HOSTED_ACCESS | transport=local_fs | root=proof_store
DEP_STATUS_RECOVERY_EDGE ..> FS_COMMAND_STATE : CB_STATUS_RECOVERY_EDGE__FS_COMMAND_STATE_HOSTED_ACCESS | transport=local_fs | root=command_state
DEP_EXPORT_EDGE ..> FS_EXPORT_STAGING : CB_EXPORT_EDGE__FS_EXPORT_STAGING_HOSTED_ACCESS | transport=local_fs | root=export_staging

' -------------------------
' ENDPOINT BINDINGS
' -------------------------
DEP_ESIR_CLOUD ..> EP_ESIR_PROV_ESIR_SERVICE_HOSTED : CB_BA__ESIR__ESIR_SERVICE_HOSTED_ACCESS | connector=C_BA__ESIR__ESIR_SERVICE | cp=CP_BA__ESIR__ESIR_SERVICE_HOSTED_ACCESS | ep=EP_ESIR_PROV_ESIR_SERVICE_HOSTED | cm=CI_BIND_CB_BA__ESIR__ESIR_SERVICE_HOSTED_ACCESS
DEP_ESIR_CLOUD ..> EP_ESIR_PROV_ESIR_SERVICE_HOSTED : CB_OP__ESIR__ESIR_SERVICE_HOSTED_ACCESS | connector=C_OP__ESIR__ESIR_SERVICE | cp=CP_OP__ESIR__ESIR_SERVICE_HOSTED_ACCESS | ep=EP_ESIR_PROV_ESIR_SERVICE_HOSTED | cm=CI_BIND_CB_OP__ESIR__ESIR_SERVICE_HOSTED_ACCESS
DEP_ESDC_EDGE ..> EP_ESDC_PROV_ESDC_SERVICE_EDGE : CB_ESIR__ESDC__ESDC_SERVICE_HOSTED_ACCESS | connector=C_ESIR__ESDC__ESDC_SERVICE | cp=CP_ESIR__ESDC__ESDC_SERVICE_HOSTED_ACCESS | ep=EP_ESDC_PROV_ESDC_SERVICE_EDGE | cm=CI_BIND_CB_ESIR__ESDC__ESDC_SERVICE_HOSTED_ACCESS
DEP_ESIR_CLOUD ..> EP_VSDC_PROV_TAXCORE_VSDC_REMOTE : CB_ESIR__VSDC__TAXCORE_VSDC_HOSTED_ACCESS | connector=C_ESIR__VSDC__TAXCORE_VSDC | cp=CP_ESIR__VSDC__TAXCORE_VSDC_HOSTED_ACCESS | ep=EP_VSDC_PROV_TAXCORE_VSDC_REMOTE | cm=CI_BIND_CB_ESIR__VSDC__TAXCORE_VSDC_HOSTED_ACCESS
DEP_ESDC_EDGE ..> EP_TCS_PROV_TAXCORE_SHARED_REMOTE : CB_ESDC__TCS__TAXCORE_SHARED_HOSTED_ACCESS | connector=C_ESDC__TCS__TAXCORE_SHARED | cp=CP_ESDC__TCS__TAXCORE_SHARED_HOSTED_ACCESS | ep=EP_TCS_PROV_TAXCORE_SHARED_REMOTE | cm=CI_BIND_CB_ESDC__TCS__TAXCORE_SHARED_HOSTED_ACCESS
DEP_ESDC_EDGE ..> EP_SE_PROV_SECURE_ELEMENT_LOCAL : CB_ESDC__SE__SECURE_ELEMENT_HOSTED_ACCESS | connector=C_ESDC__SE__SECURE_ELEMENT | cp=CP_ESDC__SE__SECURE_ELEMENT_HOSTED_ACCESS | ep=EP_SE_PROV_SECURE_ELEMENT_LOCAL | cm=CI_BIND_CB_ESDC__SE__SECURE_ELEMENT_HOSTED_ACCESS
DEP_ESDC_EDGE ..> EP_PKI_PROV_CLIENT_CERT_CONTEXT_LOCAL : CB_ESDC__PKI__CLIENT_CERT_CONTEXT_HOSTED_ACCESS | connector=C_ESDC__PKI__CLIENT_CERT_CONTEXT | cp=CP_ESDC__PKI__CLIENT_CERT_CONTEXT_HOSTED_ACCESS | ep=EP_PKI_PROV_CLIENT_CERT_CONTEXT_LOCAL | cm=CI_BIND_CB_ESDC__PKI__CLIENT_CERT_CONTEXT_HOSTED_ACCESS
DEP_ESDC_EDGE ..> EP_TCB_PROV_TAXCORE_ESDC_BACKEND_REMOTE : CB_ESDC__TCB__TAXCORE_ESDC_BACKEND_HOSTED_ACCESS | connector=C_ESDC__TCB__TAXCORE_ESDC_BACKEND | cp=CP_ESDC__TCB__TAXCORE_ESDC_BACKEND_HOSTED_ACCESS | ep=EP_TCB_PROV_TAXCORE_ESDC_BACKEND_REMOTE | cm=CI_BIND_CB_ESDC__TCB__TAXCORE_ESDC_BACKEND_HOSTED_ACCESS
DEP_EXPORT_EDGE ..> EP_MEDIA_PROV_REMOVABLE_MEDIA_IO_LOCAL : CB_ESDC__MEDIA__REMOVABLE_MEDIA_IO_HOSTED_ACCESS | connector=C_ESDC__MEDIA__REMOVABLE_MEDIA_IO | cp=CP_ESDC__MEDIA__REMOVABLE_MEDIA_IO_HOSTED_ACCESS | ep=EP_MEDIA_PROV_REMOVABLE_MEDIA_IO_LOCAL | cm=CI_BIND_CB_ESDC__MEDIA__REMOVABLE_MEDIA_IO_HOSTED_ACCESS


  'This variant is suitable when centralized access, remote operations,
  'or multi-site exposure matter more than hard local autonomy.
  'If uninterrupted tenant-local invoice submission during WAN outage
  'is required, use embedded or local-service deployment instead,
  'or define an additional local fallback deployment outside this variant.
@enduml
