@startuml
title Detect and validate removable media — E-SDC leaf

hide footbox
autonumber 10 10
skinparam BoxPadding 12
skinparam SequenceMessageAlign center
skinparam Shadowing false
skinparam ParticipantPadding 18
skinparam ResponseMessageBelowArrow true
skinparam DefaultFontName Monospace

participant "Caller\n(EsdcFacade)" as CC_FACADE

box "E-SDC — Internal Components" #F3F3F3
  control "RemovableMediaAdapter" as CC_RMA <<component>>
end box

box "External Dependencies" #EEF5FF
  storage "Removable Media\n(SD Card / USB)" as EXT_MEDIA <<external>>
end box

note over CC_FACADE, EXT_MEDIA #FFF8DC
S_LEAF_ESDC_DETECT_AND_VALIDATE_MEDIA
parent_ref: S_CMP_ESDC_LOCAL_AUDIT_EXPORT_MASTER / GRP_LOCAL_EXPORT_TRIGGER
behavior_ref: B_ESDC_LOCAL_AUDIT_EXPORT_DETECT_MEDIA
end note

note over CC_RMA
  RemovableMediaAdapter detects media insertion events, validates
  the filesystem type and mount access, and reports readiness.
  The adapter also inspects the media root for a {UID}.commands
  file to signal whether command import is required.
end note

' ============================================================================
' S1 — Detect media insertion
' ============================================================================
group S1 "GRP_DETECT_MEDIA"
  CC_FACADE -> CC_RMA : IF_CMP_ESDC_REMOVABLE_MEDIA.detectMedia() -> Result[MediaDetectionResult]\n[step=S1.1]\n[connection use_port=P_FACADE_USE_REMOVABLE_MEDIA; prov_port=P_RMA_PROV_REMOVABLE_MEDIA; conn=C_FACADE__RMA__REMOVABLE_MEDIA]
  activate CC_RMA
  CC_RMA -> CC_RMA : listen for media insertion event\n[step=S1.2]
  CC_RMA -> EXT_MEDIA : IF_DEP_REMOVABLE_MEDIA_IO.probeFilesystem() -> Result[FilesystemProbeResult]\n[step=S1.3]\n[connection use_port=P_ESDC_USE_REMOVABLE_MEDIA_IO; prov_port=P_MEDIA_PROV_REMOVABLE_MEDIA_IO; conn=C_ESDC__MEDIA__REMOVABLE_MEDIA_IO]
  activate EXT_MEDIA
  EXT_MEDIA --> CC_RMA : [step=S1.3r]\n[vals filesystem=<FAT32|NTFS|ext4|unsupported>; writable=<bool>]
  deactivate EXT_MEDIA
end

' ============================================================================
' S2 — Validate media readiness
' ============================================================================
group S2 "GRP_VALIDATE_MEDIA"
  alt [COND=filesystem supported AND writable]
    CC_RMA -> CC_RMA : media validated\n[step=S2.1a]\n[vals media_valid=true]

    ' ======================================================================
    ' S3 — Inspect for command file
    ' ======================================================================
    group S3 "GRP_INSPECT_COMMAND_FILE"
      CC_RMA -> EXT_MEDIA : IF_DEP_REMOVABLE_MEDIA_IO.inspectFile(path:string) -> Result[FileInspectResult]\n[step=S3.1]\n[connection use_port=P_ESDC_USE_REMOVABLE_MEDIA_IO; prov_port=P_MEDIA_PROV_REMOVABLE_MEDIA_IO; conn=C_ESDC__MEDIA__REMOVABLE_MEDIA_IO]\n[vals search_pattern=<active_se_uid>.commands]
      activate EXT_MEDIA
      EXT_MEDIA --> CC_RMA : [step=S3.1r]\n[vals commands_file_present=<bool>]
      deactivate EXT_MEDIA
    end

    CC_RMA --> CC_FACADE : [step=S2.2a]\n[vals result=MediaDetectionResult(ready=true; commands_file_present=<bool>)]
    deactivate CC_RMA

  else [COND=filesystem unsupported OR not writable]
    CC_RMA --> CC_FACADE : [step=S2.1e]\n[vals result=MediaDetectionResult(ready=false; reason=<unsupported_filesystem|read_only>)]
    deactivate CC_RMA
  end
end

@enduml
