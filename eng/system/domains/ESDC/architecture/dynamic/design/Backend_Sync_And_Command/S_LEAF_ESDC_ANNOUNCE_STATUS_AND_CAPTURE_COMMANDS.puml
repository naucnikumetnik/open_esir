@startuml
title Announce online status and capture commands — E-SDC leaf

hide footbox
autonumber 10 10
skinparam BoxPadding 12
skinparam SequenceMessageAlign center
skinparam Shadowing false
skinparam ParticipantPadding 18
skinparam ResponseMessageBelowArrow true
skinparam DefaultFontName Monospace

box "E-SDC — Internal Components" #F3F3F3
  control "CommandLifecycleCoordinator" as CC_CLC <<component>>
  control "TaxCoreEsdcBackendAdapter" as CC_TBA <<component>>
end box

box "External Dependencies" #EEF5FF
  control "TaxCore Backend\n(E-SDC API)" as EXT_TCB <<external>>
end box

note over CC_CLC, EXT_TCB #FFF8DC
S_LEAF_ESDC_ANNOUNCE_STATUS_AND_CAPTURE_COMMANDS
parent_ref: S_CMP_ESDC_BACKEND_SYNC_MASTER / GRP_BACKEND_SYNC_ANNOUNCE_AND_CAPTURE
behavior_ref: B_ESDC_BACKEND_SYNC_ANNOUNCE_STATUS, B_ESDC_BACKEND_SYNC_CAPTURE_COMMANDS
end note

note over CC_CLC, CC_TBA
  Online status announcement informs TaxCore Backend of E-SDC availability.
  The status response may contain piggy-backed commands.
  Optionally, an explicit initialization command pull is performed
  when a configuration refresh is required.
end note

' ============================================================================
' S1 — Announce online status
' ============================================================================
group S1 "GRP_STATUS_ANNOUNCE"
  CC_CLC -> CC_TBA : IF_CMP_ESDC_TAXCORE_ESDC_BACKEND.notifyOnlineStatus(online:bool) -> Result[Command[]]\n[step=S1.1]\n[connection use_port=P_CLC_USE_TAXCORE_ESDC_BACKEND; prov_port=P_TBA_PROV_TAXCORE_ESDC_BACKEND; conn=C_CLC__TBA__TAXCORE_ESDC_BACKEND]\n[vals online=true]
  activate CC_TBA
  CC_TBA -> EXT_TCB : IF_DEP_TAXCORE_ESDC_BACKEND.NotifyOnlineStatus(body:BooleanFlagBody) -> Command[]\n[step=S1.2]\n[connection use_port=P_ESDC_USE_TAXCORE_ESDC_BACKEND; prov_port=P_TCB_PROV_TAXCORE_ESDC_BACKEND; conn=C_ESDC__TCB__TAXCORE_ESDC_BACKEND]\n[CTR-302 · HTTPS PUT /api/v3/sdc/status · TaxCoreAuthenticationToken]
  activate EXT_TCB
  EXT_TCB --> CC_TBA : [step=S1.2r]\n[vals result=Command[](commandId, type, payload, uid)]
  deactivate EXT_TCB
  CC_TBA --> CC_CLC : [step=S1.1r]\n[vals status_commands=<Command[]>]
  deactivate CC_TBA
end

' ============================================================================
' S2 — Capture commands from status response
' ============================================================================
group S2 "GRP_STATUS_CAPTURE_COMMANDS"
  alt [COND=status_commands non-empty]
    CC_CLC -> CC_CLC : persist received commands to command backlog\n[step=S2.1]\n[vals commands_captured=true; command_count=<n>]\n[store_write entity=E_BACKEND_COMMAND_RECORD; entity=E_BACKEND_COMMAND_INDEX; pattern_ref=AP_CMP_CAPTURE_COMMANDS]
  else [COND=status_commands empty]
    CC_CLC -> CC_CLC : no commands from status response\n[step=S2.2]\n[vals commands_captured=false]
  end
end

' ============================================================================
' S3 — Optionally pull initialization commands (explicit refresh)
' ============================================================================
alt [COND=explicit_initialization_refresh_required]
  group S3 "GRP_STATUS_PULL_INIT_COMMANDS"
    CC_CLC -> CC_TBA : IF_CMP_ESDC_TAXCORE_ESDC_BACKEND.getInitializationCommands() -> Result[Command[]]\n[step=S3.1]\n[connection use_port=P_CLC_USE_TAXCORE_ESDC_BACKEND; prov_port=P_TBA_PROV_TAXCORE_ESDC_BACKEND; conn=C_CLC__TBA__TAXCORE_ESDC_BACKEND]
    activate CC_TBA
    CC_TBA -> EXT_TCB : IF_DEP_TAXCORE_ESDC_BACKEND.GetInitializationCommands() -> Command[]\n[step=S3.2]\n[connection use_port=P_ESDC_USE_TAXCORE_ESDC_BACKEND; prov_port=P_TCB_PROV_TAXCORE_ESDC_BACKEND; conn=C_ESDC__TCB__TAXCORE_ESDC_BACKEND]\n[CTR-304 · HTTPS GET /api/v3/sdc/commands · TaxCoreAuthenticationToken]
    activate EXT_TCB
    EXT_TCB --> CC_TBA : [step=S3.2r]\n[vals result=Command[]]
    deactivate EXT_TCB
    CC_TBA --> CC_CLC : [step=S3.1r]\n[vals init_commands=<Command[]>]
    deactivate CC_TBA

    alt [COND=init_commands non-empty]
      CC_CLC -> CC_CLC : append initialization commands to command backlog\n[step=S3.3]\n[vals commands_captured=true; command_count+=<n>]\n[store_write entity=E_BACKEND_COMMAND_RECORD; entity=E_BACKEND_COMMAND_INDEX; pattern_ref=AP_CMP_CAPTURE_COMMANDS]
    end
  end
end

@enduml
