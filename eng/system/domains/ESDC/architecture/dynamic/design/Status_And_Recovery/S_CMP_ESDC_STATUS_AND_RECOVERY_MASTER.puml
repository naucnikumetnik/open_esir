@startuml
title Status and operator recovery — E-SDC domain master

hide footbox
autonumber 10 10
skinparam BoxPadding 12
skinparam SequenceMessageAlign center
skinparam Shadowing false
skinparam ParticipantPadding 18
skinparam ResponseMessageBelowArrow true
skinparam DefaultFontName Monospace

participant "Caller\n(EsdcFacade)" as CC_FACADE

box "E-SDC — Internal Components" #F3F3F3
  control "StatusAndOperatorRecoveryManager" as CC_SRM <<component>>
  control "SecureElementAdapter" as CC_SEA <<component>>
end box

box "External Dependencies" #EEF5FF
  entity "SE\n(Security Element)" as EXT_SE <<external>>
end box

note over CC_FACADE, EXT_SE #FFF8DC
S_CMP_ESDC_STATUS_AND_RECOVERY_MASTER
[semantics lifecycle_spine=true]
dynamic_view_ref: S_SYS_STATUS_AND_OPERATOR_RECOVERY (E-SDC portion)
state_machine_ref: SM_SYS_ESDC_SERVING
end note

note over CC_SRM
  StatusAndOperatorRecoveryManager determines E-SDC readiness
  for fiscalization. It probes local availability (including SE),
  evaluates recovery obligations, and when needed performs
  operator-initiated recovery (PIN verify).
end note

' ============================================================================
' S1 — EsdcFacade receives readiness check request
' ============================================================================
group S1 "GRP_STATUS_TRIGGER"
  CC_FACADE -> CC_SRM : IF_CMP_ESDC_STATUS_AND_RECOVERY.checkReady() -> Result[ReadinessResult]\n[step=S1.1]
  activate CC_SRM
end

' ============================================================================
' S2 — Probe E-SDC local availability (inter-component: SRM → SEA → SE)
' ============================================================================
group S2 "GRP_STATUS_PROBE"
  ref over CC_SRM, CC_SEA, EXT_SE
    expand=S_LEAF_ESDC_PROBE_AVAILABILITY
    ref_mode=call_return
  end ref
end

alt [COND=local_unavailable]
  CC_SRM --> CC_FACADE : [step=S2.reject]\n[vals result.outcome=ok; result.ok=ReadinessResult(unavailable; reason=<runtime_error|smart_card_missing>)]
  deactivate CC_SRM

else [COND=local_available]

  ' ==========================================================================
  ' S3 — Evaluate recovery needs (internal to SRM — collapsed)
  ' ==========================================================================
  note over CC_SRM
    Evaluate recovery needs (collapsed — no inter-component calls):
      Read StatusResponse flags: isPinRequired, auditRequired, sdcDateTime, uid, gsc
      Priority-ordered evaluation:
        auditRequired == true → recovery_action=audit_required
        isPinRequired == true → recovery_action=pin_verify
        time_sync_ok == false → recovery_action=degraded (time_desynchronized)
        cert_valid == false → recovery_action=degraded (certificate_expired)
        all passed → recovery_action=none (ready)
    behavior_ref: B_ESDC_STATUS_EVALUATE_RECOVERY
  end note

  ' ==========================================================================
  ' S4 — Act on recovery evaluation
  ' ==========================================================================
  alt [COND=recovery_action == audit_required]
    CC_SRM --> CC_FACADE : [step=S4.1a]\n[vals result.outcome=ok; result.ok=ReadinessResult(audit_required)]
    deactivate CC_SRM

  else [COND=recovery_action == pin_verify]
    group S4 "GRP_STATUS_RECOVER_PIN"
      ref over CC_FACADE, CC_SRM, CC_SEA, EXT_SE
        expand=S_LEAF_ESDC_RECOVER_PIN
        ref_mode=call_return
      end ref
    end

  else [COND=recovery_action == degraded]
    CC_SRM --> CC_FACADE : [step=S4.1c]\n[vals result.outcome=ok; result.ok=ReadinessResult(degraded; reason=<time_invalid|certificate_expired>)]
    deactivate CC_SRM

  else [COND=recovery_action == none (ready)]
    CC_SRM --> CC_FACADE : [step=S4.1d]\n[vals result.outcome=ok; result.ok=ReadinessResult(ready)]
    deactivate CC_SRM
  end

end

@enduml
